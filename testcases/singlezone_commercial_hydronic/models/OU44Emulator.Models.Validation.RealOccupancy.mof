// Initial equations and algorithms

  // Component ahu.fanSu.filter
  // class Modelica.Blocks.Continuous.Filter
  initial equation
    if (ahu.fanSu.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
      CriticalDamping) then 
      ahu.fanSu.filter.cr = Modelica.Blocks.Continuous.Internal.Filter.base.CriticalDamping
        (ahu.fanSu.filter.order, ahu.fanSu.filter.normalized);
    elseif (ahu.fanSu.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
      Bessel) then 
      (ahu.fanSu.filter.cr, ahu.fanSu.filter.c0, ahu.fanSu.filter.c1)  = 
        Modelica.Blocks.Continuous.Internal.Filter.base.Bessel(ahu.fanSu.filter.order,
         ahu.fanSu.filter.normalized);
    elseif (ahu.fanSu.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
      Butterworth) then 
      (ahu.fanSu.filter.cr, ahu.fanSu.filter.c0, ahu.fanSu.filter.c1)  = 
        Modelica.Blocks.Continuous.Internal.Filter.base.Butterworth(
        ahu.fanSu.filter.order, ahu.fanSu.filter.normalized);
    elseif (ahu.fanSu.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
      ChebyshevI) then 
      (ahu.fanSu.filter.cr, ahu.fanSu.filter.c0, ahu.fanSu.filter.c1)  = 
        Modelica.Blocks.Continuous.Internal.Filter.base.ChebyshevI(
        ahu.fanSu.filter.order, ahu.fanSu.filter.A_ripple, ahu.fanSu.filter.normalized);
    end if;
    if (ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.LowPass)
       then 
      (ahu.fanSu.filter.r, ahu.fanSu.filter.a, ahu.fanSu.filter.b, 
        ahu.fanSu.filter.ku)  = Modelica.Blocks.Continuous.Internal.Filter.roots.lowPass
        (ahu.fanSu.filter.cr, ahu.fanSu.filter.c0, ahu.fanSu.filter.c1, 
        ahu.fanSu.filter.f_cut);
    elseif (ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.
      HighPass) then 
      (ahu.fanSu.filter.r, ahu.fanSu.filter.a, ahu.fanSu.filter.b, 
        ahu.fanSu.filter.ku, ahu.fanSu.filter.k1, ahu.fanSu.filter.k2)  = 
        Modelica.Blocks.Continuous.Internal.Filter.roots.highPass(
        ahu.fanSu.filter.cr, ahu.fanSu.filter.c0, ahu.fanSu.filter.c1, 
        ahu.fanSu.filter.f_cut);
    elseif (ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.
      BandPass) then 
      (ahu.fanSu.filter.a, ahu.fanSu.filter.b, ahu.fanSu.filter.ku, 
        ahu.fanSu.filter.k1, ahu.fanSu.filter.k2)  = Modelica.Blocks.Continuous.Internal.Filter.roots.bandPass
        (ahu.fanSu.filter.cr, ahu.fanSu.filter.c0, ahu.fanSu.filter.c1, 
        ahu.fanSu.filter.f_min, ahu.fanSu.filter.f_cut);
    elseif (ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.
      BandStop) then 
      (ahu.fanSu.filter.a, ahu.fanSu.filter.b, ahu.fanSu.filter.ku, 
        ahu.fanSu.filter.k1, ahu.fanSu.filter.k2)  = Modelica.Blocks.Continuous.Internal.Filter.roots.bandStop
        (ahu.fanSu.filter.cr, ahu.fanSu.filter.c0, ahu.fanSu.filter.c1, 
        ahu.fanSu.filter.f_min, ahu.fanSu.filter.f_cut);
    end if;
    if (ahu.fanSu.filter.init == Modelica.Blocks.Types.Init.InitialState) then 
      ahu.fanSu.filter.x = ahu.fanSu.filter.x_start;
    elseif (ahu.fanSu.filter.init == Modelica.Blocks.Types.Init.SteadyState)
       then 
      der(ahu.fanSu.filter.x) = zeros(ahu.fanSu.filter.nx);
    elseif (ahu.fanSu.filter.init == Modelica.Blocks.Types.Init.InitialOutput)
       then 
      ahu.fanSu.filter.y = ahu.fanSu.filter.y_start;
      if (ahu.fanSu.filter.nx > 1) then 
        der(ahu.fanSu.filter.x[1:ahu.fanSu.filter.nx-1]) = zeros(
          ahu.fanSu.filter.nx-1);
      end if;
    end if;

  // Component ahu.fanSu.eff
  // class Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface
  initial equation
    assert(ahu.fanSu.eff.nOri > 1, "Must have at least two data points for pressure.V_flow.");
    assert(Buildings.Utilities.Math.Functions.isMonotonic(ahu.fanSu.eff.per.pressure.V_flow,
       true) and ahu.fanSu.eff.per.pressure.V_flow[1] > -1E-15, "The fan pressure rise must be a strictly decreasing sequence with respect to the volume flow rate,
  with the first element for the fan pressure raise being non-zero.
The following performance data have been entered:
"
      +Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface.getArrayAsString(
      ahu.fanSu.eff.per.pressure.V_flow, "pressure.V_flow", 6, 6));
    if ( not ahu.fanSu.eff.haveVMax) then 
      assert((ahu.fanSu.eff.per.pressure.V_flow[ahu.fanSu.eff.nOri]-
        ahu.fanSu.eff.per.pressure.V_flow[ahu.fanSu.eff.nOri-1])/(
        ahu.fanSu.eff.per.pressure.dp[ahu.fanSu.eff.nOri]-ahu.fanSu.eff.per.pressure.dp
        [ahu.fanSu.eff.nOri-1]) < 0, "The last two pressure points for the fan or pump performance curve must be decreasing.
    You need to set more reasonable parameters.
Received
"
        +Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface.getArrayAsString
        (ahu.fanSu.eff.per.pressure.dp, "dp", 6, 6));
    end if;
    if ( not ahu.fanSu.eff.haveMinimumDecrease) then 
      ModelicaInternal_print("
Warning:
========
It is recommended that the volume flow rate versus pressure relation
of the fan or pump satisfies the minimum decrease condition

        (per.pressure.dp[i+1]-per.pressure.dp[i])
d[i] = ------------------------------------------------- < "
        +String( -ahu.fanSu.eff.kRes)+"
       (per.pressure.V_flow[i+1]-per.pressure.V_flow[i])

 is
"
        +Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface.getArrayAsString
        (array((ahu.fanSu.eff.per.pressure.dp[i+1]-ahu.fanSu.eff.per.pressure.dp
        [i])/(ahu.fanSu.eff.per.pressure.V_flow[i+1]-ahu.fanSu.eff.per.pressure.V_flow
        [i]) for i in 1:ahu.fanSu.eff.nOri-1), "d", 6, 6)+"
Otherwise, a solution to the equations may not exist if the fan or pump speed is reduced.
In this situation, the solver will fail due to non-convergence and
the simulation stops.",
         "");
    end if;
    if (ahu.fanSu.eff.haveVMax and ahu.fanSu.eff.haveDPMax or ahu.fanSu.eff.nOri
       == 2) then 
      ahu.fanSu.eff.preDer1 = Buildings.Utilities.Math.Functions.splineDerivatives
        (ahu.fanSu.eff.pCur1.V_flow, ahu.fanSu.eff.pCur1.dp, Buildings.Utilities.Math.Functions.isMonotonic
        (ahu.fanSu.eff.pCur1.dp, false));
      ahu.fanSu.eff.preDer2 = zeros(ahu.fanSu.eff.nOri+1);
      ahu.fanSu.eff.preDer3 = zeros(ahu.fanSu.eff.nOri+2);
    elseif (ahu.fanSu.eff.haveVMax or ahu.fanSu.eff.haveDPMax) then 
      ahu.fanSu.eff.preDer1 = zeros(ahu.fanSu.eff.nOri);
      ahu.fanSu.eff.preDer2 = Buildings.Utilities.Math.Functions.splineDerivatives
        (ahu.fanSu.eff.pCur2.V_flow, ahu.fanSu.eff.pCur2.dp, Buildings.Utilities.Math.Functions.isMonotonic
        (ahu.fanSu.eff.pCur2.dp, false));
      ahu.fanSu.eff.preDer3 = zeros(ahu.fanSu.eff.nOri+2);
    else
      ahu.fanSu.eff.preDer1 = zeros(ahu.fanSu.eff.nOri);
      ahu.fanSu.eff.preDer2 = zeros(ahu.fanSu.eff.nOri+1);
      ahu.fanSu.eff.preDer3 = Buildings.Utilities.Math.Functions.splineDerivatives
        (ahu.fanSu.eff.pCur3.V_flow, ahu.fanSu.eff.pCur3.dp, Buildings.Utilities.Math.Functions.isMonotonic
        (ahu.fanSu.eff.pCur3.dp, false));
    end if;
    ahu.fanSu.eff.motDer = (if ahu.fanSu.eff.per.use_powerCharacteristic then 
      zeros(size(ahu.fanSu.eff.per.motorEfficiency.V_flow, 1)) else (if size(
      ahu.fanSu.eff.per.motorEfficiency.V_flow, 1) == 1 then {0} else 
      Buildings.Utilities.Math.Functions.splineDerivatives(ahu.fanSu.eff.per.motorEfficiency.V_flow,
       ahu.fanSu.eff.per.motorEfficiency.eta, Buildings.Utilities.Math.Functions.isMonotonic
      (ahu.fanSu.eff.per.motorEfficiency.eta, false))));
    ahu.fanSu.eff.hydDer = (if ahu.fanSu.eff.per.use_powerCharacteristic then 
      zeros(size(ahu.fanSu.eff.per.hydraulicEfficiency.V_flow, 1)) else (if size
      (ahu.fanSu.eff.per.hydraulicEfficiency.V_flow, 1) == 1 then {0} else 
      Buildings.Utilities.Math.Functions.splineDerivatives(ahu.fanSu.eff.per.hydraulicEfficiency.V_flow,
       ahu.fanSu.eff.per.hydraulicEfficiency.eta, Buildings.Utilities.Math.Functions.isMonotonic
      (ahu.fanSu.eff.per.hydraulicEfficiency.eta, false))));
    assert(ahu.fanSu.eff.homotopyInitialization, "In RealOccupancy.ahu.fanSu.eff: The constant homotopyInitialization has been modified from its default value. This constant will be removed in future releases.",
       AssertionLevel.warning);

  // Component ahu.fanSu
  // class Buildings.Fluid.Movers.SpeedControlled_y
    // extends Buildings.Fluid.Movers.BaseClasses.PartialFlowMachine
    initial equation
      assert(ahu.fanSu.m_flow_nominal >= 1E-60, "In RealOccupancy.ahu.fanSu: The value of parameter m_flow_nominal should be greater or equal than "
        +String(1E-60)+" but it equals "+String(ahu.fanSu.m_flow_nominal));
      assert(ahu.fanSu.nominalValuesDefineDefaultPressureCurve or 
        ahu.fanSu.per.havePressureCurve or ahu.fanSu.preVar == Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
        Speed, "*** Warning: You are using a flow or pressure controlled mover with the
             default pressure curve.
             This leads to approximate calculations of the electrical power
             consumption. Add the correct pressure curve in the record per
             to obtain an accurate computation.
             Setting nominalValuesDefineDefaultPressureCurve=true will suppress this warning.",
         AssertionLevel.warning);
      assert(ahu.fanSu.nominalValuesDefineDefaultPressureCurve or (
        ahu.fanSu.per.havePressureCurve or ahu.fanSu.preVar == Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
        Speed) or ahu.fanSu.per.use_powerCharacteristic == false, 
        "*** Warning: You are using a flow or pressure controlled mover with the
             default pressure curve and you set use_powerCharacteristic = true.
             Since this can cause wrong power consumption, the model will overwrite
             this setting and use instead use_powerCharacteristic = false.Since this causes the efficiency curve to be used,
             make sure that the efficiency curves in the performance record per
             are correct or add the pressure curve of the mover.
             Setting nominalValuesDefineDefaultPressureCurve=true will suppress this warning.",
         AssertionLevel.warning);
    // end of extends 
  initial equation
    assert(ahu.fanSu.per.havePressureCurve, "SpeedControlled_y requires to set the pressure vs. flow rate curve in record 'per'.");

  // Component ahu.senVolFloIn
  // class Buildings.Fluid.Sensors.VolumeFlowRate
  initial equation
    if (ahu.senVolFloIn.dynamic) then 
      if (ahu.senVolFloIn.initType == Modelica.Blocks.Types.Init.SteadyState)
         then 
        der(ahu.senVolFloIn.d) = 0;
      elseif (ahu.senVolFloIn.initType == Modelica.Blocks.Types.Init.
        InitialState or ahu.senVolFloIn.initType == Modelica.Blocks.Types.Init.
        InitialOutput) then 
        ahu.senVolFloIn.d = ahu.senVolFloIn.d_start;
      end if;
    end if;

  // Component ahu.senTemIn2
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
  initial equation
    if (ahu.senTemIn2.dynamic) then 
      if (ahu.senTemIn2.initType == Modelica.Blocks.Types.Init.SteadyState)
         then 
        der(ahu.senTemIn2.T) = 0;
      elseif (ahu.senTemIn2.initType == Modelica.Blocks.Types.Init.InitialState
         or ahu.senTemIn2.initType == Modelica.Blocks.Types.Init.InitialOutput)
         then 
        ahu.senTemIn2.T = ahu.senTemIn2.T_start;
      end if;
    end if;

  // Component ahu.hex.bal1.vol
  // class Buildings.Fluid.Interfaces.StaticTwoPortConservationEquation
  initial equation
    assert(false or abs(sum(ahu.hex.bal1.vol.s)-1) < 1E-05, "If Medium.nXi > 1, then substance 'water' must be present for one component.'Air'.
Check medium model.");

  // Component ahu.hex.bal1.preDro
  // class Buildings.Fluid.FixedResistances.PressureDrop
    // extends Buildings.Fluid.BaseClasses.PartialResistance
    initial equation
      assert(ahu.hex.bal1.preDro.homotopyInitialization, "In RealOccupancy.ahu.hex.bal1.preDro: The constant homotopyInitialization has been modified from its default value. This constant will be removed in future releases.",
         AssertionLevel.warning);
    // end of extends 
  initial equation
    if (ahu.hex.bal1.preDro.computeFlowResistance) then 
      assert(ahu.hex.bal1.preDro.m_flow_turbulent > 0, "m_flow_turbulent must be bigger than zero.");
    end if;
    assert(ahu.hex.bal1.preDro.m_flow_nominal_pos > 0, "m_flow_nominal_pos must be non-zero. Check parameters.");

  // Component ahu.hex.bal1
  // class Buildings.Fluid.Interfaces.StaticTwoPortHeatMassExchanger
  initial equation
    assert(ahu.hex.bal1.homotopyInitialization, "In RealOccupancy.ahu.hex.bal1: The constant homotopyInitialization has been modified from its default value. This constant will be removed in future releases.",
       AssertionLevel.warning);

  // Component ahu.hex.bal2.vol
  // class Buildings.Fluid.Interfaces.StaticTwoPortConservationEquation
  initial equation
    assert(false or abs(sum(ahu.hex.bal2.vol.s)-1) < 1E-05, "If Medium.nXi > 1, then substance 'water' must be present for one component.'Air'.
Check medium model.");

  // Component ahu.hex.bal2.preDro
  // class Buildings.Fluid.FixedResistances.PressureDrop
    // extends Buildings.Fluid.BaseClasses.PartialResistance
    initial equation
      assert(ahu.hex.bal2.preDro.homotopyInitialization, "In RealOccupancy.ahu.hex.bal2.preDro: The constant homotopyInitialization has been modified from its default value. This constant will be removed in future releases.",
         AssertionLevel.warning);
    // end of extends 
  initial equation
    if (ahu.hex.bal2.preDro.computeFlowResistance) then 
      assert(ahu.hex.bal2.preDro.m_flow_turbulent > 0, "m_flow_turbulent must be bigger than zero.");
    end if;
    assert(ahu.hex.bal2.preDro.m_flow_nominal_pos > 0, "m_flow_nominal_pos must be non-zero. Check parameters.");

  // Component ahu.hex.bal2
  // class Buildings.Fluid.Interfaces.StaticTwoPortHeatMassExchanger
  initial equation
    assert(ahu.hex.bal2.homotopyInitialization, "In RealOccupancy.ahu.hex.bal2: The constant homotopyInitialization has been modified from its default value. This constant will be removed in future releases.",
       AssertionLevel.warning);

  // Component ahu.hex
  // class Buildings.Fluid.HeatExchangers.ConstantEffectiveness
    // extends Buildings.Fluid.Interfaces.StaticFourPortHeatMassExchanger
    initial equation
      assert(ahu.hex.homotopyInitialization, "In RealOccupancy.ahu.hex: The constant homotopyInitialization has been modified from its default value. This constant will be removed in future releases.",
         AssertionLevel.warning);
    // extends Buildings.Fluid.HeatExchangers.BaseClasses.PartialEffectiveness
    initial equation
      ahu.hex.cp1_default = ahu.hex.specificHeatCapacityCp_Unique96(
        ahu.hex.setState_pTX_Unique48(101325, 293.15, {0.01, 0.99}));
      ahu.hex.cp2_default = ahu.hex.specificHeatCapacityCp_Unique98(
        ahu.hex.setState_pTX_Unique53(101325, 293.15, {0.01, 0.99}));
      ahu.hex.CMin_flow_small = min(ahu.hex.m1_flow_small*ahu.hex.cp1_default, 
        ahu.hex.m2_flow_small*ahu.hex.cp2_default);
    // end of extends 

  // Component ahu.senTemEx1
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
  initial equation
    if (ahu.senTemEx1.dynamic) then 
      if (ahu.senTemEx1.initType == Modelica.Blocks.Types.Init.SteadyState)
         then 
        der(ahu.senTemEx1.T) = 0;
      elseif (ahu.senTemEx1.initType == Modelica.Blocks.Types.Init.InitialState
         or ahu.senTemEx1.initType == Modelica.Blocks.Types.Init.InitialOutput)
         then 
        ahu.senTemEx1.T = ahu.senTemEx1.T_start;
      end if;
    end if;

  // Component ahu.senVolFloEx
  // class Buildings.Fluid.Sensors.VolumeFlowRate
  initial equation
    if (ahu.senVolFloEx.dynamic) then 
      if (ahu.senVolFloEx.initType == Modelica.Blocks.Types.Init.SteadyState)
         then 
        der(ahu.senVolFloEx.d) = 0;
      elseif (ahu.senVolFloEx.initType == Modelica.Blocks.Types.Init.
        InitialState or ahu.senVolFloEx.initType == Modelica.Blocks.Types.Init.
        InitialOutput) then 
        ahu.senVolFloEx.d = ahu.senVolFloEx.d_start;
      end if;
    end if;

  // Component ahu.senPreIn
  // class Buildings.Fluid.Sensors.Pressure
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialAbsoluteSensor
    initial equation
      assert( not ahu.senPreIn.warnAboutOnePortConnection, "Sensor "+
        ahu.senPreIn.instanceName+" can lead to numerical problems if connected to a scalar fluid port.
  Only connect it to a vectorized fluid port, such as used in 'Buildings.Fluid.MixingVolumes`.
  See Buildings.Fluid.Sensors.UsersGuide for more information.
  To disable this warning, set 'warnAboutOnePortConnection = false' in "
        +ahu.senPreIn.instanceName+".", AssertionLevel.warning);
    // end of extends 

  // Component ahu.senPreEx
  // class Buildings.Fluid.Sensors.Pressure
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialAbsoluteSensor
    initial equation
      assert( not ahu.senPreEx.warnAboutOnePortConnection, "Sensor "+
        ahu.senPreEx.instanceName+" can lead to numerical problems if connected to a scalar fluid port.
  Only connect it to a vectorized fluid port, such as used in 'Buildings.Fluid.MixingVolumes`.
  See Buildings.Fluid.Sensors.UsersGuide for more information.
  To disable this warning, set 'warnAboutOnePortConnection = false' in "
        +ahu.senPreEx.instanceName+".", AssertionLevel.warning);
    // end of extends 

  // Component ahu.fanEx.filter
  // class Modelica.Blocks.Continuous.Filter
  initial equation
    if (ahu.fanEx.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
      CriticalDamping) then 
      ahu.fanEx.filter.cr = Modelica.Blocks.Continuous.Internal.Filter.base.CriticalDamping
        (ahu.fanEx.filter.order, ahu.fanEx.filter.normalized);
    elseif (ahu.fanEx.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
      Bessel) then 
      (ahu.fanEx.filter.cr, ahu.fanEx.filter.c0, ahu.fanEx.filter.c1)  = 
        Modelica.Blocks.Continuous.Internal.Filter.base.Bessel(ahu.fanEx.filter.order,
         ahu.fanEx.filter.normalized);
    elseif (ahu.fanEx.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
      Butterworth) then 
      (ahu.fanEx.filter.cr, ahu.fanEx.filter.c0, ahu.fanEx.filter.c1)  = 
        Modelica.Blocks.Continuous.Internal.Filter.base.Butterworth(
        ahu.fanEx.filter.order, ahu.fanEx.filter.normalized);
    elseif (ahu.fanEx.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
      ChebyshevI) then 
      (ahu.fanEx.filter.cr, ahu.fanEx.filter.c0, ahu.fanEx.filter.c1)  = 
        Modelica.Blocks.Continuous.Internal.Filter.base.ChebyshevI(
        ahu.fanEx.filter.order, ahu.fanEx.filter.A_ripple, ahu.fanEx.filter.normalized);
    end if;
    if (ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.LowPass)
       then 
      (ahu.fanEx.filter.r, ahu.fanEx.filter.a, ahu.fanEx.filter.b, 
        ahu.fanEx.filter.ku)  = Modelica.Blocks.Continuous.Internal.Filter.roots.lowPass
        (ahu.fanEx.filter.cr, ahu.fanEx.filter.c0, ahu.fanEx.filter.c1, 
        ahu.fanEx.filter.f_cut);
    elseif (ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.
      HighPass) then 
      (ahu.fanEx.filter.r, ahu.fanEx.filter.a, ahu.fanEx.filter.b, 
        ahu.fanEx.filter.ku, ahu.fanEx.filter.k1, ahu.fanEx.filter.k2)  = 
        Modelica.Blocks.Continuous.Internal.Filter.roots.highPass(
        ahu.fanEx.filter.cr, ahu.fanEx.filter.c0, ahu.fanEx.filter.c1, 
        ahu.fanEx.filter.f_cut);
    elseif (ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.
      BandPass) then 
      (ahu.fanEx.filter.a, ahu.fanEx.filter.b, ahu.fanEx.filter.ku, 
        ahu.fanEx.filter.k1, ahu.fanEx.filter.k2)  = Modelica.Blocks.Continuous.Internal.Filter.roots.bandPass
        (ahu.fanEx.filter.cr, ahu.fanEx.filter.c0, ahu.fanEx.filter.c1, 
        ahu.fanEx.filter.f_min, ahu.fanEx.filter.f_cut);
    elseif (ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.
      BandStop) then 
      (ahu.fanEx.filter.a, ahu.fanEx.filter.b, ahu.fanEx.filter.ku, 
        ahu.fanEx.filter.k1, ahu.fanEx.filter.k2)  = Modelica.Blocks.Continuous.Internal.Filter.roots.bandStop
        (ahu.fanEx.filter.cr, ahu.fanEx.filter.c0, ahu.fanEx.filter.c1, 
        ahu.fanEx.filter.f_min, ahu.fanEx.filter.f_cut);
    end if;
    if (ahu.fanEx.filter.init == Modelica.Blocks.Types.Init.InitialState) then 
      ahu.fanEx.filter.x = ahu.fanEx.filter.x_start;
    elseif (ahu.fanEx.filter.init == Modelica.Blocks.Types.Init.SteadyState)
       then 
      der(ahu.fanEx.filter.x) = zeros(ahu.fanEx.filter.nx);
    elseif (ahu.fanEx.filter.init == Modelica.Blocks.Types.Init.InitialOutput)
       then 
      ahu.fanEx.filter.y = ahu.fanEx.filter.y_start;
      if (ahu.fanEx.filter.nx > 1) then 
        der(ahu.fanEx.filter.x[1:ahu.fanEx.filter.nx-1]) = zeros(
          ahu.fanEx.filter.nx-1);
      end if;
    end if;

  // Component ahu.fanEx.eff
  // class Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface
  initial equation
    assert(ahu.fanEx.eff.nOri > 1, "Must have at least two data points for pressure.V_flow.");
    assert(Buildings.Utilities.Math.Functions.isMonotonic(ahu.fanEx.eff.per.pressure.V_flow,
       true) and ahu.fanEx.eff.per.pressure.V_flow[1] > -1E-15, "The fan pressure rise must be a strictly decreasing sequence with respect to the volume flow rate,
  with the first element for the fan pressure raise being non-zero.
The following performance data have been entered:
"
      +Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface.getArrayAsString(
      ahu.fanEx.eff.per.pressure.V_flow, "pressure.V_flow", 6, 6));
    if ( not ahu.fanEx.eff.haveVMax) then 
      assert((ahu.fanEx.eff.per.pressure.V_flow[ahu.fanEx.eff.nOri]-
        ahu.fanEx.eff.per.pressure.V_flow[ahu.fanEx.eff.nOri-1])/(
        ahu.fanEx.eff.per.pressure.dp[ahu.fanEx.eff.nOri]-ahu.fanEx.eff.per.pressure.dp
        [ahu.fanEx.eff.nOri-1]) < 0, "The last two pressure points for the fan or pump performance curve must be decreasing.
    You need to set more reasonable parameters.
Received
"
        +Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface.getArrayAsString
        (ahu.fanEx.eff.per.pressure.dp, "dp", 6, 6));
    end if;
    if ( not ahu.fanEx.eff.haveMinimumDecrease) then 
      ModelicaInternal_print("
Warning:
========
It is recommended that the volume flow rate versus pressure relation
of the fan or pump satisfies the minimum decrease condition

        (per.pressure.dp[i+1]-per.pressure.dp[i])
d[i] = ------------------------------------------------- < "
        +String( -ahu.fanEx.eff.kRes)+"
       (per.pressure.V_flow[i+1]-per.pressure.V_flow[i])

 is
"
        +Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface.getArrayAsString
        (array((ahu.fanEx.eff.per.pressure.dp[i+1]-ahu.fanEx.eff.per.pressure.dp
        [i])/(ahu.fanEx.eff.per.pressure.V_flow[i+1]-ahu.fanEx.eff.per.pressure.V_flow
        [i]) for i in 1:ahu.fanEx.eff.nOri-1), "d", 6, 6)+"
Otherwise, a solution to the equations may not exist if the fan or pump speed is reduced.
In this situation, the solver will fail due to non-convergence and
the simulation stops.",
         "");
    end if;
    if (ahu.fanEx.eff.haveVMax and ahu.fanEx.eff.haveDPMax or ahu.fanEx.eff.nOri
       == 2) then 
      ahu.fanEx.eff.preDer1 = Buildings.Utilities.Math.Functions.splineDerivatives
        (ahu.fanEx.eff.pCur1.V_flow, ahu.fanEx.eff.pCur1.dp, Buildings.Utilities.Math.Functions.isMonotonic
        (ahu.fanEx.eff.pCur1.dp, false));
      ahu.fanEx.eff.preDer2 = zeros(ahu.fanEx.eff.nOri+1);
      ahu.fanEx.eff.preDer3 = zeros(ahu.fanEx.eff.nOri+2);
    elseif (ahu.fanEx.eff.haveVMax or ahu.fanEx.eff.haveDPMax) then 
      ahu.fanEx.eff.preDer1 = zeros(ahu.fanEx.eff.nOri);
      ahu.fanEx.eff.preDer2 = Buildings.Utilities.Math.Functions.splineDerivatives
        (ahu.fanEx.eff.pCur2.V_flow, ahu.fanEx.eff.pCur2.dp, Buildings.Utilities.Math.Functions.isMonotonic
        (ahu.fanEx.eff.pCur2.dp, false));
      ahu.fanEx.eff.preDer3 = zeros(ahu.fanEx.eff.nOri+2);
    else
      ahu.fanEx.eff.preDer1 = zeros(ahu.fanEx.eff.nOri);
      ahu.fanEx.eff.preDer2 = zeros(ahu.fanEx.eff.nOri+1);
      ahu.fanEx.eff.preDer3 = Buildings.Utilities.Math.Functions.splineDerivatives
        (ahu.fanEx.eff.pCur3.V_flow, ahu.fanEx.eff.pCur3.dp, Buildings.Utilities.Math.Functions.isMonotonic
        (ahu.fanEx.eff.pCur3.dp, false));
    end if;
    ahu.fanEx.eff.motDer = (if ahu.fanEx.eff.per.use_powerCharacteristic then 
      zeros(size(ahu.fanEx.eff.per.motorEfficiency.V_flow, 1)) else (if size(
      ahu.fanEx.eff.per.motorEfficiency.V_flow, 1) == 1 then {0} else 
      Buildings.Utilities.Math.Functions.splineDerivatives(ahu.fanEx.eff.per.motorEfficiency.V_flow,
       ahu.fanEx.eff.per.motorEfficiency.eta, Buildings.Utilities.Math.Functions.isMonotonic
      (ahu.fanEx.eff.per.motorEfficiency.eta, false))));
    ahu.fanEx.eff.hydDer = (if ahu.fanEx.eff.per.use_powerCharacteristic then 
      zeros(size(ahu.fanEx.eff.per.hydraulicEfficiency.V_flow, 1)) else (if size
      (ahu.fanEx.eff.per.hydraulicEfficiency.V_flow, 1) == 1 then {0} else 
      Buildings.Utilities.Math.Functions.splineDerivatives(ahu.fanEx.eff.per.hydraulicEfficiency.V_flow,
       ahu.fanEx.eff.per.hydraulicEfficiency.eta, Buildings.Utilities.Math.Functions.isMonotonic
      (ahu.fanEx.eff.per.hydraulicEfficiency.eta, false))));
    assert(ahu.fanEx.eff.homotopyInitialization, "In RealOccupancy.ahu.fanEx.eff: The constant homotopyInitialization has been modified from its default value. This constant will be removed in future releases.",
       AssertionLevel.warning);

  // Component ahu.fanEx
  // class Buildings.Fluid.Movers.SpeedControlled_y
    // extends Buildings.Fluid.Movers.BaseClasses.PartialFlowMachine
    initial equation
      assert(ahu.fanEx.m_flow_nominal >= 1E-60, "In RealOccupancy.ahu.fanEx: The value of parameter m_flow_nominal should be greater or equal than "
        +String(1E-60)+" but it equals "+String(ahu.fanEx.m_flow_nominal));
      assert(ahu.fanEx.nominalValuesDefineDefaultPressureCurve or 
        ahu.fanEx.per.havePressureCurve or ahu.fanEx.preVar == Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
        Speed, "*** Warning: You are using a flow or pressure controlled mover with the
             default pressure curve.
             This leads to approximate calculations of the electrical power
             consumption. Add the correct pressure curve in the record per
             to obtain an accurate computation.
             Setting nominalValuesDefineDefaultPressureCurve=true will suppress this warning.",
         AssertionLevel.warning);
      assert(ahu.fanEx.nominalValuesDefineDefaultPressureCurve or (
        ahu.fanEx.per.havePressureCurve or ahu.fanEx.preVar == Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
        Speed) or ahu.fanEx.per.use_powerCharacteristic == false, 
        "*** Warning: You are using a flow or pressure controlled mover with the
             default pressure curve and you set use_powerCharacteristic = true.
             Since this can cause wrong power consumption, the model will overwrite
             this setting and use instead use_powerCharacteristic = false.Since this causes the efficiency curve to be used,
             make sure that the efficiency curves in the performance record per
             are correct or add the pressure curve of the mover.
             Setting nominalValuesDefineDefaultPressureCurve=true will suppress this warning.",
         AssertionLevel.warning);
    // end of extends 
  initial equation
    assert(ahu.fanEx.per.havePressureCurve, "SpeedControlled_y requires to set the pressure vs. flow rate curve in record 'per'.");

  // Component ahu.senTemEx2
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
  initial equation
    if (ahu.senTemEx2.dynamic) then 
      if (ahu.senTemEx2.initType == Modelica.Blocks.Types.Init.SteadyState)
         then 
        der(ahu.senTemEx2.T) = 0;
      elseif (ahu.senTemEx2.initType == Modelica.Blocks.Types.Init.InitialState
         or ahu.senTemEx2.initType == Modelica.Blocks.Types.Init.InitialOutput)
         then 
        ahu.senTemEx2.T = ahu.senTemEx2.T_start;
      end if;
    end if;

  // Component ahu.senTemIn1
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
  initial equation
    if (ahu.senTemIn1.dynamic) then 
      if (ahu.senTemIn1.initType == Modelica.Blocks.Types.Init.SteadyState)
         then 
        der(ahu.senTemIn1.T) = 0;
      elseif (ahu.senTemIn1.initType == Modelica.Blocks.Types.Init.InitialState
         or ahu.senTemIn1.initType == Modelica.Blocks.Types.Init.InitialOutput)
         then 
        ahu.senTemIn1.T = ahu.senTemIn1.T_start;
      end if;
    end if;

  // Component ahu.senTemIn3
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
  initial equation
    if (ahu.senTemIn3.dynamic) then 
      if (ahu.senTemIn3.initType == Modelica.Blocks.Types.Init.SteadyState)
         then 
        der(ahu.senTemIn3.T) = 0;
      elseif (ahu.senTemIn3.initType == Modelica.Blocks.Types.Init.InitialState
         or ahu.senTemIn3.initType == Modelica.Blocks.Types.Init.InitialOutput)
         then 
        ahu.senTemIn3.T = ahu.senTemIn3.T_start;
      end if;
    end if;

  // Component ahu.outEx
  // class Buildings.Fluid.Sources.Outside
    // extends Buildings.Fluid.Sources.BaseClasses.PartialSource
    initial equation
      for i in Unknown error function() loop
        Unknown error function();
      end for;
    // end of extends 

end RealOccupancy;
