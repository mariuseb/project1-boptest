// Equations and algorithms

  // Component ahu.fanSu.inputSwitch
  // class Modelica.Blocks.Routing.RealPassThrough
  equation
    ahu.fanSu.inputSwitch.y = ahu.fanSu.inputSwitch.u;

  // Component ahu.fanSu.vol.preTem
  // class Buildings.HeatTransfer.Sources.PrescribedTemperature
  equation
    ahu.fanSu.vol.preTem.port.T = ahu.fanSu.vol.preTem.T;

  // Component ahu.fanSu.vol.heaFloSen
  // class Modelica.Thermal.HeatTransfer.Sensors.HeatFlowSensor
  equation
    ahu.fanSu.vol.heaFloSen.port_a.T = ahu.fanSu.vol.heaFloSen.port_b.T;
    ahu.fanSu.vol.heaFloSen.port_a.Q_flow+ahu.fanSu.vol.heaFloSen.port_b.Q_flow
       = 0;
    ahu.fanSu.vol.heaFloSen.Q_flow = ahu.fanSu.vol.heaFloSen.port_a.Q_flow;

  // Component ahu.fanSu.vol
  // class Buildings.Fluid.Delays.DelayFirstOrder
    // extends Buildings.Fluid.MixingVolumes.BaseClasses.PartialMixingVolume
    equation
      if ( not ahu.fanSu.vol.allowFlowReversal) then 
        assert(ahu.fanSu.vol.ports[1].m_flow >  -ahu.fanSu.vol.m_flow_small, 
          "In RealOccupancy.ahu.fanSu.vol: Model has flow reversal,
  but the parameter allowFlowReversal is set to false.
  m_flow_small    = "
          +String(ahu.fanSu.vol.m_flow_small)+"
  ports[1].m_flow = "+String(
          ahu.fanSu.vol.ports[1].m_flow)+"
");
      end if;
      if (ahu.fanSu.vol.useSteadyStateTwoPort) then 
        connect(ahu.fanSu.vol.steBal.port_a, ahu.fanSu.vol.ports[1]);
        connect(ahu.fanSu.vol.steBal.port_b, ahu.fanSu.vol.ports[2]);
        ahu.fanSu.vol.U = 0;
        ahu.fanSu.vol.mXi = zeros(1);
        ahu.fanSu.vol.m = 0;
        ahu.fanSu.vol.mC = zeros(1);
        connect(ahu.fanSu.vol.hOut_internal, ahu.fanSu.vol.steBal.hOut);
        connect(ahu.fanSu.vol.XiOut_internal, ahu.fanSu.vol.steBal.XiOut);
        connect(ahu.fanSu.vol.COut_internal, ahu.fanSu.vol.steBal.COut);
      else
        connect(ahu.fanSu.vol.dynBal.ports, ahu.fanSu.vol.ports);
        connect(ahu.fanSu.vol.U, ahu.fanSu.vol.dynBal.UOut);
        connect(ahu.fanSu.vol.mXi, ahu.fanSu.vol.dynBal.mXiOut);
        connect(ahu.fanSu.vol.m, ahu.fanSu.vol.dynBal.mOut);
        connect(ahu.fanSu.vol.mC, ahu.fanSu.vol.dynBal.mCOut);
        connect(ahu.fanSu.vol.hOut_internal, ahu.fanSu.vol.dynBal.hOut);
        connect(ahu.fanSu.vol.XiOut_internal, ahu.fanSu.vol.dynBal.XiOut);
        connect(ahu.fanSu.vol.COut_internal, ahu.fanSu.vol.dynBal.COut);
      end if;
      connect(ahu.fanSu.vol.portT.y, ahu.fanSu.vol.preTem.T);
      connect(ahu.fanSu.vol.heaFloSen.port_b, ahu.fanSu.vol.preTem.port);
      connect(ahu.fanSu.vol.heaFloSen.Q_flow, ahu.fanSu.vol.steBal.Q_flow);
      connect(ahu.fanSu.vol.heaFloSen.Q_flow, ahu.fanSu.vol.dynBal.Q_flow);
    // extends Buildings.Fluid.MixingVolumes.MixingVolume
    equation
      connect(ahu.fanSu.vol.heaFloSen.port_a, ahu.fanSu.vol.heatPort);
      connect(ahu.fanSu.vol.C_flow, ahu.fanSu.vol.steBal.C_flow);
      connect(ahu.fanSu.vol.C_flow, ahu.fanSu.vol.dynBal.C_flow);
    // end of extends 

  // Component ahu.fanSu.filter
  // class Modelica.Blocks.Continuous.Filter
  equation
    assert(ahu.fanSu.filter.u_nominal > 0, "u_nominal > 0 required");
    assert(ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.
      LowPass or ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.
      HighPass or ahu.fanSu.filter.f_min > 0, "f_min > 0 required for band pass and band stop filter");
    assert(ahu.fanSu.filter.A_ripple > 0, "A_ripple > 0 required");
    assert(ahu.fanSu.filter.f_cut > 0, "f_cut > 0 required");
    ahu.fanSu.filter.uu[1] = ahu.fanSu.filter.u/ahu.fanSu.filter.u_nominal;
    for i in (1:ahu.fanSu.filter.nr) loop
      der(ahu.fanSu.filter.x[i]) = ahu.fanSu.filter.r[i]*(ahu.fanSu.filter.x[i]-
        ahu.fanSu.filter.uu[i]);
    end for;
    for i in (1:ahu.fanSu.filter.na) loop
      der(ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i-1]) = ahu.fanSu.filter.a[i]
        *ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i-1]-ahu.fanSu.filter.b[i]*
        ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i]+ahu.fanSu.filter.ku[i]*
        ahu.fanSu.filter.uu[ahu.fanSu.filter.nr+i];
      der(ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i]) = ahu.fanSu.filter.b[i]*
        ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i-1]+ahu.fanSu.filter.a[i]*
        ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i];
    end for;
    if (ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.LowPass)
       then 
      for i in (1:ahu.fanSu.filter.nr) loop
        ahu.fanSu.filter.uu[i+1] = ahu.fanSu.filter.x[i];
      end for;
      for i in (1:ahu.fanSu.filter.na) loop
        ahu.fanSu.filter.uu[ahu.fanSu.filter.nr+i+1] = ahu.fanSu.filter.x[
          ahu.fanSu.filter.nr+2*i];
      end for;
    elseif (ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.
      HighPass) then 
      for i in (1:ahu.fanSu.filter.nr) loop
        ahu.fanSu.filter.uu[i+1] = ( -ahu.fanSu.filter.x[i])+ahu.fanSu.filter.uu
          [i];
      end for;
      for i in (1:ahu.fanSu.filter.na) loop
        ahu.fanSu.filter.uu[ahu.fanSu.filter.nr+i+1] = ahu.fanSu.filter.k1[i]*
          ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i-1]+ahu.fanSu.filter.k2[i]*
          ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i]+ahu.fanSu.filter.uu[
          ahu.fanSu.filter.nr+i];
      end for;
    elseif (ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.
      BandPass) then 
      for i in (1:ahu.fanSu.filter.na) loop
        ahu.fanSu.filter.uu[ahu.fanSu.filter.nr+i+1] = ahu.fanSu.filter.k1[i]*
          ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i-1]+ahu.fanSu.filter.k2[i]*
          ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i];
      end for;
    elseif (ahu.fanSu.filter.filterType == Modelica.Blocks.Types.FilterType.
      BandStop) then 
      for i in (1:ahu.fanSu.filter.na) loop
        ahu.fanSu.filter.uu[ahu.fanSu.filter.nr+i+1] = ahu.fanSu.filter.k1[i]*
          ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i-1]+ahu.fanSu.filter.k2[i]*
          ahu.fanSu.filter.x[ahu.fanSu.filter.nr+2*i]+ahu.fanSu.filter.uu[
          ahu.fanSu.filter.nr+i];
      end for;
    else
      assert(false, "filterType (= "+String(ahu.fanSu.filter.filterType)+
        ") is unknown");
      ahu.fanSu.filter.uu = zeros(ahu.fanSu.filter.na+ahu.fanSu.filter.nr+1);
    end if;
    ahu.fanSu.filter.y = ahu.fanSu.filter.gain*ahu.fanSu.filter.u_nominal*
      ahu.fanSu.filter.uu[ahu.fanSu.filter.nr+ahu.fanSu.filter.na+1];

  // Component ahu.fanSu.gaiSpe
  // class Modelica.Blocks.Math.Gain
  equation
    ahu.fanSu.gaiSpe.y = ahu.fanSu.gaiSpe.k*ahu.fanSu.gaiSpe.u;

  // Component ahu.fanSu.preSou
  // class Buildings.Fluid.Movers.BaseClasses.IdealSource
    // extends Buildings.Fluid.Interfaces.PartialTwoPortTransport
    equation
      ahu.fanSu.preSou.dp = ahu.fanSu.preSou.port_a.p-ahu.fanSu.preSou.port_b.p;
      ahu.fanSu.preSou.m_flow = ahu.fanSu.preSou.port_a.m_flow;
      assert(ahu.fanSu.preSou.m_flow >  -ahu.fanSu.preSou.m_flow_small or 
        ahu.fanSu.preSou.allowFlowReversal, "Reverting flow occurs even though allowFlowReversal is false");
      ahu.fanSu.preSou.port_a.m_flow+ahu.fanSu.preSou.port_b.m_flow = 0;
      ahu.fanSu.preSou.port_a.Xi_outflow = (if ahu.fanSu.preSou.allowFlowReversal
         then inStream(ahu.fanSu.preSou.port_b.Xi_outflow) else {0.01});
      ahu.fanSu.preSou.port_b.Xi_outflow = inStream(ahu.fanSu.preSou.port_a.Xi_outflow);
      ahu.fanSu.preSou.port_a.C_outflow = (if ahu.fanSu.preSou.allowFlowReversal
         then inStream(ahu.fanSu.preSou.port_b.C_outflow) else zeros(1));
      ahu.fanSu.preSou.port_b.C_outflow = inStream(ahu.fanSu.preSou.port_a.C_outflow);
    // end of extends 
  equation
    if (ahu.fanSu.preSou.control_m_flow) then 
      ahu.fanSu.preSou.m_flow = ahu.fanSu.preSou.m_flow_internal;
    else
      ahu.fanSu.preSou.m_flow_internal = 0;
    end if;
    if (ahu.fanSu.preSou.control_dp) then 
      ahu.fanSu.preSou.dp = ahu.fanSu.preSou.dp_internal;
    else
      ahu.fanSu.preSou.dp_internal = 0;
    end if;
    connect(ahu.fanSu.preSou.dp_internal, ahu.fanSu.preSou.dp_in);
    connect(ahu.fanSu.preSou.m_flow_internal, ahu.fanSu.preSou.m_flow_in);
    ahu.fanSu.preSou.port_a.h_outflow = (if ahu.fanSu.preSou.allowFlowReversal
       then inStream(ahu.fanSu.preSou.port_b.h_outflow) else 45300.945);
    ahu.fanSu.preSou.port_b.h_outflow = inStream(ahu.fanSu.preSou.port_a.h_outflow);

  // Component ahu.fanSu.senMasFlo
  // class Buildings.Fluid.Sensors.MassFlowRate
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialFlowSensor
    equation
      ahu.fanSu.senMasFlo.port_b.m_flow =  -ahu.fanSu.senMasFlo.port_a.m_flow;
      ahu.fanSu.senMasFlo.port_a.p = ahu.fanSu.senMasFlo.port_b.p;
      ahu.fanSu.senMasFlo.port_a.h_outflow = (if ahu.fanSu.senMasFlo.allowFlowReversal
         then inStream(ahu.fanSu.senMasFlo.port_b.h_outflow) else 45300.945);
      ahu.fanSu.senMasFlo.port_b.h_outflow = inStream(ahu.fanSu.senMasFlo.port_a.h_outflow);
      ahu.fanSu.senMasFlo.port_a.Xi_outflow = (if ahu.fanSu.senMasFlo.allowFlowReversal
         then inStream(ahu.fanSu.senMasFlo.port_b.Xi_outflow) else {0.01});
      ahu.fanSu.senMasFlo.port_b.Xi_outflow = inStream(ahu.fanSu.senMasFlo.port_a.Xi_outflow);
      ahu.fanSu.senMasFlo.port_a.C_outflow = (if ahu.fanSu.senMasFlo.allowFlowReversal
         then inStream(ahu.fanSu.senMasFlo.port_b.C_outflow) else zeros(1));
      ahu.fanSu.senMasFlo.port_b.C_outflow = inStream(ahu.fanSu.senMasFlo.port_a.C_outflow);
    // end of extends 
  equation
    ahu.fanSu.senMasFlo.m_flow = ahu.fanSu.senMasFlo.port_a.m_flow;

  // Component ahu.fanSu.senRelPre
  // class Buildings.Fluid.Sensors.RelativePressure
  equation
    ahu.fanSu.senRelPre.port_a.m_flow = 0;
    ahu.fanSu.senRelPre.port_b.m_flow = 0;
    ahu.fanSu.senRelPre.port_a.h_outflow = 0;
    ahu.fanSu.senRelPre.port_b.h_outflow = 0;
    ahu.fanSu.senRelPre.port_a.Xi_outflow = zeros(1);
    ahu.fanSu.senRelPre.port_b.Xi_outflow = zeros(1);
    ahu.fanSu.senRelPre.port_a.C_outflow = zeros(1);
    ahu.fanSu.senRelPre.port_b.C_outflow = zeros(1);
    ahu.fanSu.senRelPre.p_rel = ahu.fanSu.senRelPre.port_a.p-ahu.fanSu.senRelPre.port_b.p;

  // Component ahu.fanSu.eff
  // class Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface
  equation
    connect(ahu.fanSu.eff.dp_internal, ahu.fanSu.eff.dp);
    connect(ahu.fanSu.eff.dp_internal, ahu.fanSu.eff.dp_in);
    connect(ahu.fanSu.eff.r_N, ahu.fanSu.eff.y_in);
    ahu.fanSu.eff.y_out = ahu.fanSu.eff.r_N;
    ahu.fanSu.eff.V_flow = ahu.fanSu.eff.m_flow/ahu.fanSu.eff.rho;
    ahu.fanSu.eff.r_V = ahu.fanSu.eff.V_flow/ahu.fanSu.eff.V_flow_max;
    if (ahu.fanSu.eff.computePowerUsingSimilarityLaws == false and 
      ahu.fanSu.eff.preVar <> Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
      Speed) then 
      ahu.fanSu.eff.r_N = 1;
    else
      if (ahu.fanSu.eff.curve == 1) then 
        if (ahu.fanSu.eff.homotopyInitialization) then 
          ahu.fanSu.eff.V_flow*ahu.fanSu.eff.kRes+ahu.fanSu.eff.dp_internal = 
            homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanSu.eff.V_flow, 
            ahu.fanSu.eff.r_N, 
            ahu.fanSu.eff.preDer1, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur1), ahu.fanSu.eff.r_N*(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanSu.eff.V_flow_nominal, 
            1, 
            ahu.fanSu.eff.preDer1, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur1)+(ahu.fanSu.eff.V_flow-ahu.fanSu.eff.V_flow_nominal)
            *(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            (1+ahu.fanSu.eff.delta)*ahu.fanSu.eff.V_flow_nominal, 
            1, 
            ahu.fanSu.eff.preDer1, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur1)-Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            (1-ahu.fanSu.eff.delta)*ahu.fanSu.eff.V_flow_nominal, 
            1, 
            ahu.fanSu.eff.preDer1, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur1))/(2*ahu.fanSu.eff.delta*ahu.fanSu.eff.V_flow_nominal)));
        else
          ahu.fanSu.eff.V_flow*ahu.fanSu.eff.kRes+ahu.fanSu.eff.dp_internal = 
            Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            ahu.fanSu.eff.V_flow, 
            ahu.fanSu.eff.r_N, 
            ahu.fanSu.eff.preDer1, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur1);
        end if;
      elseif (ahu.fanSu.eff.curve == 2) then 
        if (ahu.fanSu.eff.homotopyInitialization) then 
          ahu.fanSu.eff.V_flow*ahu.fanSu.eff.kRes+ahu.fanSu.eff.dp_internal = 
            homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanSu.eff.V_flow, 
            ahu.fanSu.eff.r_N, 
            ahu.fanSu.eff.preDer2, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur2), ahu.fanSu.eff.r_N*(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanSu.eff.V_flow_nominal, 
            1, 
            ahu.fanSu.eff.preDer2, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur2)+(ahu.fanSu.eff.V_flow-ahu.fanSu.eff.V_flow_nominal)
            *(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            (1+ahu.fanSu.eff.delta)*ahu.fanSu.eff.V_flow_nominal, 
            1, 
            ahu.fanSu.eff.preDer2, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur2)-Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            (1-ahu.fanSu.eff.delta)*ahu.fanSu.eff.V_flow_nominal, 
            1, 
            ahu.fanSu.eff.preDer2, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur2))/(2*ahu.fanSu.eff.delta*ahu.fanSu.eff.V_flow_nominal)));
        else
          ahu.fanSu.eff.V_flow*ahu.fanSu.eff.kRes+ahu.fanSu.eff.dp_internal = 
            Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            ahu.fanSu.eff.V_flow, 
            ahu.fanSu.eff.r_N, 
            ahu.fanSu.eff.preDer2, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur2);
        end if;
      else
        if (ahu.fanSu.eff.homotopyInitialization) then 
          ahu.fanSu.eff.V_flow*ahu.fanSu.eff.kRes+ahu.fanSu.eff.dp_internal = 
            homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanSu.eff.V_flow, 
            ahu.fanSu.eff.r_N, 
            ahu.fanSu.eff.preDer3, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur3), ahu.fanSu.eff.r_N*(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanSu.eff.V_flow_nominal, 
            1, 
            ahu.fanSu.eff.preDer3, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur3)+(ahu.fanSu.eff.V_flow-ahu.fanSu.eff.V_flow_nominal)
            *(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            (1+ahu.fanSu.eff.delta)*ahu.fanSu.eff.V_flow_nominal, 
            1, 
            ahu.fanSu.eff.preDer3, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur3)-Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            (1-ahu.fanSu.eff.delta)*ahu.fanSu.eff.V_flow_nominal, 
            1, 
            ahu.fanSu.eff.preDer3, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur3))/(2*ahu.fanSu.eff.delta*ahu.fanSu.eff.V_flow_nominal)));
        else
          ahu.fanSu.eff.V_flow*ahu.fanSu.eff.kRes+ahu.fanSu.eff.dp_internal = 
            Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            ahu.fanSu.eff.V_flow, 
            ahu.fanSu.eff.r_N, 
            ahu.fanSu.eff.preDer3, 
            ahu.fanSu.eff.dpMax, 
            ahu.fanSu.eff.V_flow_max, 
            ahu.fanSu.eff.pCur3);
        end if;
      end if;
    end if;
    ahu.fanSu.eff.WFlo = ahu.fanSu.eff.dp_internal*ahu.fanSu.eff.V_flow;
    if (ahu.fanSu.eff.per.use_powerCharacteristic) then 
      if (ahu.fanSu.eff.homotopyInitialization) then 
        ahu.fanSu.eff.PEle = homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.power
          (
          ahu.fanSu.eff.per.power, 
          ahu.fanSu.eff.V_flow, 
          ahu.fanSu.eff.r_N, 
          ahu.fanSu.eff.powDer, 
          ahu.fanSu.eff.delta), ahu.fanSu.eff.V_flow/ahu.fanSu.eff.V_flow_nominal
          *Buildings.Fluid.Movers.BaseClasses.Characteristics.power(
          ahu.fanSu.eff.per.power, 
          ahu.fanSu.eff.V_flow_nominal, 
          1, 
          ahu.fanSu.eff.powDer, 
          ahu.fanSu.eff.delta));
      else
        ahu.fanSu.eff.PEle = ahu.fanSu.eff.rho/ahu.fanSu.eff.rho_default*
          Buildings.Fluid.Movers.BaseClasses.Characteristics.power(
          ahu.fanSu.eff.per.power, 
          ahu.fanSu.eff.V_flow, 
          ahu.fanSu.eff.r_N, 
          ahu.fanSu.eff.powDer, 
          ahu.fanSu.eff.delta);
      end if;
      ahu.fanSu.eff.eta = ahu.fanSu.eff.WFlo/Buildings.Utilities.Math.Functions.smoothMax
        (ahu.fanSu.eff.PEle, 1E-05, 1E-06);
      ahu.fanSu.eff.etaHyd = 1;
      ahu.fanSu.eff.etaMot = ahu.fanSu.eff.eta;
    else
      if (ahu.fanSu.eff.homotopyInitialization) then 
        ahu.fanSu.eff.etaHyd = homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanSu.eff.per.hydraulicEfficiency, 
          ahu.fanSu.eff.V_flow, 
          ahu.fanSu.eff.hydDer, 
          ahu.fanSu.eff.r_N, 
          ahu.fanSu.eff.delta), Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanSu.eff.per.hydraulicEfficiency, 
          ahu.fanSu.eff.V_flow_max, 
          ahu.fanSu.eff.hydDer, 
          ahu.fanSu.eff.r_N, 
          ahu.fanSu.eff.delta));
        ahu.fanSu.eff.etaMot = homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanSu.eff.per.motorEfficiency, 
          ahu.fanSu.eff.V_flow, 
          ahu.fanSu.eff.motDer, 
          ahu.fanSu.eff.r_N, 
          ahu.fanSu.eff.delta), Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanSu.eff.per.motorEfficiency, 
          ahu.fanSu.eff.V_flow_max, 
          ahu.fanSu.eff.motDer, 
          ahu.fanSu.eff.r_N, 
          ahu.fanSu.eff.delta));
      else
        ahu.fanSu.eff.etaHyd = Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanSu.eff.per.hydraulicEfficiency, 
          ahu.fanSu.eff.V_flow, 
          ahu.fanSu.eff.hydDer, 
          ahu.fanSu.eff.r_N, 
          ahu.fanSu.eff.delta);
        ahu.fanSu.eff.etaMot = Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanSu.eff.per.motorEfficiency, 
          ahu.fanSu.eff.V_flow, 
          ahu.fanSu.eff.motDer, 
          ahu.fanSu.eff.r_N, 
          ahu.fanSu.eff.delta);
      end if;
      ahu.fanSu.eff.PEle = ahu.fanSu.eff.WFlo/Buildings.Utilities.Math.Functions.smoothMax
        (ahu.fanSu.eff.eta, 1E-05, 1E-06);
      ahu.fanSu.eff.eta = ahu.fanSu.eff.etaHyd*ahu.fanSu.eff.etaMot;
    end if;

  // Component ahu.fanSu.gain
  // class Modelica.Blocks.Math.Gain
  equation
    ahu.fanSu.gain.y = ahu.fanSu.gain.k*ahu.fanSu.gain.u;

  // Component ahu.fanSu
  // class Buildings.Fluid.Movers.SpeedControlled_y
    // extends Buildings.Fluid.Movers.BaseClasses.PartialFlowMachine
    equation
      connect(ahu.fanSu.prePow.port, ahu.fanSu.vol.heatPort);
      connect(ahu.fanSu.vol.heatPort, ahu.fanSu.heatPort);
      connect(ahu.fanSu.preSou.port_b, ahu.fanSu.port_b);
      connect(ahu.fanSu.stageValues.y, ahu.fanSu.extractor.u);
      connect(ahu.fanSu.extractor.y, ahu.fanSu.inputSwitch.u);
      connect(ahu.fanSu.setConst.y, ahu.fanSu.inputSwitch.u);
      connect(ahu.fanSu.extractor.index, ahu.fanSu.stage);
      connect(ahu.fanSu.PToMed.y, ahu.fanSu.prePow.Q_flow);
      connect(ahu.fanSu.PToMed.u1, ahu.fanSu.heaDis.Q_flow);
      connect(ahu.fanSu.senRelPre.port_b, ahu.fanSu.preSou.port_a);
      connect(ahu.fanSu.senRelPre.port_a, ahu.fanSu.preSou.port_b);
      connect(ahu.fanSu.heaDis.etaHyd, ahu.fanSu.eff.etaHyd);
      connect(ahu.fanSu.heaDis.V_flow, ahu.fanSu.eff.V_flow);
      connect(ahu.fanSu.eff.PEle, ahu.fanSu.heaDis.PEle);
      connect(ahu.fanSu.eff.WFlo, ahu.fanSu.heaDis.WFlo);
      connect(ahu.fanSu.rho_inlet.y, ahu.fanSu.eff.rho);
      connect(ahu.fanSu.eff.m_flow, ahu.fanSu.senMasFlo.m_flow);
      connect(ahu.fanSu.eff.PEle, ahu.fanSu.P);
      connect(ahu.fanSu.eff.WFlo, ahu.fanSu.PToMed.u2);
      connect(ahu.fanSu.inputSwitch.y, ahu.fanSu.filter.u);
      connect(ahu.fanSu.senRelPre.p_rel, ahu.fanSu.eff.dp_in);
      connect(ahu.fanSu.eff.y_out, ahu.fanSu.y_actual);
      connect(ahu.fanSu.port_a, ahu.fanSu.vol.ports[1]);
      connect(ahu.fanSu.vol.ports[2], ahu.fanSu.senMasFlo.port_a);
      connect(ahu.fanSu.senMasFlo.port_b, ahu.fanSu.preSou.port_a);
    // end of extends 
  equation
    connect(ahu.fanSu.gaiSpe.u, ahu.fanSu.y);
    connect(ahu.fanSu.gaiSpe.y, ahu.fanSu.inputSwitch.u);
    connect(ahu.fanSu.eff.dp, ahu.fanSu.gain.u);
    connect(ahu.fanSu.gain.y, ahu.fanSu.preSou.dp_in);
    if (ahu.fanSu.use_inputFilter) then 
      connect(ahu.fanSu.filter.y, ahu.fanSu.eff.y_in);
    else
      connect(ahu.fanSu.inputSwitch.y, ahu.fanSu.eff.y_in);
    end if;

  // Component ahu.senVolFloIn
  // class Buildings.Fluid.Sensors.VolumeFlowRate
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialFlowSensor
    equation
      ahu.senVolFloIn.port_b.m_flow =  -ahu.senVolFloIn.port_a.m_flow;
      ahu.senVolFloIn.port_a.p = ahu.senVolFloIn.port_b.p;
      ahu.senVolFloIn.port_a.h_outflow = (if ahu.senVolFloIn.allowFlowReversal
         then inStream(ahu.senVolFloIn.port_b.h_outflow) else 45300.945);
      ahu.senVolFloIn.port_b.h_outflow = inStream(ahu.senVolFloIn.port_a.h_outflow);
      ahu.senVolFloIn.port_a.Xi_outflow = (if ahu.senVolFloIn.allowFlowReversal
         then inStream(ahu.senVolFloIn.port_b.Xi_outflow) else {0.01});
      ahu.senVolFloIn.port_b.Xi_outflow = inStream(ahu.senVolFloIn.port_a.Xi_outflow);
      ahu.senVolFloIn.port_a.C_outflow = (if ahu.senVolFloIn.allowFlowReversal
         then inStream(ahu.senVolFloIn.port_b.C_outflow) else zeros(1));
      ahu.senVolFloIn.port_b.C_outflow = inStream(ahu.senVolFloIn.port_a.C_outflow);
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialDynamicFlowSensor
    equation
      if (ahu.senVolFloIn.dynamic) then 
        ahu.senVolFloIn.mNor_flow = ahu.senVolFloIn.port_a.m_flow/
          ahu.senVolFloIn.m_flow_nominal;
        ahu.senVolFloIn.k = Modelica.Fluid.Utilities.regStep(ahu.senVolFloIn.port_a.m_flow,
           ahu.senVolFloIn.mNor_flow,  -ahu.senVolFloIn.mNor_flow, 
          ahu.senVolFloIn.m_flow_small);
      else
        ahu.senVolFloIn.mNor_flow = 1;
        ahu.senVolFloIn.k = 1;
      end if;
    // end of extends 
  equation
    if (ahu.senVolFloIn.allowFlowReversal) then 
      ahu.senVolFloIn.d_a_inflow = ahu.senVolFloIn.density_Unique37(
        ahu.senVolFloIn.setState_phX_Unique38(ahu.senVolFloIn.port_b.p, 
          ahu.senVolFloIn.port_b.h_outflow, ahu.senVolFloIn.port_b.Xi_outflow));
      ahu.senVolFloIn.d_b_inflow = ahu.senVolFloIn.density_Unique37(
        ahu.senVolFloIn.setState_phX_Unique38(ahu.senVolFloIn.port_a.p, 
          ahu.senVolFloIn.port_a.h_outflow, ahu.senVolFloIn.port_a.Xi_outflow));
      ahu.senVolFloIn.dMed = Modelica.Fluid.Utilities.regStep(ahu.senVolFloIn.port_a.m_flow,
         ahu.senVolFloIn.d_a_inflow, ahu.senVolFloIn.d_b_inflow, 
        ahu.senVolFloIn.m_flow_small);
    else
      ahu.senVolFloIn.dMed = ahu.senVolFloIn.density_Unique37(
        ahu.senVolFloIn.setState_phX_Unique38(ahu.senVolFloIn.port_b.p, 
          ahu.senVolFloIn.port_b.h_outflow, ahu.senVolFloIn.port_b.Xi_outflow));
      ahu.senVolFloIn.d_a_inflow = ahu.senVolFloIn.dMed;
      ahu.senVolFloIn.d_b_inflow = ahu.senVolFloIn.dMed;
    end if;
    if (ahu.senVolFloIn.dynamic) then 
      der(ahu.senVolFloIn.d) = (ahu.senVolFloIn.dMed-ahu.senVolFloIn.d)*
        ahu.senVolFloIn.k*ahu.senVolFloIn.tauInv;
    else
      ahu.senVolFloIn.d = ahu.senVolFloIn.dMed;
    end if;
    ahu.senVolFloIn.V_flow = ahu.senVolFloIn.port_a.m_flow/ahu.senVolFloIn.d;

  // Component ahu.senTemIn2
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialFlowSensor
    equation
      ahu.senTemIn2.port_b.m_flow =  -ahu.senTemIn2.port_a.m_flow;
      ahu.senTemIn2.port_a.p = ahu.senTemIn2.port_b.p;
      ahu.senTemIn2.port_a.h_outflow = (if ahu.senTemIn2.allowFlowReversal then 
        inStream(ahu.senTemIn2.port_b.h_outflow) else 45300.945);
      ahu.senTemIn2.port_b.h_outflow = inStream(ahu.senTemIn2.port_a.h_outflow);
      ahu.senTemIn2.port_a.Xi_outflow = (if ahu.senTemIn2.allowFlowReversal
         then inStream(ahu.senTemIn2.port_b.Xi_outflow) else {0.01});
      ahu.senTemIn2.port_b.Xi_outflow = inStream(ahu.senTemIn2.port_a.Xi_outflow);
      ahu.senTemIn2.port_a.C_outflow = (if ahu.senTemIn2.allowFlowReversal then 
        inStream(ahu.senTemIn2.port_b.C_outflow) else zeros(1));
      ahu.senTemIn2.port_b.C_outflow = inStream(ahu.senTemIn2.port_a.C_outflow);
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialDynamicFlowSensor
    equation
      if (ahu.senTemIn2.dynamic) then 
        ahu.senTemIn2.mNor_flow = ahu.senTemIn2.port_a.m_flow/ahu.senTemIn2.m_flow_nominal;
        ahu.senTemIn2.k = Modelica.Fluid.Utilities.regStep(ahu.senTemIn2.port_a.m_flow,
           ahu.senTemIn2.mNor_flow,  -ahu.senTemIn2.mNor_flow, ahu.senTemIn2.m_flow_small);
      else
        ahu.senTemIn2.mNor_flow = 1;
        ahu.senTemIn2.k = 1;
      end if;
    // end of extends 
  equation
    if (ahu.senTemIn2.allowFlowReversal) then 
      ahu.senTemIn2.T_a_inflow = ahu.senTemIn2.temperature_Unique44(
        ahu.senTemIn2.setState_phX_Unique45(ahu.senTemIn2.port_b.p, 
          ahu.senTemIn2.port_b.h_outflow, ahu.senTemIn2.port_b.Xi_outflow));
      ahu.senTemIn2.T_b_inflow = ahu.senTemIn2.temperature_Unique44(
        ahu.senTemIn2.setState_phX_Unique45(ahu.senTemIn2.port_a.p, 
          ahu.senTemIn2.port_a.h_outflow, ahu.senTemIn2.port_a.Xi_outflow));
      ahu.senTemIn2.TMed = Modelica.Fluid.Utilities.regStep(ahu.senTemIn2.port_a.m_flow,
         ahu.senTemIn2.T_a_inflow, ahu.senTemIn2.T_b_inflow, ahu.senTemIn2.m_flow_small);
    else
      ahu.senTemIn2.TMed = ahu.senTemIn2.temperature_Unique44(
        ahu.senTemIn2.setState_phX_Unique45(ahu.senTemIn2.port_b.p, 
          ahu.senTemIn2.port_b.h_outflow, ahu.senTemIn2.port_b.Xi_outflow));
      ahu.senTemIn2.T_a_inflow = ahu.senTemIn2.TMed;
      ahu.senTemIn2.T_b_inflow = ahu.senTemIn2.TMed;
    end if;
    if (ahu.senTemIn2.dynamic) then 
      if (ahu.senTemIn2.transferHeat) then 
        der(ahu.senTemIn2.T) = (ahu.senTemIn2.TMed-ahu.senTemIn2.T)*
          ahu.senTemIn2.k*ahu.senTemIn2.tauInv+(ahu.senTemIn2.TAmb-
          ahu.senTemIn2.T)*ahu.senTemIn2.tauHeaTraInv/(ahu.senTemIn2.ratTau*
          ahu.senTemIn2.k+1);
      else
        der(ahu.senTemIn2.T) = (ahu.senTemIn2.TMed-ahu.senTemIn2.T)*
          ahu.senTemIn2.k*ahu.senTemIn2.tauInv;
      end if;
    else
      ahu.senTemIn2.T = ahu.senTemIn2.TMed;
    end if;

  // Component ahu.hex.bal1.vol
  // class Buildings.Fluid.Interfaces.StaticTwoPortConservationEquation
  equation
    connect(ahu.hex.bal1.vol.mWat_flow, ahu.hex.bal1.vol.mWat_flow_internal);
    if ( not ahu.hex.bal1.vol.use_mWat_flow) then 
      ahu.hex.bal1.vol.mWat_flow_internal = 0;
    end if;
    connect(ahu.hex.bal1.vol.C_flow, ahu.hex.bal1.vol.C_flow_internal);
    if ( not ahu.hex.bal1.vol.use_C_flow) then 
      ahu.hex.bal1.vol.C_flow_internal = zeros(1);
    end if;
    ahu.hex.bal1.vol.mXi_flow = ahu.hex.bal1.vol.mWat_flow_internal*
      ahu.hex.bal1.vol.s;
    if (ahu.hex.bal1.vol.use_m_flowInv) then 
      ahu.hex.bal1.vol.m_flowInv = Buildings.Utilities.Math.Functions.inverseXRegularized
        (ahu.hex.bal1.vol.port_a.m_flow, ahu.hex.bal1.vol.deltaReg, 
        ahu.hex.bal1.vol.deltaInvReg, ahu.hex.bal1.vol.aReg, ahu.hex.bal1.vol.bReg,
         ahu.hex.bal1.vol.cReg, ahu.hex.bal1.vol.dReg, ahu.hex.bal1.vol.eReg, 
        ahu.hex.bal1.vol.fReg);
    else
      ahu.hex.bal1.vol.m_flowInv = 0;
    end if;
    if (ahu.hex.bal1.vol.prescribedHeatFlowRate) then 
      assert(noEvent(abs(ahu.hex.bal1.vol.Q_flow) < ahu.hex.bal1.vol.dTMax*
        ahu.hex.bal1.vol.cp_default*max(ahu.hex.bal1.vol.m_flow_small/1000.0, 
        abs(ahu.hex.bal1.vol.m_flow))), "In RealOccupancy.ahu.hex.bal1.vol:
   The heat flow rate equals "
        +String(ahu.hex.bal1.vol.Q_flow)+" W and the mass flow rate equals "+
        String(ahu.hex.bal1.vol.m_flow)+" kg/s,
   which results in a temperature difference "
        +String(abs(ahu.hex.bal1.vol.Q_flow)/(ahu.hex.bal1.vol.cp_default*max(
        ahu.hex.bal1.vol.m_flow_small/1000.0, abs(ahu.hex.bal1.vol.m_flow))))+
        " K > dTMax="+String(ahu.hex.bal1.vol.dTMax)+" K.
   This may indicate that energy is not conserved for small mass flow rates.
   The implementation may require prescribedHeatFlowRate = false.");
    end if;
    if (ahu.hex.bal1.vol.allowFlowReversal) then 
      ahu.hex.bal1.vol.hOut = Buildings.Utilities.Math.Functions.regStep(
        ahu.hex.bal1.vol.port_a.m_flow, ahu.hex.bal1.vol.port_b.h_outflow, 
        ahu.hex.bal1.vol.port_a.h_outflow, ahu.hex.bal1.vol.m_flow_small/1000.0);
      ahu.hex.bal1.vol.XiOut = Buildings.Utilities.Math.Functions.regStep(
        ahu.hex.bal1.vol.port_a.m_flow, ahu.hex.bal1.vol.port_b.Xi_outflow, 
        ahu.hex.bal1.vol.port_a.Xi_outflow, ahu.hex.bal1.vol.m_flow_small/1000.0);
      ahu.hex.bal1.vol.COut = Buildings.Utilities.Math.Functions.regStep(
        ahu.hex.bal1.vol.port_a.m_flow, ahu.hex.bal1.vol.port_b.C_outflow, 
        ahu.hex.bal1.vol.port_a.C_outflow, ahu.hex.bal1.vol.m_flow_small/1000.0);
    else
      ahu.hex.bal1.vol.hOut = ahu.hex.bal1.vol.port_b.h_outflow;
      ahu.hex.bal1.vol.XiOut = ahu.hex.bal1.vol.port_b.Xi_outflow;
      ahu.hex.bal1.vol.COut = ahu.hex.bal1.vol.port_b.C_outflow;
    end if;
    ahu.hex.bal1.vol.port_a.m_flow+ahu.hex.bal1.vol.port_b.m_flow = (if 
      ahu.hex.bal1.vol.simplify_mWat_flow then 0 else  -ahu.hex.bal1.vol.mWat_flow_internal);
    if (ahu.hex.bal1.vol.use_m_flowInv) then 
      ahu.hex.bal1.vol.port_b.Xi_outflow = inStream(ahu.hex.bal1.vol.port_a.Xi_outflow)
        +ahu.hex.bal1.vol.mXi_flow*ahu.hex.bal1.vol.m_flowInv;
    else
      assert(ahu.hex.bal1.vol.use_mWat_flow == false, "In RealOccupancy.ahu.hex.bal1.vol: Wrong implementation for forward flow.");
      ahu.hex.bal1.vol.port_b.Xi_outflow = inStream(ahu.hex.bal1.vol.port_a.Xi_outflow);
    end if;
    if (ahu.hex.bal1.vol.allowFlowReversal) then 
      if (ahu.hex.bal1.vol.use_m_flowInv) then 
        ahu.hex.bal1.vol.port_a.Xi_outflow = inStream(ahu.hex.bal1.vol.port_b.Xi_outflow)
          -ahu.hex.bal1.vol.mXi_flow*ahu.hex.bal1.vol.m_flowInv;
      else
        assert(ahu.hex.bal1.vol.use_mWat_flow == false, "In RealOccupancy.ahu.hex.bal1.vol: Wrong implementation for reverse flow.");
        ahu.hex.bal1.vol.port_a.Xi_outflow = inStream(ahu.hex.bal1.vol.port_b.Xi_outflow);
      end if;
    else
      ahu.hex.bal1.vol.port_a.Xi_outflow = {0.01};
    end if;
    if (ahu.hex.bal1.vol.prescribedHeatFlowRate) then 
      ahu.hex.bal1.vol.port_b.h_outflow = inStream(ahu.hex.bal1.vol.port_a.h_outflow)
        +ahu.hex.bal1.vol.Q_flow*ahu.hex.bal1.vol.m_flowInv;
      if (ahu.hex.bal1.vol.allowFlowReversal) then 
        ahu.hex.bal1.vol.port_a.h_outflow = inStream(ahu.hex.bal1.vol.port_b.h_outflow)
          -ahu.hex.bal1.vol.Q_flow*ahu.hex.bal1.vol.m_flowInv;
      else
        ahu.hex.bal1.vol.port_a.h_outflow = 45300.945;
      end if;
    else
      ahu.hex.bal1.vol.port_a.m_flow*(inStream(ahu.hex.bal1.vol.port_a.h_outflow)
        -ahu.hex.bal1.vol.port_b.h_outflow) =  -ahu.hex.bal1.vol.Q_flow;
      if (ahu.hex.bal1.vol.allowFlowReversal) then 
        ahu.hex.bal1.vol.port_a.m_flow*(inStream(ahu.hex.bal1.vol.port_b.h_outflow)
          -ahu.hex.bal1.vol.port_a.h_outflow) = ahu.hex.bal1.vol.Q_flow;
      else
        ahu.hex.bal1.vol.port_a.h_outflow = 45300.945;
      end if;
    end if;
    if (ahu.hex.bal1.vol.use_m_flowInv and ahu.hex.bal1.vol.use_C_flow) then 
      ahu.hex.bal1.vol.port_b.C_outflow = inStream(ahu.hex.bal1.vol.port_a.C_outflow)
        +ahu.hex.bal1.vol.C_flow_internal*ahu.hex.bal1.vol.m_flowInv;
    else
      assert( not ahu.hex.bal1.vol.use_C_flow, "In RealOccupancy.ahu.hex.bal1.vol: Wrong implementation of trace substance balance for forward flow.");
      ahu.hex.bal1.vol.port_b.C_outflow = inStream(ahu.hex.bal1.vol.port_a.C_outflow);
    end if;
    if (ahu.hex.bal1.vol.allowFlowReversal) then 
      if (ahu.hex.bal1.vol.use_C_flow) then 
        ahu.hex.bal1.vol.port_a.C_outflow = inStream(ahu.hex.bal1.vol.port_b.C_outflow)
          -ahu.hex.bal1.vol.C_flow_internal*ahu.hex.bal1.vol.m_flowInv;
      else
        ahu.hex.bal1.vol.port_a.C_outflow = inStream(ahu.hex.bal1.vol.port_b.C_outflow);
      end if;
    else
      ahu.hex.bal1.vol.port_a.C_outflow = zeros(1);
    end if;
    ahu.hex.bal1.vol.port_a.p = ahu.hex.bal1.vol.port_b.p;

  // Component ahu.hex.bal1.preDro
  // class Buildings.Fluid.FixedResistances.PressureDrop
    // extends Buildings.Fluid.BaseClasses.PartialResistance
    equation
      ahu.hex.bal1.preDro.port_a.h_outflow = (if ahu.hex.bal1.preDro.allowFlowReversal
         then inStream(ahu.hex.bal1.preDro.port_b.h_outflow) else 45300.945);
      ahu.hex.bal1.preDro.port_b.h_outflow = inStream(ahu.hex.bal1.preDro.port_a.h_outflow);
      ahu.hex.bal1.preDro.port_a.m_flow+ahu.hex.bal1.preDro.port_b.m_flow = 0;
      ahu.hex.bal1.preDro.port_a.Xi_outflow = (if ahu.hex.bal1.preDro.allowFlowReversal
         then inStream(ahu.hex.bal1.preDro.port_b.Xi_outflow) else {0.01});
      ahu.hex.bal1.preDro.port_b.Xi_outflow = inStream(ahu.hex.bal1.preDro.port_a.Xi_outflow);
      ahu.hex.bal1.preDro.port_a.C_outflow = (if ahu.hex.bal1.preDro.allowFlowReversal
         then inStream(ahu.hex.bal1.preDro.port_b.C_outflow) else zeros(1));
      ahu.hex.bal1.preDro.port_b.C_outflow = inStream(ahu.hex.bal1.preDro.port_a.C_outflow);
    // end of extends 
  equation
    if (ahu.hex.bal1.preDro.computeFlowResistance) then 
      if (ahu.hex.bal1.preDro.linearized) then 
        if (ahu.hex.bal1.preDro.from_dp) then 
          ahu.hex.bal1.preDro.m_flow = ahu.hex.bal1.preDro.dp*ahu.hex.bal1.preDro.coeff;
        else
          ahu.hex.bal1.preDro.dp = ahu.hex.bal1.preDro.m_flow*ahu.hex.bal1.preDro.coeff;
        end if;
      else
        if (ahu.hex.bal1.preDro.homotopyInitialization) then 
          if (ahu.hex.bal1.preDro.from_dp) then 
            ahu.hex.bal1.preDro.m_flow = homotopy(Buildings.Fluid.BaseClasses.FlowModels.basicFlowFunction_dp
              (ahu.hex.bal1.preDro.dp, ahu.hex.bal1.preDro.k, ahu.hex.bal1.preDro.m_flow_turbulent),
               ahu.hex.bal1.preDro.m_flow_nominal_pos*ahu.hex.bal1.preDro.dp/
              ahu.hex.bal1.preDro.dp_nominal_pos);
          else
            ahu.hex.bal1.preDro.dp = homotopy(Buildings.Fluid.BaseClasses.FlowModels.basicFlowFunction_m_flow
              (ahu.hex.bal1.preDro.m_flow, ahu.hex.bal1.preDro.k, 
              ahu.hex.bal1.preDro.m_flow_turbulent), ahu.hex.bal1.preDro.dp_nominal_pos
              *ahu.hex.bal1.preDro.m_flow/ahu.hex.bal1.preDro.m_flow_nominal_pos);
          end if;
        else
          if (ahu.hex.bal1.preDro.from_dp) then 
            ahu.hex.bal1.preDro.m_flow = Buildings.Fluid.BaseClasses.FlowModels.basicFlowFunction_dp
              (ahu.hex.bal1.preDro.dp, ahu.hex.bal1.preDro.k, ahu.hex.bal1.preDro.m_flow_turbulent);
          else
            ahu.hex.bal1.preDro.dp = Buildings.Fluid.BaseClasses.FlowModels.basicFlowFunction_m_flow
              (ahu.hex.bal1.preDro.m_flow, ahu.hex.bal1.preDro.k, 
              ahu.hex.bal1.preDro.m_flow_turbulent);
          end if;
        end if;
      end if;
    else
      ahu.hex.bal1.preDro.dp = 0;
    end if;

  // Component ahu.hex.bal1
  // class Buildings.Fluid.Interfaces.StaticTwoPortHeatMassExchanger
  equation
    connect(ahu.hex.bal1.vol.hOut, ahu.hex.bal1.hOut);
    connect(ahu.hex.bal1.vol.XiOut, ahu.hex.bal1.XiOut);
    connect(ahu.hex.bal1.vol.COut, ahu.hex.bal1.COut);
    connect(ahu.hex.bal1.port_a, ahu.hex.bal1.preDro.port_a);
    connect(ahu.hex.bal1.preDro.port_b, ahu.hex.bal1.vol.port_a);
    connect(ahu.hex.bal1.vol.port_b, ahu.hex.bal1.port_b);
    connect(ahu.hex.bal1.heaInp.y, ahu.hex.bal1.vol.Q_flow);
    connect(ahu.hex.bal1.masExc.y, ahu.hex.bal1.vol.mWat_flow);

