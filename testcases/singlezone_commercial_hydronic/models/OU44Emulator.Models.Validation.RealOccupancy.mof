model RealOccupancy
  parameter Modelica.SIunits.Area AFlo(unit = "m2") = 8500 "Floor area";
  parameter Modelica.SIunits.Length hRoo(unit = "m") = 3.2 "Average room height";
  parameter Modelica.SIunits.MassFlowRate m_flow_nominal_water(unit = "kg/s") = 2
     "Nominal mass flow rate for water loop";
  parameter Modelica.SIunits.MassFlowRate m_flow_nominal_air(unit = "kg/s") = 31
     "Nominal mass flow rate for air system";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanSu.energyDynamics = 
    Modelica.Fluid.Types.Dynamics.SteadyState "Type of energy balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanSu.massDynamics = 
    Modelica.Fluid.Types.Dynamics.SteadyState "Type of mass balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanSu.substanceDynamics = 
    ahu.fanSu.energyDynamics "Type of independent mass fraction balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanSu.traceDynamics = 
    ahu.fanSu.energyDynamics "Type of trace substance balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanSu.p_start(
    start = 101325, nominal = 100000.0, unit = "Pa", displayUnit = "bar", min = 
    0.0, max = 100000000.0) = 101325 "Start value of pressure";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanSu.T_start(
    start = 293.15, nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0,
     max = 10000.0) = 293.15 "Start value of temperature";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanSu.X_start[2](
    nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = {0.01, 0.99} 
    "Start value of mass fractions m_i/m";
  parameter Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanSu.C_start[1](
    start = fill(1.0, size(ahu.fanSu.C_start, 1)), min = 0.0) = fill(0, 1) 
    "Start value of trace substances";
  parameter Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanSu.C_nominal[1]
    (start = fill(1.0, size(ahu.fanSu.C_nominal, 1)), min = 0.0) = fill(0.01, 1)
     "Nominal value of trace substances. (Set to typical order of magnitude.)";
  parameter Real ahu.fanSu.mSenFac(min = 1.0) = 1 "Factor for scaling the sensible thermal mass of the volume";
  constant Boolean ahu.fanSu.allowFlowReversal = true "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.fanSu.m_flow_nominal(unit = "kg/s",
     min = 1E-60) = max(ahu.fanSu.per.pressure.V_flow)*ahu.fanSu.rho_default 
    "Nominal mass flow rate";
  parameter Modelica.SIunits.MassFlowRate ahu.fanSu.m_flow_small(unit = "kg/s", 
    min = 0.0) = 0.0001*abs(ahu.fanSu.m_flow_nominal) "Small mass flow rate for regularization of zero flow";
  constant Boolean ahu.fanSu.show_T = false "= true, if actual temperature at port is computed";
  parameter Modelica.SIunits.MassFlowRate ahu.fanSu._m_flow_start(unit = "kg/s")
     = 0 "Start value for m_flow, used to avoid a warning if not set in m_flow, and to avoid m_flow.start in parameter window";
  parameter Modelica.SIunits.PressureDifference ahu.fanSu._dp_start(unit = "Pa",
     displayUnit = "Pa") = 0 "Start value for dp, used to avoid a warning if not set in dp, and to avoid dp.start in parameter window";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.per.pressure.V_flow[:](
    unit = "m3/s", min = 0.0) = {16, 25, 35} "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanSu.per.pressure.dp[size(
    ahu.fanSu.per.pressure.V_flow, 1)](unit = "Pa", displayUnit = "Pa", min = 
    0.0) = {800, 680, 100} "Fan or pump total pressure at these flow rates";
  parameter Boolean ahu.fanSu.per.use_powerCharacteristic = true 
    "Use power data instead of motor efficiency";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.per.hydraulicEfficiency.V_flow
    [:](unit = "m3/s", min = 0.0) = {0} "Volumetric flow rate at user-selected operating points";
  parameter Modelica.SIunits.Efficiency ahu.fanSu.per.hydraulicEfficiency.eta[
    size(ahu.fanSu.per.hydraulicEfficiency.V_flow, 1)](unit = "1", min = 0.0, 
    max = 1.0) = {0.7} "Fan or pump efficiency at these flow rates";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.per.motorEfficiency.V_flow
    [:](unit = "m3/s", min = 0.0) = {0} "Volumetric flow rate at user-selected operating points";
  parameter Modelica.SIunits.Efficiency ahu.fanSu.per.motorEfficiency.eta[size(
    ahu.fanSu.per.motorEfficiency.V_flow, 1)](unit = "1", min = 0.0, max = 1.0)
     = {0.7} "Fan or pump efficiency at these flow rates";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.per.power.V_flow[:](
    unit = "m3/s", min = 0.0) = {16, 25, 35} "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.Power ahu.fanSu.per.power.P[size(ahu.fanSu.per.power.V_flow,
     1)](unit = "W", min = 0.0) = {18000, 25000, 30000} "Fan or pump electrical power at these flow rates";
  parameter Boolean ahu.fanSu.per.motorCooledByFluid = true "If true, then motor heat is added to fluid stream";
  parameter Real ahu.fanSu.per.speed_nominal(unit = "1", min = 0.0) = 1 
    "Nominal rotational speed for flow characteristic";
  parameter Real ahu.fanSu.per.constantSpeed(unit = "1", min = 0.0) = 
    ahu.fanSu.per.constantSpeed_rpm/ahu.fanSu.per.speed_rpm_nominal 
    "Normalized speed set point, used if inputType = Buildings.Fluid.Types.InputType.Constant";
  parameter Real ahu.fanSu.per.speeds[:](unit = "1", min = 0.0) = 
    ahu.fanSu.per.speeds_rpm/ahu.fanSu.per.speed_rpm_nominal "Vector of normalized speed set points, used if inputType = Buildings.Fluid.Types.InputType.Stages";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanSu.per.speed_rpm_nominal(unit = "rev/min") = 600 "Nominal rotational speed for flow characteristic";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanSu.per.constantSpeed_rpm(unit = "rev/min") = ahu.fanSu.per.speed_rpm_nominal
     "Speed set point, used if inputType = Buildings.Fluid.Types.InputType.Constant";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanSu.per.speeds_rpm[:](unit = "rev/min") = {ahu.fanSu.per.speed_rpm_nominal}
     "Vector of speed set points, used if inputType = Buildings.Fluid.Types.InputType.Stages";
  parameter Boolean ahu.fanSu.per.havePressureCurve = sum(ahu.fanSu.per.pressure.V_flow)
     > 1E-15 and sum(ahu.fanSu.per.pressure.dp) > 1E-15 "= true, if default record values are being used";
  constant Buildings.Fluid.Types.InputType ahu.fanSu.inputType = 
    Buildings.Fluid.Types.InputType.Continuous "Control input type";
  parameter Real ahu.fanSu.constInput(unit = "1") = ahu.fanSu.per.constantSpeed 
    "Constant input set point";
  parameter Real ahu.fanSu.stageInputs[:](unit = "1") = ahu.fanSu.per.speeds 
    "Vector of input set points corresponding to stages";
  parameter Boolean ahu.fanSu.computePowerUsingSimilarityLaws = true 
    "= true, compute power exactly, using similarity laws. Otherwise approximate.";
  constant Boolean ahu.fanSu.addPowerToMedium = false "Set to false to avoid any power (=heat and flow work) being added to medium (may give simpler equations)";
  parameter Boolean ahu.fanSu.nominalValuesDefineDefaultPressureCurve = false 
    "Set to true to avoid warning if m_flow_nominal and dp_nominal are used to construct the default pressure curve";
  parameter Modelica.SIunits.Time ahu.fanSu.tau(unit = "s") = 1 "Time constant of fluid volume for nominal flow, used if energy or mass balance is dynamic";
  constant Boolean ahu.fanSu.use_inputFilter = true "= true, if speed is filtered with a 2nd order CriticalDamping filter";
  parameter Modelica.SIunits.Time ahu.fanSu.riseTime(unit = "s") = 30 
    "Rise time of the filter (time to reach 99.6 % of the speed)";
  parameter Modelica.Blocks.Types.Init ahu.fanSu.init = Modelica.Blocks.Types.Init.
    InitialOutput "Type of initialization (no init/steady state/initial state/initial output)";
  parameter Real ahu.fanSu.y_start(unit = "1", min = 0.0, max = 1.0) = 0 
    "Initial value of speed";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu._VMachine_flow(unit = 
    "m3/s") = 0 "Start value for VMachine_flow, used to avoid a warning if not specified";
  constant Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable 
    ahu.fanSu.preVar = Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
    Speed "Type of prescribed variable";
  constant Boolean ahu.fanSu.speedIsInput = true "Parameter that is true if speed is the controlled variables";
  parameter Integer ahu.fanSu.nOri = size(ahu.fanSu.per.pressure.V_flow, 1) 
    "Number of data points for pressure curve";
  parameter Boolean ahu.fanSu.haveVMax = abs(ahu.fanSu.per.pressure.dp[
    ahu.fanSu.nOri]) < 1E-15 "Flag, true if user specified data that contain V_flow_max";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.V_flow_max(unit = "m3/s")
     = (if ahu.fanSu.per.havePressureCurve then (if ahu.fanSu.haveVMax then 
    ahu.fanSu.per.pressure.V_flow[ahu.fanSu.nOri] else ahu.fanSu.per.pressure.V_flow
    [ahu.fanSu.nOri]-(ahu.fanSu.per.pressure.V_flow[ahu.fanSu.nOri]-
    ahu.fanSu.per.pressure.V_flow[ahu.fanSu.nOri-1])/(ahu.fanSu.per.pressure.dp[
    ahu.fanSu.nOri]-ahu.fanSu.per.pressure.dp[ahu.fanSu.nOri-1])*
    ahu.fanSu.per.pressure.dp[ahu.fanSu.nOri]) else ahu.fanSu.m_flow_nominal/
    ahu.fanSu.rho_default) "Maximum volume flow rate, used for smoothing";
  parameter Modelica.SIunits.Density ahu.fanSu.rho_default(unit = "kg/m3", 
    displayUnit = "g/cm3", min = 0.0) = ahu.fanSu.density_pTX_Unique6(101325, 
    293.15, {0.01, 0.99}) "Default medium density";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanSu.sta_start.p
    (nominal = 100000.0, unit = "Pa", displayUnit = "bar", min = 0.0, max = 
    100000000.0) = 101325 "Absolute pressure of medium";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanSu.sta_start.T(
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0, max = 10000.0)
     = 293.15 "Temperature of medium";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanSu.sta_start.X[2]
    (nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = {0.01, 0.99} 
    "Mass fractions (= (component mass)/total mass  m_i/m)";
  parameter Modelica.SIunits.SpecificEnthalpy ahu.fanSu.h_outflow_start(unit = 
    "J/kg") = ahu.fanSu.specificEnthalpy_Unique10(
    ahu.fanSu.sta_start) "Start value for outflowing enthalpy";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanSu.vol.energyDynamics = 
    ahu.fanSu.energyDynamics "Type of energy balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanSu.vol.massDynamics = 
    ahu.fanSu.massDynamics "Type of mass balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanSu.vol.substanceDynamics = 
    ahu.fanSu.vol.energyDynamics "Type of independent mass fraction balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanSu.vol.traceDynamics = 
    ahu.fanSu.vol.energyDynamics "Type of trace substance balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanSu.vol.p_start
    (start = 101325, nominal = 100000.0, unit = "Pa", displayUnit = "bar", 
    min = 0.0, max = 100000000.0) = ahu.fanSu.p_start "Start value of pressure";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanSu.vol.T_start(
    start = 293.15, nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0,
     max = 10000.0) = ahu.fanSu.T_start "Start value of temperature";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanSu.vol.X_start[2]
    (nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = ahu.fanSu.X_start 
    "Start value of mass fractions m_i/m";
  parameter Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanSu.vol.C_start[1]
    (start = fill(1.0, size(ahu.fanSu.vol.C_start, 1)), min = 0.0) = 
    ahu.fanSu.C_start "Start value of trace substances";
  constant Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanSu.vol.C_nominal
    [1](min = 0.0) = {0.01} "Nominal value of trace substances. (Set to typical order of magnitude.)";
  parameter Real ahu.fanSu.vol.mSenFac(min = 1.0) = 1 "Factor for scaling the sensible thermal mass of the volume";
  parameter Boolean ahu.fanSu.vol.initialize_p = true "= true to set up initial equations for pressure";
  constant Boolean ahu.fanSu.vol.prescribedHeatFlowRate = true "Set to true if the model has a prescribed heat flow at its heatPort. If the heat flow rate at the heatPort is only based on temperature difference, then set to false";
  constant Boolean ahu.fanSu.vol.simplify_mWat_flow = true "Set to true to cause port_a.m_flow + port_b.m_flow = 0 even if mWat_flow is non-zero";
  parameter Modelica.SIunits.MassFlowRate ahu.fanSu.vol.m_flow_nominal(unit = 
    "kg/s", min = 0.0) = ahu.fanSu.m_flow_nominal "Nominal mass flow rate";
  constant Integer ahu.fanSu.vol.nPorts = 2 "Number of ports";
  parameter Modelica.SIunits.MassFlowRate ahu.fanSu.vol.m_flow_small(unit = 
    "kg/s", min = 0.0) = ahu.fanSu.m_flow_small "Small mass flow rate for regularization of zero flow";
  parameter Boolean ahu.fanSu.vol.allowFlowReversal = ahu.fanSu.allowFlowReversal
     "= false to simplify equations, assuming, but not enforcing, no flow reversal. Used only if model has two ports.";
  parameter Modelica.SIunits.Volume ahu.fanSu.vol.V(unit = "m3") = 
    ahu.fanSu.vol.V_nominal "Volume";
  parameter Modelica.SIunits.Density ahu.fanSu.vol.rho_start(unit = "kg/m3", 
    displayUnit = "g/cm3", min = 0.0) = ahu.fanSu.vol.density_Unique16(
    ahu.fanSu.vol.state_start) "Density, used to compute start and guess values";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanSu.vol.state_default.p
    (nominal = 100000.0, unit = "Pa", displayUnit = "bar", min = 0.0, max = 
    100000000.0) = 101325 "Absolute pressure of medium";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanSu.vol.state_default.T
    (nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0, max = 10000.0)
     = 293.15 "Temperature of medium";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanSu.vol.state_default.X
    [2](nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = {0.01, 0.99} 
    "Mass fractions (= (component mass)/total mass  m_i/m)";
  parameter Modelica.SIunits.Density ahu.fanSu.vol.rho_default(unit = "kg/m3", 
    displayUnit = "g/cm3", min = 0.0) = ahu.fanSu.vol.density_Unique16(
    ahu.fanSu.vol.state_default) "Density, used to compute fluid mass";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanSu.vol.state_start.p
    (nominal = 100000.0, unit = "Pa", displayUnit = "bar", min = 0.0, max = 
    100000000.0) = 101325 "Absolute pressure of medium";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanSu.vol.state_start.T
    (nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0, max = 10000.0)
     = 293.15 "Temperature of medium";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanSu.vol.state_start.X
    [2](nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = {0.01, 0.99} 
    "Mass fractions (= (component mass)/total mass  m_i/m)";
  parameter Boolean ahu.fanSu.vol.useSteadyStateTwoPort = ahu.fanSu.vol.nPorts
     == 2 and (ahu.fanSu.vol.prescribedHeatFlowRate or  not ahu.fanSu.vol.allowFlowReversal)
     and ahu.fanSu.vol.energyDynamics == Modelica.Fluid.Types.Dynamics.
    SteadyState and ahu.fanSu.vol.massDynamics == Modelica.Fluid.Types.Dynamics.
    SteadyState and ahu.fanSu.vol.substanceDynamics == Modelica.Fluid.Types.Dynamics.
    SteadyState and ahu.fanSu.vol.traceDynamics == Modelica.Fluid.Types.Dynamics.
    SteadyState "Flag, true if the model has two ports only and uses a steady state balance";
  constant Boolean ahu.fanSu.vol.use_C_flow = false "Set to true to enable input connector for trace substance";
  parameter Modelica.SIunits.Time ahu.fanSu.vol.tau(unit = "s") = ahu.fanSu.tau 
    "Time constant at nominal flow";
  parameter Modelica.SIunits.Volume ahu.fanSu.vol.V_nominal(unit = "m3") = 
    ahu.fanSu.vol.m_flow_nominal*ahu.fanSu.vol.tau/ahu.fanSu.vol.rho_default 
    "Volume of delay element";
  parameter Modelica.Blocks.Types.AnalogFilter ahu.fanSu.filter.analogFilter = 
    Modelica.Blocks.Types.AnalogFilter.CriticalDamping "Analog filter characteristics (CriticalDamping/Bessel/Butterworth/ChebyshevI)";
  parameter Modelica.Blocks.Types.FilterType ahu.fanSu.filter.filterType = 
    Modelica.Blocks.Types.FilterType.LowPass "Type of filter (LowPass/HighPass/BandPass/BandStop)";
  parameter Integer ahu.fanSu.filter.order(min = 1.0) = 2 "Order of filter";
  parameter Modelica.SIunits.Frequency ahu.fanSu.filter.f_cut(unit = "Hz") = 5/(
    6.283185307179586*ahu.fanSu.riseTime) "Cut-off frequency";
  parameter Real ahu.fanSu.filter.gain = 1.0 "Gain (= amplitude of frequency response at zero frequency)";
  parameter Real ahu.fanSu.filter.A_ripple(unit = "dB") = 0.5 "Pass band ripple for Chebyshev filter (otherwise not used); > 0 required";
  parameter Modelica.SIunits.Frequency ahu.fanSu.filter.f_min(unit = "Hz") = 0 
    "Band of band pass/stop filter is f_min (A=-3db*gain) .. f_cut (A=-3db*gain)";
  parameter Boolean ahu.fanSu.filter.normalized = true "= true, if amplitude at f_cut = -3db, otherwise unmodified filter";
  parameter Modelica.Blocks.Types.Init ahu.fanSu.filter.init = ahu.fanSu.init 
    "Type of initialization (no init/steady state/initial state/initial output)";
  parameter Integer ahu.fanSu.filter.nx = (if ahu.fanSu.filter.filterType == 
    Modelica.Blocks.Types.FilterType.LowPass or ahu.fanSu.filter.filterType == 
    Modelica.Blocks.Types.FilterType.HighPass then ahu.fanSu.filter.order else 2
    *ahu.fanSu.filter.order);
  parameter Real ahu.fanSu.filter.x_start[ahu.fanSu.filter.nx] = zeros(
    ahu.fanSu.filter.nx) "Initial or guess values of states";
  parameter Real ahu.fanSu.filter.y_start = ahu.fanSu.y_start "Initial value of output";
  parameter Real ahu.fanSu.filter.u_nominal = 1 "Nominal value of input (used for scaling the states)";
  parameter Integer ahu.fanSu.filter.ncr = (if ahu.fanSu.filter.analogFilter == 
    Modelica.Blocks.Types.AnalogFilter.CriticalDamping then ahu.fanSu.filter.order
     else mod(ahu.fanSu.filter.order, 2));
  parameter Integer ahu.fanSu.filter.nc0 = (if ahu.fanSu.filter.analogFilter == 
    Modelica.Blocks.Types.AnalogFilter.CriticalDamping then 0 else integer(
    ahu.fanSu.filter.order/2));
  parameter Integer ahu.fanSu.filter.na = (if ahu.fanSu.filter.filterType == 
    Modelica.Blocks.Types.FilterType.BandPass or ahu.fanSu.filter.filterType == 
    Modelica.Blocks.Types.FilterType.BandStop then ahu.fanSu.filter.order else (
    if ahu.fanSu.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
    CriticalDamping then 0 else integer(ahu.fanSu.filter.order/2)));
  parameter Integer ahu.fanSu.filter.nr = (if ahu.fanSu.filter.filterType == 
    Modelica.Blocks.Types.FilterType.BandPass or ahu.fanSu.filter.filterType == 
    Modelica.Blocks.Types.FilterType.BandStop then 0 else (if ahu.fanSu.filter.analogFilter
     == Modelica.Blocks.Types.AnalogFilter.CriticalDamping then ahu.fanSu.filter.order
     else mod(ahu.fanSu.filter.order, 2)));
  parameter Real ahu.fanSu.filter.cr[ahu.fanSu.filter.ncr](fixed = false);
  parameter Real ahu.fanSu.filter.c0[ahu.fanSu.filter.nc0](fixed = false);
  parameter Real ahu.fanSu.filter.c1[ahu.fanSu.filter.nc0](fixed = false);
  parameter Real ahu.fanSu.filter.r[ahu.fanSu.filter.nr](fixed = false);
  parameter Real ahu.fanSu.filter.a[ahu.fanSu.filter.na](fixed = false);
  parameter Real ahu.fanSu.filter.b[ahu.fanSu.filter.na](fixed = false);
  parameter Real ahu.fanSu.filter.ku[ahu.fanSu.filter.na](fixed = false);
  parameter Real ahu.fanSu.filter.k1[(if ahu.fanSu.filter.filterType == 
    Modelica.Blocks.Types.FilterType.LowPass then 0 else ahu.fanSu.filter.na)](
    fixed = false);
  parameter Real ahu.fanSu.filter.k2[(if ahu.fanSu.filter.filterType == 
    Modelica.Blocks.Types.FilterType.LowPass then 0 else ahu.fanSu.filter.na)](
    fixed = false);
  parameter Real ahu.fanSu.gaiSpe.k(start = 1, unit = "1") = 1/ahu.fanSu.per.speed_nominal
     "Gain value multiplied with input signal";
  constant Boolean ahu.fanSu.preSou.allowFlowReversal = true "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.PressureDifference ahu.fanSu.preSou.dp_start(
    unit = "Pa", displayUnit = "Pa") = 0 "Guess value of dp = port_a.p - port_b.p";
  parameter Modelica.Media.Interfaces.PartialMedium.MassFlowRate 
    ahu.fanSu.preSou.m_flow_start(unit = "kg/s", min = -100000.0, max = 100000.0)
     = 0 "Guess value of m_flow = port_a.m_flow";
  parameter Modelica.Media.Interfaces.PartialMedium.MassFlowRate 
    ahu.fanSu.preSou.m_flow_small(unit = "kg/s", min = -100000.0, max = 100000.0)
     = ahu.fanSu.m_flow_small "Small mass flow rate for regularization of zero flow";
  constant Boolean ahu.fanSu.preSou.show_T = false "= true, if temperatures at port_a and port_b are computed";
  constant Boolean ahu.fanSu.preSou.show_V_flow = true "= true, if volume flow rate at inflowing port is computed";
  constant Boolean ahu.fanSu.preSou.control_m_flow = false "if true, then the mass flow rate is equal to the value of m_flow_in";
  constant Boolean ahu.fanSu.preSou.control_dp = true "if true, then the head is equal to the value of dp_in";
  constant Boolean ahu.fanSu.senMasFlo.allowFlowReversal = true "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.fanSu.senMasFlo.m_flow_nominal(
    unit = "kg/s", min = 0.0) = 0 "Nominal mass flow rate, used for regularization near zero flow";
  parameter Modelica.SIunits.MassFlowRate ahu.fanSu.senMasFlo.m_flow_small(
    unit = "kg/s", min = 0.0) = 0 "For bi-directional flow, temperature is regularized in the region |m_flow| < m_flow_small (m_flow_small > 0 required)";
  constant Boolean ahu.fanSu.eff.homotopyInitialization = true "= true, use homotopy method";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.eff.per.pressure.V_flow[:]
    (unit = "m3/s", min = 0.0) "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanSu.eff.per.pressure.dp[
    size(ahu.fanSu.eff.per.pressure.V_flow, 1)](unit = "Pa", displayUnit = "Pa",
     min = 0.0) "Fan or pump total pressure at these flow rates";
  parameter Boolean ahu.fanSu.eff.per.use_powerCharacteristic = ahu.fanSu.per.use_powerCharacteristic
     "Use power data instead of motor efficiency";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.eff.per.hydraulicEfficiency.V_flow
    [:](unit = "m3/s", min = 0.0) "Volumetric flow rate at user-selected operating points";
  parameter Modelica.SIunits.Efficiency ahu.fanSu.eff.per.hydraulicEfficiency.eta
    [size(ahu.fanSu.eff.per.hydraulicEfficiency.V_flow, 1)](unit = "1", min = 
    0.0, max = 1.0) "Fan or pump efficiency at these flow rates";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.eff.per.motorEfficiency.V_flow
    [:](unit = "m3/s", min = 0.0) "Volumetric flow rate at user-selected operating points";
  parameter Modelica.SIunits.Efficiency ahu.fanSu.eff.per.motorEfficiency.eta[
    size(ahu.fanSu.eff.per.motorEfficiency.V_flow, 1)](unit = "1", min = 0.0, 
    max = 1.0) "Fan or pump efficiency at these flow rates";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.eff.per.power.V_flow[:](
    unit = "m3/s", min = 0.0) "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.Power ahu.fanSu.eff.per.power.P[size(
    ahu.fanSu.eff.per.power.V_flow, 1)](unit = "W", min = 0.0) "Fan or pump electrical power at these flow rates";
  parameter Boolean ahu.fanSu.eff.per.motorCooledByFluid = ahu.fanSu.per.motorCooledByFluid
     "If true, then motor heat is added to fluid stream";
  parameter Real ahu.fanSu.eff.per.speed_nominal(unit = "1", min = 0.0) = 0 
    "Nominal rotational speed for flow characteristic";
  parameter Real ahu.fanSu.eff.per.constantSpeed(unit = "1", min = 0.0) = 0 
    "Normalized speed set point, used if inputType = Buildings.Fluid.Types.InputType.Constant";
  parameter Real ahu.fanSu.eff.per.speeds[:](unit = "1", min = 0.0) = {0} 
    "Vector of normalized speed set points, used if inputType = Buildings.Fluid.Types.InputType.Stages";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanSu.eff.per.speed_rpm_nominal(unit = "rev/min") = 1500 
    "Nominal rotational speed for flow characteristic";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanSu.eff.per.constantSpeed_rpm(unit = "rev/min") = ahu.fanSu.eff.per.speed_rpm_nominal
     "Speed set point, used if inputType = Buildings.Fluid.Types.InputType.Constant";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanSu.eff.per.speeds_rpm[:](unit = "rev/min") = {ahu.fanSu.eff.per.speed_rpm_nominal}
     "Vector of speed set points, used if inputType = Buildings.Fluid.Types.InputType.Stages";
  parameter Boolean ahu.fanSu.eff.per.havePressureCurve = sum(ahu.fanSu.eff.per.pressure.V_flow)
     > 1E-15 and sum(ahu.fanSu.eff.per.pressure.dp) > 1E-15 "= true, if default record values are being used";
  parameter Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable 
    ahu.fanSu.eff.preVar = ahu.fanSu.preVar "Type of prescribed variable";
  parameter Boolean ahu.fanSu.eff.computePowerUsingSimilarityLaws = 
    ahu.fanSu.computePowerUsingSimilarityLaws "= true, compute power exactly, using similarity laws. Otherwise approximate.";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.eff.V_flow_nominal(unit = 
    "m3/s") = ahu.fanSu.eff.per.pressure.V_flow[ahu.fanSu.eff.nOri] 
    "Nominal volume flow rate, used for homotopy";
  parameter Modelica.SIunits.Density ahu.fanSu.eff.rho_default(unit = "kg/m3", 
    displayUnit = "g/cm3", min = 0.0) = ahu.fanSu.rho_default "Fluid density at medium default state";
  parameter Boolean ahu.fanSu.eff.haveVMax = ahu.fanSu.haveVMax "Flag, true if user specified data that contain V_flow_max";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.eff.V_flow_max(unit = 
    "m3/s") = ahu.fanSu.V_flow_max "Maximum volume flow rate, used for smoothing";
  parameter Integer ahu.fanSu.eff.nOri(min = 1.0) = ahu.fanSu.nOri 
    "Number of data points for pressure curve";
  parameter Boolean ahu.fanSu.eff.preSpe = ahu.fanSu.eff.preVar == 
    Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.Speed 
    "True if speed is a prescribed variable of this block";
  parameter Boolean ahu.fanSu.eff.prePre = ahu.fanSu.eff.preVar == 
    Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.PressureDifference
     or ahu.fanSu.eff.preVar == Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
    FlowRate "True if pressure head is a prescribed variable of this block";
  parameter Real ahu.fanSu.eff.motDer[size(ahu.fanSu.eff.per.motorEfficiency.V_flow,
     1)](fixed = false) "Coefficients for polynomial of motor efficiency vs. volume flow rate";
  parameter Real ahu.fanSu.eff.hydDer[size(ahu.fanSu.eff.per.hydraulicEfficiency.V_flow,
     1)](fixed = false) "Coefficients for polynomial of hydraulic efficiency vs. volume flow rate";
  parameter Modelica.SIunits.PressureDifference ahu.fanSu.eff.dpMax(unit = "Pa",
     displayUnit = "Pa") = (if ahu.fanSu.eff.haveDPMax then ahu.fanSu.eff.per.pressure.dp
    [1] else ahu.fanSu.eff.per.pressure.dp[1]-(ahu.fanSu.eff.per.pressure.dp[2]-
    ahu.fanSu.eff.per.pressure.dp[1])/(ahu.fanSu.eff.per.pressure.V_flow[2]-
    ahu.fanSu.eff.per.pressure.V_flow[1])*ahu.fanSu.eff.per.pressure.V_flow[1]) 
    "Maximum head";
  parameter Real ahu.fanSu.eff.delta = 0.05 "Small value used to for regularization and to approximate an internal flow resistance of the fan";
  parameter Real ahu.fanSu.eff.kRes(unit = "kg/(s.m4)", min = 0.0) = 
    ahu.fanSu.eff.dpMax/ahu.fanSu.eff.V_flow_max*ahu.fanSu.eff.delta^2/10 
    "Coefficient for internal pressure drop of fan or pump";
  parameter Integer ahu.fanSu.eff.curve = (if ahu.fanSu.eff.haveVMax and 
    ahu.fanSu.eff.haveDPMax or ahu.fanSu.eff.nOri == 2 then 1 else (if 
    ahu.fanSu.eff.haveVMax or ahu.fanSu.eff.haveDPMax then 2 else 3)) 
    "Flag, used to pick the right representatio of the fan or pump pressure curve";
  parameter Integer ahu.fanSu.eff.pCur1.n = ahu.fanSu.eff.nOri "Number of elements in each array";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.eff.pCur1.V_flow[
    ahu.fanSu.eff.pCur1.n](unit = "m3/s", min = 0.0) = (if ahu.fanSu.eff.haveVMax
     and ahu.fanSu.eff.haveDPMax or ahu.fanSu.eff.nOri == 2 then (array(
    ahu.fanSu.eff.per.pressure.V_flow[i] for i in 1:ahu.fanSu.eff.nOri)) else 
    zeros(ahu.fanSu.eff.nOri)) "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanSu.eff.pCur1.dp[
    ahu.fanSu.eff.pCur1.n](unit = "Pa", displayUnit = "Pa", min = 0.0) = (if 
    ahu.fanSu.eff.haveVMax and ahu.fanSu.eff.haveDPMax or ahu.fanSu.eff.nOri == 2
     then (array(ahu.fanSu.eff.per.pressure.dp[i]+ahu.fanSu.eff.per.pressure.V_flow
    [i]*ahu.fanSu.eff.kRes for i in 1:ahu.fanSu.eff.nOri)) else zeros(
    ahu.fanSu.eff.nOri)) "Fan or pump total pressure at these flow rates";
  parameter Integer ahu.fanSu.eff.pCur2.n = ahu.fanSu.eff.nOri+1 
    "Number of elements in each array";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.eff.pCur2.V_flow[
    ahu.fanSu.eff.pCur2.n](unit = "m3/s", min = 0.0) = (if ahu.fanSu.eff.haveVMax
     and ahu.fanSu.eff.haveDPMax or ahu.fanSu.eff.nOri == 2 then zeros(
    ahu.fanSu.eff.nOri+1) else (if ahu.fanSu.eff.haveVMax then cat(1, {0}, array
    (ahu.fanSu.eff.per.pressure.V_flow[i] for i in 1:ahu.fanSu.eff.nOri)) else (
    if ahu.fanSu.eff.haveDPMax then cat(1, array(ahu.fanSu.eff.per.pressure.V_flow
    [i] for i in 1:ahu.fanSu.eff.nOri), {ahu.fanSu.eff.V_flow_max}) else zeros(
    ahu.fanSu.eff.nOri+1)))) "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanSu.eff.pCur2.dp[
    ahu.fanSu.eff.pCur2.n](unit = "Pa", displayUnit = "Pa", min = 0.0) = (if 
    ahu.fanSu.eff.haveVMax and ahu.fanSu.eff.haveDPMax or ahu.fanSu.eff.nOri == 2
     then zeros(ahu.fanSu.eff.nOri+1) else (if ahu.fanSu.eff.haveVMax then cat(1,
     {ahu.fanSu.eff.dpMax}, array(ahu.fanSu.eff.per.pressure.dp[i]+
    ahu.fanSu.eff.per.pressure.V_flow[i]*ahu.fanSu.eff.kRes for i in 1:
    ahu.fanSu.eff.nOri)) else (if ahu.fanSu.eff.haveDPMax then cat(1, array(
    ahu.fanSu.eff.per.pressure.dp[i]+ahu.fanSu.eff.per.pressure.V_flow[i]*
    ahu.fanSu.eff.kRes for i in 1:ahu.fanSu.eff.nOri), {0}) else zeros(
    ahu.fanSu.eff.nOri+1)))) "Fan or pump total pressure at these flow rates";
  parameter Integer ahu.fanSu.eff.pCur3.n = ahu.fanSu.eff.nOri+2 
    "Number of elements in each array";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanSu.eff.pCur3.V_flow[
    ahu.fanSu.eff.pCur3.n](unit = "m3/s", min = 0.0) = (if ahu.fanSu.eff.haveVMax
     and ahu.fanSu.eff.haveDPMax or ahu.fanSu.eff.nOri == 2 then zeros(
    ahu.fanSu.eff.nOri+2) else (if ahu.fanSu.eff.haveVMax or ahu.fanSu.eff.haveDPMax
     then zeros(ahu.fanSu.eff.nOri+2) else cat(1, {0}, array(ahu.fanSu.eff.per.pressure.V_flow
    [i] for i in 1:ahu.fanSu.eff.nOri), {ahu.fanSu.eff.V_flow_max}))) 
    "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanSu.eff.pCur3.dp[
    ahu.fanSu.eff.pCur3.n](unit = "Pa", displayUnit = "Pa", min = 0.0) = (if 
    ahu.fanSu.eff.haveVMax and ahu.fanSu.eff.haveDPMax or ahu.fanSu.eff.nOri == 2
     then zeros(ahu.fanSu.eff.nOri+2) else (if ahu.fanSu.eff.haveVMax or 
    ahu.fanSu.eff.haveDPMax then zeros(ahu.fanSu.eff.nOri+2) else cat(1, {
    ahu.fanSu.eff.dpMax}, array(ahu.fanSu.eff.per.pressure.dp[i]+
    ahu.fanSu.eff.per.pressure.V_flow[i]*ahu.fanSu.eff.kRes for i in 1:
    ahu.fanSu.eff.nOri), {0}))) "Fan or pump total pressure at these flow rates";
  parameter Real ahu.fanSu.eff.preDer1[ahu.fanSu.eff.nOri](fixed = false) 
    "Derivatives of flow rate vs. pressure at the support points";
  parameter Real ahu.fanSu.eff.preDer2[ahu.fanSu.eff.nOri+1](fixed = false) 
    "Derivatives of flow rate vs. pressure at the support points";
  parameter Real ahu.fanSu.eff.preDer3[ahu.fanSu.eff.nOri+2](fixed = false) 
    "Derivatives of flow rate vs. pressure at the support points";
  parameter Real ahu.fanSu.eff.powDer[size(ahu.fanSu.eff.per.power.V_flow, 1)]
     = (if ahu.fanSu.eff.per.use_powerCharacteristic then Buildings.Utilities.Math.Functions.splineDerivatives
    (ahu.fanSu.eff.per.power.V_flow, ahu.fanSu.eff.per.power.P, Buildings.Utilities.Math.Functions.isMonotonic
    (ahu.fanSu.eff.per.power.P, false)) else zeros(size(ahu.fanSu.eff.per.power.V_flow,
     1))) "Coefficients for polynomial of power vs. flow rate";
  parameter Boolean ahu.fanSu.eff.haveMinimumDecrease = Modelica.Math.BooleanVectors.allTrue
    (array((ahu.fanSu.eff.per.pressure.dp[i+1]-ahu.fanSu.eff.per.pressure.dp[i])
    /(ahu.fanSu.eff.per.pressure.V_flow[i+1]-ahu.fanSu.eff.per.pressure.V_flow[i])
     <  -ahu.fanSu.eff.kRes for i in 1:ahu.fanSu.eff.nOri-1)) "Flag used for reporting";
  parameter Boolean ahu.fanSu.eff.haveDPMax = abs(ahu.fanSu.eff.per.pressure.V_flow
    [1]) < 1E-15 "Flag, true if user specified data that contain dpMax";
  parameter Real ahu.fanSu.gain.k(start = 1, unit = "1") = -1 "Gain value multiplied with input signal";
  constant Boolean ahu.senVolFloIn.allowFlowReversal = false "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.senVolFloIn.m_flow_nominal(unit = 
    "kg/s", min = 0.0) = ahu.m_flow_nominal "Nominal mass flow rate, used for regularization near zero flow";
  parameter Modelica.SIunits.MassFlowRate ahu.senVolFloIn.m_flow_small(unit = 
    "kg/s", min = 0.0) = 0.0001*ahu.senVolFloIn.m_flow_nominal "For bi-directional flow, temperature is regularized in the region |m_flow| < m_flow_small (m_flow_small > 0 required)";
  parameter Modelica.SIunits.Time ahu.senVolFloIn.tau(unit = "s", min = 0.0) = 0
     "Time constant at nominal flow rate (use tau=0 for steady-state sensor, but see user guide for potential problems)";
  parameter Modelica.Blocks.Types.Init ahu.senVolFloIn.initType = 
    Modelica.Blocks.Types.Init.InitialState "Type of initialization (InitialState and InitialOutput are identical)";
  parameter Boolean ahu.senVolFloIn.dynamic = ahu.senVolFloIn.tau > 1E-10 or 
    ahu.senVolFloIn.tau < -1E-10 "Flag, true if the sensor is a dynamic sensor";
  parameter Real ahu.senVolFloIn.tauInv(unit = "s-1") = (if ahu.senVolFloIn.dynamic
     then 1/ahu.senVolFloIn.tau else 0) "Inverse of tau";
  parameter Modelica.Media.Interfaces.Types.Density ahu.senVolFloIn.d_start(
    start = 1, nominal = 1.0, unit = "kg/m3", displayUnit = "g/cm3", min = 0.0, 
    max = 100000.0) = ahu.senVolFloIn.density_Unique37(
    ahu.senVolFloIn.setState_pTX_Unique34(ahu.senVolFloIn.p_start, 
      ahu.senVolFloIn.T_start, ahu.senVolFloIn.X_start)) "Initial or guess value of density";
  parameter Modelica.SIunits.Temperature ahu.senVolFloIn.T_start(start = 288.15,
     nominal = 300.0, unit = "K", displayUnit = "degC", min = 0.0) = 293.15 
    "Temperature used to compute d_start";
  parameter Modelica.SIunits.Pressure ahu.senVolFloIn.p_start(unit = "Pa", 
    displayUnit = "bar") = 101325 "Pressure used to compute d_start";
  parameter Modelica.SIunits.MassFraction ahu.senVolFloIn.X_start[2](unit = "1",
     min = 0.0, max = 1.0) = {0.01, 0.99} "Mass fraction used to compute d_start";
  constant Boolean ahu.senTemIn2.allowFlowReversal = false "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.senTemIn2.m_flow_nominal(unit = 
    "kg/s", min = 0.0) = ahu.m_flow_nominal "Nominal mass flow rate, used for regularization near zero flow";
  parameter Modelica.SIunits.MassFlowRate ahu.senTemIn2.m_flow_small(unit = 
    "kg/s", min = 0.0) = 0.0001*ahu.senTemIn2.m_flow_nominal "For bi-directional flow, temperature is regularized in the region |m_flow| < m_flow_small (m_flow_small > 0 required)";
  parameter Modelica.SIunits.Time ahu.senTemIn2.tau(unit = "s", min = 0.0) = 1 
    "Time constant at nominal flow rate (use tau=0 for steady-state sensor, but see user guide for potential problems)";
  parameter Modelica.Blocks.Types.Init ahu.senTemIn2.initType = Modelica.Blocks.Types.Init.
    InitialState "Type of initialization (InitialState and InitialOutput are identical)";
  parameter Boolean ahu.senTemIn2.dynamic = ahu.senTemIn2.tau > 1E-10 or 
    ahu.senTemIn2.tau < -1E-10 "Flag, true if the sensor is a dynamic sensor";
  parameter Real ahu.senTemIn2.tauInv(unit = "s-1") = (if ahu.senTemIn2.dynamic
     then 1/ahu.senTemIn2.tau else 0) "Inverse of tau";
  parameter Modelica.SIunits.Temperature ahu.senTemIn2.T_start(start = 288.15, 
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 0.0) = 293.15 
    "Initial or guess value of output (= state)";
  parameter Boolean ahu.senTemIn2.transferHeat = false "if true, temperature T converges towards TAmb when no flow";
  parameter Modelica.SIunits.Temperature ahu.senTemIn2.TAmb(start = 288.15, 
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 0.0) = 293.15 
    "Fixed ambient temperature for heat transfer";
  parameter Modelica.SIunits.Time ahu.senTemIn2.tauHeaTra(unit = "s", min = 1.0)
     = 1200 "Time constant for heat transfer, default 20 minutes";
  parameter Real ahu.senTemIn2.tauHeaTraInv(unit = "1/s") = (if ahu.senTemIn2.tauHeaTra
     < 1E-10 then 0 else 1/ahu.senTemIn2.tauHeaTra) "Dummy parameter to avoid division by tauHeaTra";
  parameter Real ahu.senTemIn2.ratTau = (if ahu.senTemIn2.dynamic then 
    ahu.senTemIn2.tauHeaTra/ahu.senTemIn2.tau else 1) "Ratio of tau";
  constant Boolean ahu.hex.allowFlowReversal1 = false "= false to simplify equations, assuming, but not enforcing, no flow reversal for medium 1";
  constant Boolean ahu.hex.allowFlowReversal2 = false "= false to simplify equations, assuming, but not enforcing, no flow reversal for medium 2";
  parameter Modelica.SIunits.MassFlowRate ahu.hex.m1_flow_nominal(unit = "kg/s",
     min = 0.0) = ahu.m_flow_nominal "Nominal mass flow rate";
  parameter Modelica.SIunits.MassFlowRate ahu.hex.m2_flow_nominal(unit = "kg/s",
     min = 0.0) = ahu.m_flow_nominal "Nominal mass flow rate";
  parameter Modelica.Media.Interfaces.PartialMedium.MassFlowRate 
    ahu.hex.m1_flow_small(unit = "kg/s", min = 0.0, max = 100000.0) = 0.0001*abs
    (ahu.hex.m1_flow_nominal) "Small mass flow rate for regularization of zero flow";
  parameter Modelica.Media.Interfaces.PartialMedium.MassFlowRate 
    ahu.hex.m2_flow_small(unit = "kg/s", min = 0.0, max = 100000.0) = 0.0001*abs
    (ahu.hex.m2_flow_nominal) "Small mass flow rate for regularization of zero flow";
  constant Boolean ahu.hex.show_T = false "= true, if actual temperature at port is computed";
  parameter Boolean ahu.hex.computeFlowResistance1 = ahu.hex.dp1_nominal > 1E-15
     "=true, compute flow resistance. Set to false to assume no friction";
  parameter Boolean ahu.hex.from_dp1 = false "= true, use m_flow = f(dp) else dp = f(m_flow)";
  constant Modelica.SIunits.PressureDifference ahu.hex.dp1_nominal(unit = "Pa", 
    displayUnit = "Pa", min = 0.0) = 150 "Pressure difference";
  parameter Boolean ahu.hex.linearizeFlowResistance1 = true "= true, use linear relation between m_flow and dp for any flow rate";
  parameter Real ahu.hex.deltaM1 = 0.1 "Fraction of nominal flow rate where flow transitions to laminar";
  parameter Boolean ahu.hex.computeFlowResistance2 = ahu.hex.dp2_nominal > 1E-15
     "=true, compute flow resistance. Set to false to assume no friction";
  parameter Boolean ahu.hex.from_dp2 = false "= true, use m_flow = f(dp) else dp = f(m_flow)";
  constant Modelica.SIunits.PressureDifference ahu.hex.dp2_nominal(unit = "Pa", 
    displayUnit = "Pa", min = 0.0) = 150 "Pressure difference";
  parameter Boolean ahu.hex.linearizeFlowResistance2 = true "= true, use linear relation between m_flow and dp for any flow rate";
  parameter Real ahu.hex.deltaM2 = 0.1 "Fraction of nominal flow rate where flow transitions to laminar";
  constant Boolean ahu.hex.prescribedHeatFlowRate1 = true "Set to true if the heat flow rate into fluid 1 is not a function of the component temperature";
  constant Boolean ahu.hex.prescribedHeatFlowRate2 = true "Set to true if the heat flow rate into fluid 2 is not a function of the component temperature";
  constant Boolean ahu.hex.homotopyInitialization = true "= true, use homotopy method";
  constant Boolean ahu.hex.sensibleOnly1 = true "Set to true if sensible exchange only for medium 1";
  constant Boolean ahu.hex.sensibleOnly2 = true "Set to true if sensible exchange only for medium 2";
  constant Boolean ahu.hex.bal1.allowFlowReversal = false "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.hex.bal1.m_flow_nominal(unit = 
    "kg/s") = ahu.hex.m1_flow_nominal "Nominal mass flow rate";
  parameter Modelica.SIunits.MassFlowRate ahu.hex.bal1.m_flow_small(unit = 
    "kg/s", min = 0.0) = ahu.hex.m1_flow_small "Small mass flow rate for regularization of zero flow";
  constant Boolean ahu.hex.bal1.show_T = false "= true, if actual temperature at port is computed";
  parameter Modelica.SIunits.MassFlowRate ahu.hex.bal1._m_flow_start(unit = 
    "kg/s") = 0 "Start value for m_flow, used to avoid a warning if not set in m_flow, and to avoid m_flow.start in parameter window";
  parameter Modelica.SIunits.PressureDifference ahu.hex.bal1._dp_start(unit = 
    "Pa", displayUnit = "Pa") = 0 "Start value for dp, used to avoid a warning if not set in dp, and to avoid dp.start in parameter window";
  parameter Boolean ahu.hex.bal1.computeFlowResistance = abs(ahu.hex.bal1.dp_nominal)
     > 1E-15 "=true, compute flow resistance. Set to false to assume no friction";
  parameter Boolean ahu.hex.bal1.from_dp = ahu.hex.from_dp1 "= true, use m_flow = f(dp) else dp = f(m_flow)";
  constant Modelica.SIunits.PressureDifference ahu.hex.bal1.dp_nominal(unit = 
    "Pa", displayUnit = "Pa", min = 0.0) = 150 "Pressure difference";
  parameter Boolean ahu.hex.bal1.linearizeFlowResistance = ahu.hex.linearizeFlowResistance1
     "= true, use linear relation between m_flow and dp for any flow rate";
  parameter Real ahu.hex.bal1.deltaM = ahu.hex.deltaM1 "Fraction of nominal flow rate where flow transitions to laminar";
  constant Boolean ahu.hex.bal1.sensibleOnly = true "Set to true if sensible exchange only";
  constant Boolean ahu.hex.bal1.prescribedHeatFlowRate = ahu.hex.prescribedHeatFlowRate1
     "Set to true if the heat flow rate is not a function of the component temperature";
  constant Boolean ahu.hex.bal1.homotopyInitialization = ahu.hex.homotopyInitialization
     "= true, use homotopy method";
  constant Boolean ahu.hex.bal1.vol.allowFlowReversal = false "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.hex.bal1.vol.m_flow_nominal(
    unit = "kg/s") = ahu.hex.bal1.m_flow_nominal "Nominal mass flow rate";
  parameter Modelica.SIunits.MassFlowRate ahu.hex.bal1.vol.m_flow_small(unit = 
    "kg/s", min = 0.0) = ahu.hex.bal1.m_flow_small "Small mass flow rate for regularization of zero flow";
  constant Boolean ahu.hex.bal1.vol.show_T = false "= true, if actual temperature at port is computed";
  parameter Modelica.SIunits.MassFlowRate ahu.hex.bal1.vol._m_flow_start(unit = 
    "kg/s") = 0 "Start value for m_flow, used to avoid a warning if not set in m_flow, and to avoid m_flow.start in parameter window";
  parameter Modelica.SIunits.PressureDifference ahu.hex.bal1.vol._dp_start(
    unit = "Pa", displayUnit = "Pa") = 0 "Start value for dp, used to avoid a warning if not set in dp, and to avoid dp.start in parameter window";
  constant Boolean ahu.hex.bal1.vol.simplify_mWat_flow = true "Set to true to cause port_a.m_flow + port_b.m_flow = 0 even if mWat_flow is non-zero";
  constant Boolean ahu.hex.bal1.vol.prescribedHeatFlowRate = ahu.hex.bal1.prescribedHeatFlowRate
     "Set to true if the heat flow rate is not a function of a temperature difference to the fluid temperature";
  constant Boolean ahu.hex.bal1.vol.use_mWat_flow = false "Set to true to enable input connector for moisture mass flow rate";
  constant Boolean ahu.hex.bal1.vol.use_C_flow = false "Set to true to enable input connector for trace substance";
  parameter Boolean ahu.hex.bal1.vol.use_m_flowInv = ahu.hex.bal1.vol.prescribedHeatFlowRate
     or ahu.hex.bal1.vol.use_mWat_flow or ahu.hex.bal1.vol.use_C_flow 
    "Flag, true if m_flowInv is used in the model";
  parameter Real ahu.hex.bal1.vol.s[1] = array((if Modelica.Utilities.Strings.isEqual
