      if (ahu.hex.bal2.vol.use_m_flowInv) then 
        ahu.hex.bal2.vol.port_a.Xi_outflow = inStream(ahu.hex.bal2.vol.port_b.Xi_outflow)
          -ahu.hex.bal2.vol.mXi_flow*ahu.hex.bal2.vol.m_flowInv;
      else
        assert(ahu.hex.bal2.vol.use_mWat_flow == false, "In RealOccupancy.ahu.hex.bal2.vol: Wrong implementation for reverse flow.");
        ahu.hex.bal2.vol.port_a.Xi_outflow = inStream(ahu.hex.bal2.vol.port_b.Xi_outflow);
      end if;
    else
      ahu.hex.bal2.vol.port_a.Xi_outflow = {0.01};
    end if;
    if (ahu.hex.bal2.vol.prescribedHeatFlowRate) then 
      ahu.hex.bal2.vol.port_b.h_outflow = inStream(ahu.hex.bal2.vol.port_a.h_outflow)
        +ahu.hex.bal2.vol.Q_flow*ahu.hex.bal2.vol.m_flowInv;
      if (ahu.hex.bal2.vol.allowFlowReversal) then 
        ahu.hex.bal2.vol.port_a.h_outflow = inStream(ahu.hex.bal2.vol.port_b.h_outflow)
          -ahu.hex.bal2.vol.Q_flow*ahu.hex.bal2.vol.m_flowInv;
      else
        ahu.hex.bal2.vol.port_a.h_outflow = 45300.945;
      end if;
    else
      ahu.hex.bal2.vol.port_a.m_flow*(inStream(ahu.hex.bal2.vol.port_a.h_outflow)
        -ahu.hex.bal2.vol.port_b.h_outflow) =  -ahu.hex.bal2.vol.Q_flow;
      if (ahu.hex.bal2.vol.allowFlowReversal) then 
        ahu.hex.bal2.vol.port_a.m_flow*(inStream(ahu.hex.bal2.vol.port_b.h_outflow)
          -ahu.hex.bal2.vol.port_a.h_outflow) = ahu.hex.bal2.vol.Q_flow;
      else
        ahu.hex.bal2.vol.port_a.h_outflow = 45300.945;
      end if;
    end if;
    if (ahu.hex.bal2.vol.use_m_flowInv and ahu.hex.bal2.vol.use_C_flow) then 
      ahu.hex.bal2.vol.port_b.C_outflow = inStream(ahu.hex.bal2.vol.port_a.C_outflow)
        +ahu.hex.bal2.vol.C_flow_internal*ahu.hex.bal2.vol.m_flowInv;
    else
      assert( not ahu.hex.bal2.vol.use_C_flow, "In RealOccupancy.ahu.hex.bal2.vol: Wrong implementation of trace substance balance for forward flow.");
      ahu.hex.bal2.vol.port_b.C_outflow = inStream(ahu.hex.bal2.vol.port_a.C_outflow);
    end if;
    if (ahu.hex.bal2.vol.allowFlowReversal) then 
      if (ahu.hex.bal2.vol.use_C_flow) then 
        ahu.hex.bal2.vol.port_a.C_outflow = inStream(ahu.hex.bal2.vol.port_b.C_outflow)
          -ahu.hex.bal2.vol.C_flow_internal*ahu.hex.bal2.vol.m_flowInv;
      else
        ahu.hex.bal2.vol.port_a.C_outflow = inStream(ahu.hex.bal2.vol.port_b.C_outflow);
      end if;
    else
      ahu.hex.bal2.vol.port_a.C_outflow = zeros(1);
    end if;
    ahu.hex.bal2.vol.port_a.p = ahu.hex.bal2.vol.port_b.p;

  // Component ahu.hex.bal2.preDro
  // class Buildings.Fluid.FixedResistances.PressureDrop
    // extends Buildings.Fluid.BaseClasses.PartialResistance
    equation
      ahu.hex.bal2.preDro.port_a.h_outflow = (if ahu.hex.bal2.preDro.allowFlowReversal
         then inStream(ahu.hex.bal2.preDro.port_b.h_outflow) else 45300.945);
      ahu.hex.bal2.preDro.port_b.h_outflow = inStream(ahu.hex.bal2.preDro.port_a.h_outflow);
      ahu.hex.bal2.preDro.port_a.m_flow+ahu.hex.bal2.preDro.port_b.m_flow = 0;
      ahu.hex.bal2.preDro.port_a.Xi_outflow = (if ahu.hex.bal2.preDro.allowFlowReversal
         then inStream(ahu.hex.bal2.preDro.port_b.Xi_outflow) else {0.01});
      ahu.hex.bal2.preDro.port_b.Xi_outflow = inStream(ahu.hex.bal2.preDro.port_a.Xi_outflow);
      ahu.hex.bal2.preDro.port_a.C_outflow = (if ahu.hex.bal2.preDro.allowFlowReversal
         then inStream(ahu.hex.bal2.preDro.port_b.C_outflow) else zeros(1));
      ahu.hex.bal2.preDro.port_b.C_outflow = inStream(ahu.hex.bal2.preDro.port_a.C_outflow);
    // end of extends 
  equation
    if (ahu.hex.bal2.preDro.computeFlowResistance) then 
      if (ahu.hex.bal2.preDro.linearized) then 
        if (ahu.hex.bal2.preDro.from_dp) then 
          ahu.hex.bal2.preDro.m_flow = ahu.hex.bal2.preDro.dp*ahu.hex.bal2.preDro.coeff;
        else
          ahu.hex.bal2.preDro.dp = ahu.hex.bal2.preDro.m_flow*ahu.hex.bal2.preDro.coeff;
        end if;
      else
        if (ahu.hex.bal2.preDro.homotopyInitialization) then 
          if (ahu.hex.bal2.preDro.from_dp) then 
            ahu.hex.bal2.preDro.m_flow = homotopy(Buildings.Fluid.BaseClasses.FlowModels.basicFlowFunction_dp
              (ahu.hex.bal2.preDro.dp, ahu.hex.bal2.preDro.k, ahu.hex.bal2.preDro.m_flow_turbulent),
               ahu.hex.bal2.preDro.m_flow_nominal_pos*ahu.hex.bal2.preDro.dp/
              ahu.hex.bal2.preDro.dp_nominal_pos);
          else
            ahu.hex.bal2.preDro.dp = homotopy(Buildings.Fluid.BaseClasses.FlowModels.basicFlowFunction_m_flow
              (ahu.hex.bal2.preDro.m_flow, ahu.hex.bal2.preDro.k, 
              ahu.hex.bal2.preDro.m_flow_turbulent), ahu.hex.bal2.preDro.dp_nominal_pos
              *ahu.hex.bal2.preDro.m_flow/ahu.hex.bal2.preDro.m_flow_nominal_pos);
          end if;
        else
          if (ahu.hex.bal2.preDro.from_dp) then 
            ahu.hex.bal2.preDro.m_flow = Buildings.Fluid.BaseClasses.FlowModels.basicFlowFunction_dp
              (ahu.hex.bal2.preDro.dp, ahu.hex.bal2.preDro.k, ahu.hex.bal2.preDro.m_flow_turbulent);
          else
            ahu.hex.bal2.preDro.dp = Buildings.Fluid.BaseClasses.FlowModels.basicFlowFunction_m_flow
              (ahu.hex.bal2.preDro.m_flow, ahu.hex.bal2.preDro.k, 
              ahu.hex.bal2.preDro.m_flow_turbulent);
          end if;
        end if;
      end if;
    else
      ahu.hex.bal2.preDro.dp = 0;
    end if;

  // Component ahu.hex.bal2
  // class Buildings.Fluid.Interfaces.StaticTwoPortHeatMassExchanger
  equation
    connect(ahu.hex.bal2.vol.hOut, ahu.hex.bal2.hOut);
    connect(ahu.hex.bal2.vol.XiOut, ahu.hex.bal2.XiOut);
    connect(ahu.hex.bal2.vol.COut, ahu.hex.bal2.COut);
    connect(ahu.hex.bal2.port_a, ahu.hex.bal2.preDro.port_a);
    connect(ahu.hex.bal2.preDro.port_b, ahu.hex.bal2.vol.port_a);
    connect(ahu.hex.bal2.vol.port_b, ahu.hex.bal2.port_b);
    connect(ahu.hex.bal2.heaInp.y, ahu.hex.bal2.vol.Q_flow);
    connect(ahu.hex.bal2.masExc.y, ahu.hex.bal2.vol.mWat_flow);

  // Component ahu.hex
  // class Buildings.Fluid.HeatExchangers.ConstantEffectiveness
    // extends Buildings.Fluid.Interfaces.StaticFourPortHeatMassExchanger
    equation
      connect(ahu.hex.bal1.port_a, ahu.hex.port_a1);
      connect(ahu.hex.bal1.port_b, ahu.hex.port_b1);
      connect(ahu.hex.bal2.port_a, ahu.hex.port_a2);
      connect(ahu.hex.bal2.port_b, ahu.hex.port_b2);
    // end of extends 

  // Component ahu.senTemEx1
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialFlowSensor
    equation
      ahu.senTemEx1.port_b.m_flow =  -ahu.senTemEx1.port_a.m_flow;
      ahu.senTemEx1.port_a.p = ahu.senTemEx1.port_b.p;
      ahu.senTemEx1.port_a.h_outflow = (if ahu.senTemEx1.allowFlowReversal then 
        inStream(ahu.senTemEx1.port_b.h_outflow) else 45300.945);
      ahu.senTemEx1.port_b.h_outflow = inStream(ahu.senTemEx1.port_a.h_outflow);
      ahu.senTemEx1.port_a.Xi_outflow = (if ahu.senTemEx1.allowFlowReversal
         then inStream(ahu.senTemEx1.port_b.Xi_outflow) else {0.01});
      ahu.senTemEx1.port_b.Xi_outflow = inStream(ahu.senTemEx1.port_a.Xi_outflow);
      ahu.senTemEx1.port_a.C_outflow = (if ahu.senTemEx1.allowFlowReversal then 
        inStream(ahu.senTemEx1.port_b.C_outflow) else zeros(1));
      ahu.senTemEx1.port_b.C_outflow = inStream(ahu.senTemEx1.port_a.C_outflow);
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialDynamicFlowSensor
    equation
      if (ahu.senTemEx1.dynamic) then 
        ahu.senTemEx1.mNor_flow = ahu.senTemEx1.port_a.m_flow/ahu.senTemEx1.m_flow_nominal;
        ahu.senTemEx1.k = Modelica.Fluid.Utilities.regStep(ahu.senTemEx1.port_a.m_flow,
           ahu.senTemEx1.mNor_flow,  -ahu.senTemEx1.mNor_flow, ahu.senTemEx1.m_flow_small);
      else
        ahu.senTemEx1.mNor_flow = 1;
        ahu.senTemEx1.k = 1;
      end if;
    // end of extends 
  equation
    if (ahu.senTemEx1.allowFlowReversal) then 
      ahu.senTemEx1.T_a_inflow = ahu.senTemEx1.temperature_Unique105(
        ahu.senTemEx1.setState_phX_Unique106(ahu.senTemEx1.port_b.p, 
          ahu.senTemEx1.port_b.h_outflow, ahu.senTemEx1.port_b.Xi_outflow));
      ahu.senTemEx1.T_b_inflow = ahu.senTemEx1.temperature_Unique105(
        ahu.senTemEx1.setState_phX_Unique106(ahu.senTemEx1.port_a.p, 
          ahu.senTemEx1.port_a.h_outflow, ahu.senTemEx1.port_a.Xi_outflow));
      ahu.senTemEx1.TMed = Modelica.Fluid.Utilities.regStep(ahu.senTemEx1.port_a.m_flow,
         ahu.senTemEx1.T_a_inflow, ahu.senTemEx1.T_b_inflow, ahu.senTemEx1.m_flow_small);
    else
      ahu.senTemEx1.TMed = ahu.senTemEx1.temperature_Unique105(
        ahu.senTemEx1.setState_phX_Unique106(ahu.senTemEx1.port_b.p, 
          ahu.senTemEx1.port_b.h_outflow, ahu.senTemEx1.port_b.Xi_outflow));
      ahu.senTemEx1.T_a_inflow = ahu.senTemEx1.TMed;
      ahu.senTemEx1.T_b_inflow = ahu.senTemEx1.TMed;
    end if;
    if (ahu.senTemEx1.dynamic) then 
      if (ahu.senTemEx1.transferHeat) then 
        der(ahu.senTemEx1.T) = (ahu.senTemEx1.TMed-ahu.senTemEx1.T)*
          ahu.senTemEx1.k*ahu.senTemEx1.tauInv+(ahu.senTemEx1.TAmb-
          ahu.senTemEx1.T)*ahu.senTemEx1.tauHeaTraInv/(ahu.senTemEx1.ratTau*
          ahu.senTemEx1.k+1);
      else
        der(ahu.senTemEx1.T) = (ahu.senTemEx1.TMed-ahu.senTemEx1.T)*
          ahu.senTemEx1.k*ahu.senTemEx1.tauInv;
      end if;
    else
      ahu.senTemEx1.T = ahu.senTemEx1.TMed;
    end if;

  // Component ahu.senVolFloEx
  // class Buildings.Fluid.Sensors.VolumeFlowRate
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialFlowSensor
    equation
      ahu.senVolFloEx.port_b.m_flow =  -ahu.senVolFloEx.port_a.m_flow;
      ahu.senVolFloEx.port_a.p = ahu.senVolFloEx.port_b.p;
      ahu.senVolFloEx.port_a.h_outflow = (if ahu.senVolFloEx.allowFlowReversal
         then inStream(ahu.senVolFloEx.port_b.h_outflow) else 45300.945);
      ahu.senVolFloEx.port_b.h_outflow = inStream(ahu.senVolFloEx.port_a.h_outflow);
      ahu.senVolFloEx.port_a.Xi_outflow = (if ahu.senVolFloEx.allowFlowReversal
         then inStream(ahu.senVolFloEx.port_b.Xi_outflow) else {0.01});
      ahu.senVolFloEx.port_b.Xi_outflow = inStream(ahu.senVolFloEx.port_a.Xi_outflow);
      ahu.senVolFloEx.port_a.C_outflow = (if ahu.senVolFloEx.allowFlowReversal
         then inStream(ahu.senVolFloEx.port_b.C_outflow) else zeros(1));
      ahu.senVolFloEx.port_b.C_outflow = inStream(ahu.senVolFloEx.port_a.C_outflow);
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialDynamicFlowSensor
    equation
      if (ahu.senVolFloEx.dynamic) then 
        ahu.senVolFloEx.mNor_flow = ahu.senVolFloEx.port_a.m_flow/
          ahu.senVolFloEx.m_flow_nominal;
        ahu.senVolFloEx.k = Modelica.Fluid.Utilities.regStep(ahu.senVolFloEx.port_a.m_flow,
           ahu.senVolFloEx.mNor_flow,  -ahu.senVolFloEx.mNor_flow, 
          ahu.senVolFloEx.m_flow_small);
      else
        ahu.senVolFloEx.mNor_flow = 1;
        ahu.senVolFloEx.k = 1;
      end if;
    // end of extends 
  equation
    if (ahu.senVolFloEx.allowFlowReversal) then 
      ahu.senVolFloEx.d_a_inflow = ahu.senVolFloEx.density_Unique112(
        ahu.senVolFloEx.setState_phX_Unique113(ahu.senVolFloEx.port_b.p, 
          ahu.senVolFloEx.port_b.h_outflow, ahu.senVolFloEx.port_b.Xi_outflow));
      ahu.senVolFloEx.d_b_inflow = ahu.senVolFloEx.density_Unique112(
        ahu.senVolFloEx.setState_phX_Unique113(ahu.senVolFloEx.port_a.p, 
          ahu.senVolFloEx.port_a.h_outflow, ahu.senVolFloEx.port_a.Xi_outflow));
      ahu.senVolFloEx.dMed = Modelica.Fluid.Utilities.regStep(ahu.senVolFloEx.port_a.m_flow,
         ahu.senVolFloEx.d_a_inflow, ahu.senVolFloEx.d_b_inflow, 
        ahu.senVolFloEx.m_flow_small);
    else
      ahu.senVolFloEx.dMed = ahu.senVolFloEx.density_Unique112(
        ahu.senVolFloEx.setState_phX_Unique113(ahu.senVolFloEx.port_b.p, 
          ahu.senVolFloEx.port_b.h_outflow, ahu.senVolFloEx.port_b.Xi_outflow));
      ahu.senVolFloEx.d_a_inflow = ahu.senVolFloEx.dMed;
      ahu.senVolFloEx.d_b_inflow = ahu.senVolFloEx.dMed;
    end if;
    if (ahu.senVolFloEx.dynamic) then 
      der(ahu.senVolFloEx.d) = (ahu.senVolFloEx.dMed-ahu.senVolFloEx.d)*
        ahu.senVolFloEx.k*ahu.senVolFloEx.tauInv;
    else
      ahu.senVolFloEx.d = ahu.senVolFloEx.dMed;
    end if;
    ahu.senVolFloEx.V_flow = ahu.senVolFloEx.port_a.m_flow/ahu.senVolFloEx.d;

  // Component ahu.senPreIn
  // class Buildings.Fluid.Sensors.Pressure
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialAbsoluteSensor
    equation
      ahu.senPreIn.port.m_flow = 0;
      ahu.senPreIn.port.h_outflow = 0;
      ahu.senPreIn.port.Xi_outflow = zeros(1);
      ahu.senPreIn.port.C_outflow = zeros(1);
    // end of extends 
  equation
    ahu.senPreIn.p = ahu.senPreIn.port.p;

  // Component ahu.senPreEx
  // class Buildings.Fluid.Sensors.Pressure
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialAbsoluteSensor
    equation
      ahu.senPreEx.port.m_flow = 0;
      ahu.senPreEx.port.h_outflow = 0;
      ahu.senPreEx.port.Xi_outflow = zeros(1);
      ahu.senPreEx.port.C_outflow = zeros(1);
    // end of extends 
  equation
    ahu.senPreEx.p = ahu.senPreEx.port.p;

  // Component ahu.fanEx.inputSwitch
  // class Modelica.Blocks.Routing.RealPassThrough
  equation
    ahu.fanEx.inputSwitch.y = ahu.fanEx.inputSwitch.u;

  // Component ahu.fanEx.vol.preTem
  // class Buildings.HeatTransfer.Sources.PrescribedTemperature
  equation
    ahu.fanEx.vol.preTem.port.T = ahu.fanEx.vol.preTem.T;

  // Component ahu.fanEx.vol.heaFloSen
  // class Modelica.Thermal.HeatTransfer.Sensors.HeatFlowSensor
  equation
    ahu.fanEx.vol.heaFloSen.port_a.T = ahu.fanEx.vol.heaFloSen.port_b.T;
    ahu.fanEx.vol.heaFloSen.port_a.Q_flow+ahu.fanEx.vol.heaFloSen.port_b.Q_flow
       = 0;
    ahu.fanEx.vol.heaFloSen.Q_flow = ahu.fanEx.vol.heaFloSen.port_a.Q_flow;

  // Component ahu.fanEx.vol
  // class Buildings.Fluid.Delays.DelayFirstOrder
    // extends Buildings.Fluid.MixingVolumes.BaseClasses.PartialMixingVolume
    equation
      if ( not ahu.fanEx.vol.allowFlowReversal) then 
        assert(ahu.fanEx.vol.ports[1].m_flow >  -ahu.fanEx.vol.m_flow_small, 
          "In RealOccupancy.ahu.fanEx.vol: Model has flow reversal,
  but the parameter allowFlowReversal is set to false.
  m_flow_small    = "
          +String(ahu.fanEx.vol.m_flow_small)+"
  ports[1].m_flow = "+String(
          ahu.fanEx.vol.ports[1].m_flow)+"
");
      end if;
      if (ahu.fanEx.vol.useSteadyStateTwoPort) then 
        connect(ahu.fanEx.vol.steBal.port_a, ahu.fanEx.vol.ports[1]);
        connect(ahu.fanEx.vol.steBal.port_b, ahu.fanEx.vol.ports[2]);
        ahu.fanEx.vol.U = 0;
        ahu.fanEx.vol.mXi = zeros(1);
        ahu.fanEx.vol.m = 0;
        ahu.fanEx.vol.mC = zeros(1);
        connect(ahu.fanEx.vol.hOut_internal, ahu.fanEx.vol.steBal.hOut);
        connect(ahu.fanEx.vol.XiOut_internal, ahu.fanEx.vol.steBal.XiOut);
        connect(ahu.fanEx.vol.COut_internal, ahu.fanEx.vol.steBal.COut);
      else
        connect(ahu.fanEx.vol.dynBal.ports, ahu.fanEx.vol.ports);
        connect(ahu.fanEx.vol.U, ahu.fanEx.vol.dynBal.UOut);
        connect(ahu.fanEx.vol.mXi, ahu.fanEx.vol.dynBal.mXiOut);
        connect(ahu.fanEx.vol.m, ahu.fanEx.vol.dynBal.mOut);
        connect(ahu.fanEx.vol.mC, ahu.fanEx.vol.dynBal.mCOut);
        connect(ahu.fanEx.vol.hOut_internal, ahu.fanEx.vol.dynBal.hOut);
        connect(ahu.fanEx.vol.XiOut_internal, ahu.fanEx.vol.dynBal.XiOut);
        connect(ahu.fanEx.vol.COut_internal, ahu.fanEx.vol.dynBal.COut);
      end if;
      connect(ahu.fanEx.vol.portT.y, ahu.fanEx.vol.preTem.T);
      connect(ahu.fanEx.vol.heaFloSen.port_b, ahu.fanEx.vol.preTem.port);
      connect(ahu.fanEx.vol.heaFloSen.Q_flow, ahu.fanEx.vol.steBal.Q_flow);
      connect(ahu.fanEx.vol.heaFloSen.Q_flow, ahu.fanEx.vol.dynBal.Q_flow);
    // extends Buildings.Fluid.MixingVolumes.MixingVolume
    equation
      connect(ahu.fanEx.vol.heaFloSen.port_a, ahu.fanEx.vol.heatPort);
      connect(ahu.fanEx.vol.C_flow, ahu.fanEx.vol.steBal.C_flow);
      connect(ahu.fanEx.vol.C_flow, ahu.fanEx.vol.dynBal.C_flow);
    // end of extends 

  // Component ahu.fanEx.filter
  // class Modelica.Blocks.Continuous.Filter
  equation
    assert(ahu.fanEx.filter.u_nominal > 0, "u_nominal > 0 required");
    assert(ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.
      LowPass or ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.
      HighPass or ahu.fanEx.filter.f_min > 0, "f_min > 0 required for band pass and band stop filter");
    assert(ahu.fanEx.filter.A_ripple > 0, "A_ripple > 0 required");
    assert(ahu.fanEx.filter.f_cut > 0, "f_cut > 0 required");
    ahu.fanEx.filter.uu[1] = ahu.fanEx.filter.u/ahu.fanEx.filter.u_nominal;
    for i in (1:ahu.fanEx.filter.nr) loop
      der(ahu.fanEx.filter.x[i]) = ahu.fanEx.filter.r[i]*(ahu.fanEx.filter.x[i]-
        ahu.fanEx.filter.uu[i]);
    end for;
    for i in (1:ahu.fanEx.filter.na) loop
      der(ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i-1]) = ahu.fanEx.filter.a[i]
        *ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i-1]-ahu.fanEx.filter.b[i]*
        ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i]+ahu.fanEx.filter.ku[i]*
        ahu.fanEx.filter.uu[ahu.fanEx.filter.nr+i];
      der(ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i]) = ahu.fanEx.filter.b[i]*
        ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i-1]+ahu.fanEx.filter.a[i]*
        ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i];
    end for;
    if (ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.LowPass)
       then 
      for i in (1:ahu.fanEx.filter.nr) loop
        ahu.fanEx.filter.uu[i+1] = ahu.fanEx.filter.x[i];
      end for;
      for i in (1:ahu.fanEx.filter.na) loop
        ahu.fanEx.filter.uu[ahu.fanEx.filter.nr+i+1] = ahu.fanEx.filter.x[
          ahu.fanEx.filter.nr+2*i];
      end for;
    elseif (ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.
      HighPass) then 
      for i in (1:ahu.fanEx.filter.nr) loop
        ahu.fanEx.filter.uu[i+1] = ( -ahu.fanEx.filter.x[i])+ahu.fanEx.filter.uu
          [i];
      end for;
      for i in (1:ahu.fanEx.filter.na) loop
        ahu.fanEx.filter.uu[ahu.fanEx.filter.nr+i+1] = ahu.fanEx.filter.k1[i]*
          ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i-1]+ahu.fanEx.filter.k2[i]*
          ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i]+ahu.fanEx.filter.uu[
          ahu.fanEx.filter.nr+i];
      end for;
    elseif (ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.
      BandPass) then 
      for i in (1:ahu.fanEx.filter.na) loop
        ahu.fanEx.filter.uu[ahu.fanEx.filter.nr+i+1] = ahu.fanEx.filter.k1[i]*
          ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i-1]+ahu.fanEx.filter.k2[i]*
          ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i];
      end for;
    elseif (ahu.fanEx.filter.filterType == Modelica.Blocks.Types.FilterType.
      BandStop) then 
      for i in (1:ahu.fanEx.filter.na) loop
        ahu.fanEx.filter.uu[ahu.fanEx.filter.nr+i+1] = ahu.fanEx.filter.k1[i]*
          ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i-1]+ahu.fanEx.filter.k2[i]*
          ahu.fanEx.filter.x[ahu.fanEx.filter.nr+2*i]+ahu.fanEx.filter.uu[
          ahu.fanEx.filter.nr+i];
      end for;
    else
      assert(false, "filterType (= "+String(ahu.fanEx.filter.filterType)+
        ") is unknown");
      ahu.fanEx.filter.uu = zeros(ahu.fanEx.filter.na+ahu.fanEx.filter.nr+1);
    end if;
    ahu.fanEx.filter.y = ahu.fanEx.filter.gain*ahu.fanEx.filter.u_nominal*
      ahu.fanEx.filter.uu[ahu.fanEx.filter.nr+ahu.fanEx.filter.na+1];

  // Component ahu.fanEx.gaiSpe
  // class Modelica.Blocks.Math.Gain
  equation
    ahu.fanEx.gaiSpe.y = ahu.fanEx.gaiSpe.k*ahu.fanEx.gaiSpe.u;

  // Component ahu.fanEx.preSou
  // class Buildings.Fluid.Movers.BaseClasses.IdealSource
    // extends Buildings.Fluid.Interfaces.PartialTwoPortTransport
    equation
      ahu.fanEx.preSou.dp = ahu.fanEx.preSou.port_a.p-ahu.fanEx.preSou.port_b.p;
      ahu.fanEx.preSou.m_flow = ahu.fanEx.preSou.port_a.m_flow;
      assert(ahu.fanEx.preSou.m_flow >  -ahu.fanEx.preSou.m_flow_small or 
        ahu.fanEx.preSou.allowFlowReversal, "Reverting flow occurs even though allowFlowReversal is false");
      ahu.fanEx.preSou.port_a.m_flow+ahu.fanEx.preSou.port_b.m_flow = 0;
      ahu.fanEx.preSou.port_a.Xi_outflow = (if ahu.fanEx.preSou.allowFlowReversal
         then inStream(ahu.fanEx.preSou.port_b.Xi_outflow) else {0.01});
      ahu.fanEx.preSou.port_b.Xi_outflow = inStream(ahu.fanEx.preSou.port_a.Xi_outflow);
      ahu.fanEx.preSou.port_a.C_outflow = (if ahu.fanEx.preSou.allowFlowReversal
         then inStream(ahu.fanEx.preSou.port_b.C_outflow) else zeros(1));
      ahu.fanEx.preSou.port_b.C_outflow = inStream(ahu.fanEx.preSou.port_a.C_outflow);
    // end of extends 
  equation
    if (ahu.fanEx.preSou.control_m_flow) then 
      ahu.fanEx.preSou.m_flow = ahu.fanEx.preSou.m_flow_internal;
    else
      ahu.fanEx.preSou.m_flow_internal = 0;
    end if;
    if (ahu.fanEx.preSou.control_dp) then 
      ahu.fanEx.preSou.dp = ahu.fanEx.preSou.dp_internal;
    else
      ahu.fanEx.preSou.dp_internal = 0;
    end if;
    connect(ahu.fanEx.preSou.dp_internal, ahu.fanEx.preSou.dp_in);
    connect(ahu.fanEx.preSou.m_flow_internal, ahu.fanEx.preSou.m_flow_in);
    ahu.fanEx.preSou.port_a.h_outflow = (if ahu.fanEx.preSou.allowFlowReversal
       then inStream(ahu.fanEx.preSou.port_b.h_outflow) else 45300.945);
    ahu.fanEx.preSou.port_b.h_outflow = inStream(ahu.fanEx.preSou.port_a.h_outflow);

  // Component ahu.fanEx.senMasFlo
  // class Buildings.Fluid.Sensors.MassFlowRate
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialFlowSensor
    equation
      ahu.fanEx.senMasFlo.port_b.m_flow =  -ahu.fanEx.senMasFlo.port_a.m_flow;
      ahu.fanEx.senMasFlo.port_a.p = ahu.fanEx.senMasFlo.port_b.p;
      ahu.fanEx.senMasFlo.port_a.h_outflow = (if ahu.fanEx.senMasFlo.allowFlowReversal
         then inStream(ahu.fanEx.senMasFlo.port_b.h_outflow) else 45300.945);
      ahu.fanEx.senMasFlo.port_b.h_outflow = inStream(ahu.fanEx.senMasFlo.port_a.h_outflow);
      ahu.fanEx.senMasFlo.port_a.Xi_outflow = (if ahu.fanEx.senMasFlo.allowFlowReversal
         then inStream(ahu.fanEx.senMasFlo.port_b.Xi_outflow) else {0.01});
      ahu.fanEx.senMasFlo.port_b.Xi_outflow = inStream(ahu.fanEx.senMasFlo.port_a.Xi_outflow);
      ahu.fanEx.senMasFlo.port_a.C_outflow = (if ahu.fanEx.senMasFlo.allowFlowReversal
         then inStream(ahu.fanEx.senMasFlo.port_b.C_outflow) else zeros(1));
      ahu.fanEx.senMasFlo.port_b.C_outflow = inStream(ahu.fanEx.senMasFlo.port_a.C_outflow);
    // end of extends 
  equation
    ahu.fanEx.senMasFlo.m_flow = ahu.fanEx.senMasFlo.port_a.m_flow;

  // Component ahu.fanEx.senRelPre
  // class Buildings.Fluid.Sensors.RelativePressure
  equation
    ahu.fanEx.senRelPre.port_a.m_flow = 0;
    ahu.fanEx.senRelPre.port_b.m_flow = 0;
    ahu.fanEx.senRelPre.port_a.h_outflow = 0;
    ahu.fanEx.senRelPre.port_b.h_outflow = 0;
    ahu.fanEx.senRelPre.port_a.Xi_outflow = zeros(1);
    ahu.fanEx.senRelPre.port_b.Xi_outflow = zeros(1);
    ahu.fanEx.senRelPre.port_a.C_outflow = zeros(1);
    ahu.fanEx.senRelPre.port_b.C_outflow = zeros(1);
    ahu.fanEx.senRelPre.p_rel = ahu.fanEx.senRelPre.port_a.p-ahu.fanEx.senRelPre.port_b.p;

  // Component ahu.fanEx.eff
  // class Buildings.Fluid.Movers.BaseClasses.FlowMachineInterface
  equation
    connect(ahu.fanEx.eff.dp_internal, ahu.fanEx.eff.dp);
    connect(ahu.fanEx.eff.dp_internal, ahu.fanEx.eff.dp_in);
    connect(ahu.fanEx.eff.r_N, ahu.fanEx.eff.y_in);
    ahu.fanEx.eff.y_out = ahu.fanEx.eff.r_N;
    ahu.fanEx.eff.V_flow = ahu.fanEx.eff.m_flow/ahu.fanEx.eff.rho;
    ahu.fanEx.eff.r_V = ahu.fanEx.eff.V_flow/ahu.fanEx.eff.V_flow_max;
    if (ahu.fanEx.eff.computePowerUsingSimilarityLaws == false and 
      ahu.fanEx.eff.preVar <> Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
      Speed) then 
      ahu.fanEx.eff.r_N = 1;
    else
      if (ahu.fanEx.eff.curve == 1) then 
        if (ahu.fanEx.eff.homotopyInitialization) then 
          ahu.fanEx.eff.V_flow*ahu.fanEx.eff.kRes+ahu.fanEx.eff.dp_internal = 
            homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanEx.eff.V_flow, 
            ahu.fanEx.eff.r_N, 
            ahu.fanEx.eff.preDer1, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur1), ahu.fanEx.eff.r_N*(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanEx.eff.V_flow_nominal, 
            1, 
            ahu.fanEx.eff.preDer1, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur1)+(ahu.fanEx.eff.V_flow-ahu.fanEx.eff.V_flow_nominal)
            *(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            (1+ahu.fanEx.eff.delta)*ahu.fanEx.eff.V_flow_nominal, 
            1, 
            ahu.fanEx.eff.preDer1, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur1)-Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            (1-ahu.fanEx.eff.delta)*ahu.fanEx.eff.V_flow_nominal, 
            1, 
            ahu.fanEx.eff.preDer1, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur1))/(2*ahu.fanEx.eff.delta*ahu.fanEx.eff.V_flow_nominal)));
        else
          ahu.fanEx.eff.V_flow*ahu.fanEx.eff.kRes+ahu.fanEx.eff.dp_internal = 
            Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            ahu.fanEx.eff.V_flow, 
            ahu.fanEx.eff.r_N, 
            ahu.fanEx.eff.preDer1, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur1);
        end if;
      elseif (ahu.fanEx.eff.curve == 2) then 
        if (ahu.fanEx.eff.homotopyInitialization) then 
          ahu.fanEx.eff.V_flow*ahu.fanEx.eff.kRes+ahu.fanEx.eff.dp_internal = 
            homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanEx.eff.V_flow, 
            ahu.fanEx.eff.r_N, 
            ahu.fanEx.eff.preDer2, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur2), ahu.fanEx.eff.r_N*(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanEx.eff.V_flow_nominal, 
            1, 
            ahu.fanEx.eff.preDer2, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur2)+(ahu.fanEx.eff.V_flow-ahu.fanEx.eff.V_flow_nominal)
            *(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            (1+ahu.fanEx.eff.delta)*ahu.fanEx.eff.V_flow_nominal, 
            1, 
            ahu.fanEx.eff.preDer2, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur2)-Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            (1-ahu.fanEx.eff.delta)*ahu.fanEx.eff.V_flow_nominal, 
            1, 
            ahu.fanEx.eff.preDer2, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur2))/(2*ahu.fanEx.eff.delta*ahu.fanEx.eff.V_flow_nominal)));
        else
          ahu.fanEx.eff.V_flow*ahu.fanEx.eff.kRes+ahu.fanEx.eff.dp_internal = 
            Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            ahu.fanEx.eff.V_flow, 
            ahu.fanEx.eff.r_N, 
            ahu.fanEx.eff.preDer2, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur2);
        end if;
      else
        if (ahu.fanEx.eff.homotopyInitialization) then 
          ahu.fanEx.eff.V_flow*ahu.fanEx.eff.kRes+ahu.fanEx.eff.dp_internal = 
            homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanEx.eff.V_flow, 
            ahu.fanEx.eff.r_N, 
            ahu.fanEx.eff.preDer3, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur3), ahu.fanEx.eff.r_N*(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            ahu.fanEx.eff.V_flow_nominal, 
            1, 
            ahu.fanEx.eff.preDer3, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur3)+(ahu.fanEx.eff.V_flow-ahu.fanEx.eff.V_flow_nominal)
            *(Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            (1+ahu.fanEx.eff.delta)*ahu.fanEx.eff.V_flow_nominal, 
            1, 
            ahu.fanEx.eff.preDer3, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur3)-Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure
            (
            (1-ahu.fanEx.eff.delta)*ahu.fanEx.eff.V_flow_nominal, 
            1, 
            ahu.fanEx.eff.preDer3, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur3))/(2*ahu.fanEx.eff.delta*ahu.fanEx.eff.V_flow_nominal)));
        else
          ahu.fanEx.eff.V_flow*ahu.fanEx.eff.kRes+ahu.fanEx.eff.dp_internal = 
            Buildings.Fluid.Movers.BaseClasses.Characteristics.pressure(
            ahu.fanEx.eff.V_flow, 
            ahu.fanEx.eff.r_N, 
            ahu.fanEx.eff.preDer3, 
            ahu.fanEx.eff.dpMax, 
            ahu.fanEx.eff.V_flow_max, 
            ahu.fanEx.eff.pCur3);
        end if;
      end if;
    end if;
    ahu.fanEx.eff.WFlo = ahu.fanEx.eff.dp_internal*ahu.fanEx.eff.V_flow;
    if (ahu.fanEx.eff.per.use_powerCharacteristic) then 
      if (ahu.fanEx.eff.homotopyInitialization) then 
        ahu.fanEx.eff.PEle = homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.power
          (
          ahu.fanEx.eff.per.power, 
          ahu.fanEx.eff.V_flow, 
          ahu.fanEx.eff.r_N, 
          ahu.fanEx.eff.powDer, 
          ahu.fanEx.eff.delta), ahu.fanEx.eff.V_flow/ahu.fanEx.eff.V_flow_nominal
          *Buildings.Fluid.Movers.BaseClasses.Characteristics.power(
          ahu.fanEx.eff.per.power, 
          ahu.fanEx.eff.V_flow_nominal, 
          1, 
          ahu.fanEx.eff.powDer, 
          ahu.fanEx.eff.delta));
      else
        ahu.fanEx.eff.PEle = ahu.fanEx.eff.rho/ahu.fanEx.eff.rho_default*
          Buildings.Fluid.Movers.BaseClasses.Characteristics.power(
          ahu.fanEx.eff.per.power, 
          ahu.fanEx.eff.V_flow, 
          ahu.fanEx.eff.r_N, 
          ahu.fanEx.eff.powDer, 
          ahu.fanEx.eff.delta);
      end if;
      ahu.fanEx.eff.eta = ahu.fanEx.eff.WFlo/Buildings.Utilities.Math.Functions.smoothMax
        (ahu.fanEx.eff.PEle, 1E-05, 1E-06);
      ahu.fanEx.eff.etaHyd = 1;
      ahu.fanEx.eff.etaMot = ahu.fanEx.eff.eta;
    else
      if (ahu.fanEx.eff.homotopyInitialization) then 
        ahu.fanEx.eff.etaHyd = homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanEx.eff.per.hydraulicEfficiency, 
          ahu.fanEx.eff.V_flow, 
          ahu.fanEx.eff.hydDer, 
          ahu.fanEx.eff.r_N, 
          ahu.fanEx.eff.delta), Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanEx.eff.per.hydraulicEfficiency, 
          ahu.fanEx.eff.V_flow_max, 
          ahu.fanEx.eff.hydDer, 
          ahu.fanEx.eff.r_N, 
          ahu.fanEx.eff.delta));
        ahu.fanEx.eff.etaMot = homotopy(Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanEx.eff.per.motorEfficiency, 
          ahu.fanEx.eff.V_flow, 
          ahu.fanEx.eff.motDer, 
          ahu.fanEx.eff.r_N, 
          ahu.fanEx.eff.delta), Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanEx.eff.per.motorEfficiency, 
          ahu.fanEx.eff.V_flow_max, 
          ahu.fanEx.eff.motDer, 
          ahu.fanEx.eff.r_N, 
          ahu.fanEx.eff.delta));
      else
        ahu.fanEx.eff.etaHyd = Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanEx.eff.per.hydraulicEfficiency, 
          ahu.fanEx.eff.V_flow, 
          ahu.fanEx.eff.hydDer, 
          ahu.fanEx.eff.r_N, 
          ahu.fanEx.eff.delta);
        ahu.fanEx.eff.etaMot = Buildings.Fluid.Movers.BaseClasses.Characteristics.efficiency
          (
          ahu.fanEx.eff.per.motorEfficiency, 
          ahu.fanEx.eff.V_flow, 
          ahu.fanEx.eff.motDer, 
          ahu.fanEx.eff.r_N, 
          ahu.fanEx.eff.delta);
      end if;
      ahu.fanEx.eff.PEle = ahu.fanEx.eff.WFlo/Buildings.Utilities.Math.Functions.smoothMax
        (ahu.fanEx.eff.eta, 1E-05, 1E-06);
      ahu.fanEx.eff.eta = ahu.fanEx.eff.etaHyd*ahu.fanEx.eff.etaMot;
    end if;

  // Component ahu.fanEx.gain
  // class Modelica.Blocks.Math.Gain
  equation
    ahu.fanEx.gain.y = ahu.fanEx.gain.k*ahu.fanEx.gain.u;

  // Component ahu.fanEx
  // class Buildings.Fluid.Movers.SpeedControlled_y
    // extends Buildings.Fluid.Movers.BaseClasses.PartialFlowMachine
    equation
      connect(ahu.fanEx.prePow.port, ahu.fanEx.vol.heatPort);
      connect(ahu.fanEx.vol.heatPort, ahu.fanEx.heatPort);
      connect(ahu.fanEx.preSou.port_b, ahu.fanEx.port_b);
      connect(ahu.fanEx.stageValues.y, ahu.fanEx.extractor.u);
      connect(ahu.fanEx.extractor.y, ahu.fanEx.inputSwitch.u);
      connect(ahu.fanEx.setConst.y, ahu.fanEx.inputSwitch.u);
      connect(ahu.fanEx.extractor.index, ahu.fanEx.stage);
      connect(ahu.fanEx.PToMed.y, ahu.fanEx.prePow.Q_flow);
      connect(ahu.fanEx.PToMed.u1, ahu.fanEx.heaDis.Q_flow);
      connect(ahu.fanEx.senRelPre.port_b, ahu.fanEx.preSou.port_a);
      connect(ahu.fanEx.senRelPre.port_a, ahu.fanEx.preSou.port_b);
      connect(ahu.fanEx.heaDis.etaHyd, ahu.fanEx.eff.etaHyd);
      connect(ahu.fanEx.heaDis.V_flow, ahu.fanEx.eff.V_flow);
      connect(ahu.fanEx.eff.PEle, ahu.fanEx.heaDis.PEle);
      connect(ahu.fanEx.eff.WFlo, ahu.fanEx.heaDis.WFlo);
      connect(ahu.fanEx.rho_inlet.y, ahu.fanEx.eff.rho);
      connect(ahu.fanEx.eff.m_flow, ahu.fanEx.senMasFlo.m_flow);
      connect(ahu.fanEx.eff.PEle, ahu.fanEx.P);
      connect(ahu.fanEx.eff.WFlo, ahu.fanEx.PToMed.u2);
      connect(ahu.fanEx.inputSwitch.y, ahu.fanEx.filter.u);
      connect(ahu.fanEx.senRelPre.p_rel, ahu.fanEx.eff.dp_in);
      connect(ahu.fanEx.eff.y_out, ahu.fanEx.y_actual);
      connect(ahu.fanEx.port_a, ahu.fanEx.vol.ports[1]);
      connect(ahu.fanEx.vol.ports[2], ahu.fanEx.senMasFlo.port_a);
      connect(ahu.fanEx.senMasFlo.port_b, ahu.fanEx.preSou.port_a);
    // end of extends 
  equation
    connect(ahu.fanEx.gaiSpe.u, ahu.fanEx.y);
    connect(ahu.fanEx.gaiSpe.y, ahu.fanEx.inputSwitch.u);
    connect(ahu.fanEx.eff.dp, ahu.fanEx.gain.u);
    connect(ahu.fanEx.gain.y, ahu.fanEx.preSou.dp_in);
    if (ahu.fanEx.use_inputFilter) then 
      connect(ahu.fanEx.filter.y, ahu.fanEx.eff.y_in);
    else
      connect(ahu.fanEx.inputSwitch.y, ahu.fanEx.eff.y_in);
    end if;

  // Component ahu.senTemEx2
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialFlowSensor
    equation
      ahu.senTemEx2.port_b.m_flow =  -ahu.senTemEx2.port_a.m_flow;
      ahu.senTemEx2.port_a.p = ahu.senTemEx2.port_b.p;
      ahu.senTemEx2.port_a.h_outflow = (if ahu.senTemEx2.allowFlowReversal then 
        inStream(ahu.senTemEx2.port_b.h_outflow) else 45300.945);
      ahu.senTemEx2.port_b.h_outflow = inStream(ahu.senTemEx2.port_a.h_outflow);
      ahu.senTemEx2.port_a.Xi_outflow = (if ahu.senTemEx2.allowFlowReversal
         then inStream(ahu.senTemEx2.port_b.Xi_outflow) else {0.01});
      ahu.senTemEx2.port_b.Xi_outflow = inStream(ahu.senTemEx2.port_a.Xi_outflow);
      ahu.senTemEx2.port_a.C_outflow = (if ahu.senTemEx2.allowFlowReversal then 
        inStream(ahu.senTemEx2.port_b.C_outflow) else zeros(1));
      ahu.senTemEx2.port_b.C_outflow = inStream(ahu.senTemEx2.port_a.C_outflow);
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialDynamicFlowSensor
    equation
      if (ahu.senTemEx2.dynamic) then 
        ahu.senTemEx2.mNor_flow = ahu.senTemEx2.port_a.m_flow/ahu.senTemEx2.m_flow_nominal;
        ahu.senTemEx2.k = Modelica.Fluid.Utilities.regStep(ahu.senTemEx2.port_a.m_flow,
           ahu.senTemEx2.mNor_flow,  -ahu.senTemEx2.mNor_flow, ahu.senTemEx2.m_flow_small);
      else
        ahu.senTemEx2.mNor_flow = 1;
        ahu.senTemEx2.k = 1;
      end if;
    // end of extends 
  equation
    if (ahu.senTemEx2.allowFlowReversal) then 
      ahu.senTemEx2.T_a_inflow = ahu.senTemEx2.temperature_Unique150(
        ahu.senTemEx2.setState_phX_Unique151(ahu.senTemEx2.port_b.p, 
          ahu.senTemEx2.port_b.h_outflow, ahu.senTemEx2.port_b.Xi_outflow));
      ahu.senTemEx2.T_b_inflow = ahu.senTemEx2.temperature_Unique150(
        ahu.senTemEx2.setState_phX_Unique151(ahu.senTemEx2.port_a.p, 
          ahu.senTemEx2.port_a.h_outflow, ahu.senTemEx2.port_a.Xi_outflow));
      ahu.senTemEx2.TMed = Modelica.Fluid.Utilities.regStep(ahu.senTemEx2.port_a.m_flow,
         ahu.senTemEx2.T_a_inflow, ahu.senTemEx2.T_b_inflow, ahu.senTemEx2.m_flow_small);
    else
      ahu.senTemEx2.TMed = ahu.senTemEx2.temperature_Unique150(
        ahu.senTemEx2.setState_phX_Unique151(ahu.senTemEx2.port_b.p, 
          ahu.senTemEx2.port_b.h_outflow, ahu.senTemEx2.port_b.Xi_outflow));
      ahu.senTemEx2.T_a_inflow = ahu.senTemEx2.TMed;
      ahu.senTemEx2.T_b_inflow = ahu.senTemEx2.TMed;
    end if;
    if (ahu.senTemEx2.dynamic) then 
      if (ahu.senTemEx2.transferHeat) then 
        der(ahu.senTemEx2.T) = (ahu.senTemEx2.TMed-ahu.senTemEx2.T)*
          ahu.senTemEx2.k*ahu.senTemEx2.tauInv+(ahu.senTemEx2.TAmb-
          ahu.senTemEx2.T)*ahu.senTemEx2.tauHeaTraInv/(ahu.senTemEx2.ratTau*
          ahu.senTemEx2.k+1);
      else
        der(ahu.senTemEx2.T) = (ahu.senTemEx2.TMed-ahu.senTemEx2.T)*
          ahu.senTemEx2.k*ahu.senTemEx2.tauInv;
      end if;
    else
      ahu.senTemEx2.T = ahu.senTemEx2.TMed;
    end if;

  // Component ahu.senTemIn1
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialFlowSensor
    equation
      ahu.senTemIn1.port_b.m_flow =  -ahu.senTemIn1.port_a.m_flow;
      ahu.senTemIn1.port_a.p = ahu.senTemIn1.port_b.p;
      ahu.senTemIn1.port_a.h_outflow = (if ahu.senTemIn1.allowFlowReversal then 
        inStream(ahu.senTemIn1.port_b.h_outflow) else 45300.945);
      ahu.senTemIn1.port_b.h_outflow = inStream(ahu.senTemIn1.port_a.h_outflow);
      ahu.senTemIn1.port_a.Xi_outflow = (if ahu.senTemIn1.allowFlowReversal
         then inStream(ahu.senTemIn1.port_b.Xi_outflow) else {0.01});
      ahu.senTemIn1.port_b.Xi_outflow = inStream(ahu.senTemIn1.port_a.Xi_outflow);
      ahu.senTemIn1.port_a.C_outflow = (if ahu.senTemIn1.allowFlowReversal then 
        inStream(ahu.senTemIn1.port_b.C_outflow) else zeros(1));
      ahu.senTemIn1.port_b.C_outflow = inStream(ahu.senTemIn1.port_a.C_outflow);
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialDynamicFlowSensor
    equation
      if (ahu.senTemIn1.dynamic) then 
        ahu.senTemIn1.mNor_flow = ahu.senTemIn1.port_a.m_flow/ahu.senTemIn1.m_flow_nominal;
        ahu.senTemIn1.k = Modelica.Fluid.Utilities.regStep(ahu.senTemIn1.port_a.m_flow,
           ahu.senTemIn1.mNor_flow,  -ahu.senTemIn1.mNor_flow, ahu.senTemIn1.m_flow_small);
      else
        ahu.senTemIn1.mNor_flow = 1;
        ahu.senTemIn1.k = 1;
      end if;
    // end of extends 
  equation
    if (ahu.senTemIn1.allowFlowReversal) then 
      ahu.senTemIn1.T_a_inflow = ahu.senTemIn1.temperature_Unique157(
        ahu.senTemIn1.setState_phX_Unique158(ahu.senTemIn1.port_b.p, 
          ahu.senTemIn1.port_b.h_outflow, ahu.senTemIn1.port_b.Xi_outflow));
      ahu.senTemIn1.T_b_inflow = ahu.senTemIn1.temperature_Unique157(
        ahu.senTemIn1.setState_phX_Unique158(ahu.senTemIn1.port_a.p, 
          ahu.senTemIn1.port_a.h_outflow, ahu.senTemIn1.port_a.Xi_outflow));
      ahu.senTemIn1.TMed = Modelica.Fluid.Utilities.regStep(ahu.senTemIn1.port_a.m_flow,
         ahu.senTemIn1.T_a_inflow, ahu.senTemIn1.T_b_inflow, ahu.senTemIn1.m_flow_small);
    else
      ahu.senTemIn1.TMed = ahu.senTemIn1.temperature_Unique157(
        ahu.senTemIn1.setState_phX_Unique158(ahu.senTemIn1.port_b.p, 
          ahu.senTemIn1.port_b.h_outflow, ahu.senTemIn1.port_b.Xi_outflow));
      ahu.senTemIn1.T_a_inflow = ahu.senTemIn1.TMed;
      ahu.senTemIn1.T_b_inflow = ahu.senTemIn1.TMed;
    end if;
    if (ahu.senTemIn1.dynamic) then 
      if (ahu.senTemIn1.transferHeat) then 
        der(ahu.senTemIn1.T) = (ahu.senTemIn1.TMed-ahu.senTemIn1.T)*
          ahu.senTemIn1.k*ahu.senTemIn1.tauInv+(ahu.senTemIn1.TAmb-
          ahu.senTemIn1.T)*ahu.senTemIn1.tauHeaTraInv/(ahu.senTemIn1.ratTau*
          ahu.senTemIn1.k+1);
      else
        der(ahu.senTemIn1.T) = (ahu.senTemIn1.TMed-ahu.senTemIn1.T)*
          ahu.senTemIn1.k*ahu.senTemIn1.tauInv;
      end if;
    else
      ahu.senTemIn1.T = ahu.senTemIn1.TMed;
    end if;

  // Component ahu.senTemIn3
  // class Buildings.Fluid.Sensors.TemperatureTwoPort
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialFlowSensor
    equation
      ahu.senTemIn3.port_b.m_flow =  -ahu.senTemIn3.port_a.m_flow;
      ahu.senTemIn3.port_a.p = ahu.senTemIn3.port_b.p;
      ahu.senTemIn3.port_a.h_outflow = (if ahu.senTemIn3.allowFlowReversal then 
        inStream(ahu.senTemIn3.port_b.h_outflow) else 45300.945);
      ahu.senTemIn3.port_b.h_outflow = inStream(ahu.senTemIn3.port_a.h_outflow);
      ahu.senTemIn3.port_a.Xi_outflow = (if ahu.senTemIn3.allowFlowReversal
         then inStream(ahu.senTemIn3.port_b.Xi_outflow) else {0.01});
      ahu.senTemIn3.port_b.Xi_outflow = inStream(ahu.senTemIn3.port_a.Xi_outflow);
      ahu.senTemIn3.port_a.C_outflow = (if ahu.senTemIn3.allowFlowReversal then 
        inStream(ahu.senTemIn3.port_b.C_outflow) else zeros(1));
      ahu.senTemIn3.port_b.C_outflow = inStream(ahu.senTemIn3.port_a.C_outflow);
    // extends Buildings.Fluid.Sensors.BaseClasses.PartialDynamicFlowSensor
    equation
      if (ahu.senTemIn3.dynamic) then 
        ahu.senTemIn3.mNor_flow = ahu.senTemIn3.port_a.m_flow/ahu.senTemIn3.m_flow_nominal;
        ahu.senTemIn3.k = Modelica.Fluid.Utilities.regStep(ahu.senTemIn3.port_a.m_flow,
           ahu.senTemIn3.mNor_flow,  -ahu.senTemIn3.mNor_flow, ahu.senTemIn3.m_flow_small);
      else
        ahu.senTemIn3.mNor_flow = 1;
        ahu.senTemIn3.k = 1;
      end if;
    // end of extends 
  equation
    if (ahu.senTemIn3.allowFlowReversal) then 
      ahu.senTemIn3.T_a_inflow = ahu.senTemIn3.temperature_Unique164(
        ahu.senTemIn3.setState_phX_Unique165(ahu.senTemIn3.port_b.p, 
          ahu.senTemIn3.port_b.h_outflow, ahu.senTemIn3.port_b.Xi_outflow));
      ahu.senTemIn3.T_b_inflow = ahu.senTemIn3.temperature_Unique164(
        ahu.senTemIn3.setState_phX_Unique165(ahu.senTemIn3.port_a.p, 
          ahu.senTemIn3.port_a.h_outflow, ahu.senTemIn3.port_a.Xi_outflow));
      ahu.senTemIn3.TMed = Modelica.Fluid.Utilities.regStep(ahu.senTemIn3.port_a.m_flow,
         ahu.senTemIn3.T_a_inflow, ahu.senTemIn3.T_b_inflow, ahu.senTemIn3.m_flow_small);
    else
      ahu.senTemIn3.TMed = ahu.senTemIn3.temperature_Unique164(
        ahu.senTemIn3.setState_phX_Unique165(ahu.senTemIn3.port_b.p, 
          ahu.senTemIn3.port_b.h_outflow, ahu.senTemIn3.port_b.Xi_outflow));
      ahu.senTemIn3.T_a_inflow = ahu.senTemIn3.TMed;
      ahu.senTemIn3.T_b_inflow = ahu.senTemIn3.TMed;
    end if;
    if (ahu.senTemIn3.dynamic) then 
      if (ahu.senTemIn3.transferHeat) then 
        der(ahu.senTemIn3.T) = (ahu.senTemIn3.TMed-ahu.senTemIn3.T)*
          ahu.senTemIn3.k*ahu.senTemIn3.tauInv+(ahu.senTemIn3.TAmb-
          ahu.senTemIn3.T)*ahu.senTemIn3.tauHeaTraInv/(ahu.senTemIn3.ratTau*
          ahu.senTemIn3.k+1);
      else
        der(ahu.senTemIn3.T) = (ahu.senTemIn3.TMed-ahu.senTemIn3.T)*
          ahu.senTemIn3.k*ahu.senTemIn3.tauInv;
      end if;
    else
      ahu.senTemIn3.T = ahu.senTemIn3.TMed;
    end if;

  // Component ahu.add
  // class Modelica.Blocks.Math.Add
  equation
    ahu.add.y = ahu.add.k1*ahu.add.u1+ahu.add.k2*ahu.add.u2;

