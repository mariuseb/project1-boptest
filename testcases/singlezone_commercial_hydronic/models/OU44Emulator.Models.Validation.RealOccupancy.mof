    "Set to false to suppress warning about potential numerical issues, see Buildings.Fluid.Sensors.UsersGuide for more information";
  parameter String ahu.senPreIn.instanceName = "RealOccupancy.ahu.senPreIn" 
    "Name of the instance";
  parameter Boolean ahu.senPreEx.warnAboutOnePortConnection = false 
    "Set to false to suppress warning about potential numerical issues, see Buildings.Fluid.Sensors.UsersGuide for more information";
  parameter String ahu.senPreEx.instanceName = "RealOccupancy.ahu.senPreEx" 
    "Name of the instance";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanEx.energyDynamics = 
    Modelica.Fluid.Types.Dynamics.SteadyState "Type of energy balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanEx.massDynamics = 
    Modelica.Fluid.Types.Dynamics.SteadyState "Type of mass balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanEx.substanceDynamics = 
    ahu.fanEx.energyDynamics "Type of independent mass fraction balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanEx.traceDynamics = 
    ahu.fanEx.energyDynamics "Type of trace substance balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanEx.p_start(
    start = 101325, nominal = 100000.0, unit = "Pa", displayUnit = "bar", min = 
    0.0, max = 100000000.0) = 101325 "Start value of pressure";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanEx.T_start(
    start = 293.15, nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0,
     max = 10000.0) = 293.15 "Start value of temperature";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanEx.X_start[2](
    nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = {0.01, 0.99} 
    "Start value of mass fractions m_i/m";
  parameter Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanEx.C_start[1](
    start = fill(1.0, size(ahu.fanEx.C_start, 1)), min = 0.0) = fill(0, 1) 
    "Start value of trace substances";
  parameter Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanEx.C_nominal[1]
    (start = fill(1.0, size(ahu.fanEx.C_nominal, 1)), min = 0.0) = fill(0.01, 1)
     "Nominal value of trace substances. (Set to typical order of magnitude.)";
  parameter Real ahu.fanEx.mSenFac(min = 1.0) = 1 "Factor for scaling the sensible thermal mass of the volume";
  constant Boolean ahu.fanEx.allowFlowReversal = true "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.fanEx.m_flow_nominal(unit = "kg/s",
     min = 1E-60) = max(ahu.fanEx.per.pressure.V_flow)*ahu.fanEx.rho_default 
    "Nominal mass flow rate";
  parameter Modelica.SIunits.MassFlowRate ahu.fanEx.m_flow_small(unit = "kg/s", 
    min = 0.0) = 0.0001*abs(ahu.fanEx.m_flow_nominal) "Small mass flow rate for regularization of zero flow";
  constant Boolean ahu.fanEx.show_T = false "= true, if actual temperature at port is computed";
  parameter Modelica.SIunits.MassFlowRate ahu.fanEx._m_flow_start(unit = "kg/s")
     = 0 "Start value for m_flow, used to avoid a warning if not set in m_flow, and to avoid m_flow.start in parameter window";
  parameter Modelica.SIunits.PressureDifference ahu.fanEx._dp_start(unit = "Pa",
     displayUnit = "Pa") = 0 "Start value for dp, used to avoid a warning if not set in dp, and to avoid dp.start in parameter window";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.per.pressure.V_flow[:](
    unit = "m3/s", min = 0.0) = {16, 25, 35} "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanEx.per.pressure.dp[size(
    ahu.fanEx.per.pressure.V_flow, 1)](unit = "Pa", displayUnit = "Pa", min = 
    0.0) = {800, 680, 100} "Fan or pump total pressure at these flow rates";
  parameter Boolean ahu.fanEx.per.use_powerCharacteristic = true 
    "Use power data instead of motor efficiency";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.per.hydraulicEfficiency.V_flow
    [:](unit = "m3/s", min = 0.0) = {0} "Volumetric flow rate at user-selected operating points";
  parameter Modelica.SIunits.Efficiency ahu.fanEx.per.hydraulicEfficiency.eta[
    size(ahu.fanEx.per.hydraulicEfficiency.V_flow, 1)](unit = "1", min = 0.0, 
    max = 1.0) = {0.7} "Fan or pump efficiency at these flow rates";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.per.motorEfficiency.V_flow
    [:](unit = "m3/s", min = 0.0) = {0} "Volumetric flow rate at user-selected operating points";
  parameter Modelica.SIunits.Efficiency ahu.fanEx.per.motorEfficiency.eta[size(
    ahu.fanEx.per.motorEfficiency.V_flow, 1)](unit = "1", min = 0.0, max = 1.0)
     = {0.7} "Fan or pump efficiency at these flow rates";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.per.power.V_flow[:](
    unit = "m3/s", min = 0.0) = {16, 25, 35} "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.Power ahu.fanEx.per.power.P[size(ahu.fanEx.per.power.V_flow,
     1)](unit = "W", min = 0.0) = {18000, 25000, 30000} "Fan or pump electrical power at these flow rates";
  parameter Boolean ahu.fanEx.per.motorCooledByFluid = true "If true, then motor heat is added to fluid stream";
  parameter Real ahu.fanEx.per.speed_nominal(unit = "1", min = 0.0) = 1 
    "Nominal rotational speed for flow characteristic";
  parameter Real ahu.fanEx.per.constantSpeed(unit = "1", min = 0.0) = 
    ahu.fanEx.per.constantSpeed_rpm/ahu.fanEx.per.speed_rpm_nominal 
    "Normalized speed set point, used if inputType = Buildings.Fluid.Types.InputType.Constant";
  parameter Real ahu.fanEx.per.speeds[:](unit = "1", min = 0.0) = 
    ahu.fanEx.per.speeds_rpm/ahu.fanEx.per.speed_rpm_nominal "Vector of normalized speed set points, used if inputType = Buildings.Fluid.Types.InputType.Stages";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanEx.per.speed_rpm_nominal(unit = "rev/min") = 600 "Nominal rotational speed for flow characteristic";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanEx.per.constantSpeed_rpm(unit = "rev/min") = ahu.fanEx.per.speed_rpm_nominal
     "Speed set point, used if inputType = Buildings.Fluid.Types.InputType.Constant";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanEx.per.speeds_rpm[:](unit = "rev/min") = {ahu.fanEx.per.speed_rpm_nominal}
     "Vector of speed set points, used if inputType = Buildings.Fluid.Types.InputType.Stages";
  parameter Boolean ahu.fanEx.per.havePressureCurve = sum(ahu.fanEx.per.pressure.V_flow)
     > 1E-15 and sum(ahu.fanEx.per.pressure.dp) > 1E-15 "= true, if default record values are being used";
  constant Buildings.Fluid.Types.InputType ahu.fanEx.inputType = 
    Buildings.Fluid.Types.InputType.Continuous "Control input type";
  parameter Real ahu.fanEx.constInput(unit = "1") = ahu.fanEx.per.constantSpeed 
    "Constant input set point";
  parameter Real ahu.fanEx.stageInputs[:](unit = "1") = ahu.fanEx.per.speeds 
    "Vector of input set points corresponding to stages";
  parameter Boolean ahu.fanEx.computePowerUsingSimilarityLaws = true 
    "= true, compute power exactly, using similarity laws. Otherwise approximate.";
  constant Boolean ahu.fanEx.addPowerToMedium = false "Set to false to avoid any power (=heat and flow work) being added to medium (may give simpler equations)";
  parameter Boolean ahu.fanEx.nominalValuesDefineDefaultPressureCurve = false 
    "Set to true to avoid warning if m_flow_nominal and dp_nominal are used to construct the default pressure curve";
  parameter Modelica.SIunits.Time ahu.fanEx.tau(unit = "s") = 1 "Time constant of fluid volume for nominal flow, used if energy or mass balance is dynamic";
  constant Boolean ahu.fanEx.use_inputFilter = true "= true, if speed is filtered with a 2nd order CriticalDamping filter";
  parameter Modelica.SIunits.Time ahu.fanEx.riseTime(unit = "s") = 30 
    "Rise time of the filter (time to reach 99.6 % of the speed)";
  parameter Modelica.Blocks.Types.Init ahu.fanEx.init = Modelica.Blocks.Types.Init.
    InitialOutput "Type of initialization (no init/steady state/initial state/initial output)";
  parameter Real ahu.fanEx.y_start(unit = "1", min = 0.0, max = 1.0) = 0 
    "Initial value of speed";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx._VMachine_flow(unit = 
    "m3/s") = 0 "Start value for VMachine_flow, used to avoid a warning if not specified";
  constant Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable 
    ahu.fanEx.preVar = Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
    Speed "Type of prescribed variable";
  constant Boolean ahu.fanEx.speedIsInput = true "Parameter that is true if speed is the controlled variables";
  parameter Integer ahu.fanEx.nOri = size(ahu.fanEx.per.pressure.V_flow, 1) 
    "Number of data points for pressure curve";
  parameter Boolean ahu.fanEx.haveVMax = abs(ahu.fanEx.per.pressure.dp[
    ahu.fanEx.nOri]) < 1E-15 "Flag, true if user specified data that contain V_flow_max";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.V_flow_max(unit = "m3/s")
     = (if ahu.fanEx.per.havePressureCurve then (if ahu.fanEx.haveVMax then 
    ahu.fanEx.per.pressure.V_flow[ahu.fanEx.nOri] else ahu.fanEx.per.pressure.V_flow
    [ahu.fanEx.nOri]-(ahu.fanEx.per.pressure.V_flow[ahu.fanEx.nOri]-
    ahu.fanEx.per.pressure.V_flow[ahu.fanEx.nOri-1])/(ahu.fanEx.per.pressure.dp[
    ahu.fanEx.nOri]-ahu.fanEx.per.pressure.dp[ahu.fanEx.nOri-1])*
    ahu.fanEx.per.pressure.dp[ahu.fanEx.nOri]) else ahu.fanEx.m_flow_nominal/
    ahu.fanEx.rho_default) "Maximum volume flow rate, used for smoothing";
  parameter Modelica.SIunits.Density ahu.fanEx.rho_default(unit = "kg/m3", 
    displayUnit = "g/cm3", min = 0.0) = ahu.fanEx.density_pTX_Unique119(101325, 
    293.15, {0.01, 0.99}) "Default medium density";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanEx.sta_start.p
    (nominal = 100000.0, unit = "Pa", displayUnit = "bar", min = 0.0, max = 
    100000000.0) = 101325 "Absolute pressure of medium";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanEx.sta_start.T(
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0, max = 10000.0)
     = 293.15 "Temperature of medium";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanEx.sta_start.X[2]
    (nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = {0.01, 0.99} 
    "Mass fractions (= (component mass)/total mass  m_i/m)";
  parameter Modelica.SIunits.SpecificEnthalpy ahu.fanEx.h_outflow_start(unit = 
    "J/kg") = ahu.fanEx.specificEnthalpy_Unique123(
    ahu.fanEx.sta_start) "Start value for outflowing enthalpy";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanEx.vol.energyDynamics = 
    ahu.fanEx.energyDynamics "Type of energy balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanEx.vol.massDynamics = 
    ahu.fanEx.massDynamics "Type of mass balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanEx.vol.substanceDynamics = 
    ahu.fanEx.vol.energyDynamics "Type of independent mass fraction balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Fluid.Types.Dynamics ahu.fanEx.vol.traceDynamics = 
    ahu.fanEx.vol.energyDynamics "Type of trace substance balance: dynamic (3 initialization options) or steady state";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanEx.vol.p_start
    (start = 101325, nominal = 100000.0, unit = "Pa", displayUnit = "bar", 
    min = 0.0, max = 100000000.0) = ahu.fanEx.p_start "Start value of pressure";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanEx.vol.T_start(
    start = 293.15, nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0,
     max = 10000.0) = ahu.fanEx.T_start "Start value of temperature";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanEx.vol.X_start[2]
    (nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = ahu.fanEx.X_start 
    "Start value of mass fractions m_i/m";
  parameter Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanEx.vol.C_start[1]
    (start = fill(1.0, size(ahu.fanEx.vol.C_start, 1)), min = 0.0) = 
    ahu.fanEx.C_start "Start value of trace substances";
  constant Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanEx.vol.C_nominal
    [1](min = 0.0) = {0.01} "Nominal value of trace substances. (Set to typical order of magnitude.)";
  parameter Real ahu.fanEx.vol.mSenFac(min = 1.0) = 1 "Factor for scaling the sensible thermal mass of the volume";
  parameter Boolean ahu.fanEx.vol.initialize_p = true "= true to set up initial equations for pressure";
  constant Boolean ahu.fanEx.vol.prescribedHeatFlowRate = true "Set to true if the model has a prescribed heat flow at its heatPort. If the heat flow rate at the heatPort is only based on temperature difference, then set to false";
  constant Boolean ahu.fanEx.vol.simplify_mWat_flow = true "Set to true to cause port_a.m_flow + port_b.m_flow = 0 even if mWat_flow is non-zero";
  parameter Modelica.SIunits.MassFlowRate ahu.fanEx.vol.m_flow_nominal(unit = 
    "kg/s", min = 0.0) = ahu.fanEx.m_flow_nominal "Nominal mass flow rate";
  constant Integer ahu.fanEx.vol.nPorts = 2 "Number of ports";
  parameter Modelica.SIunits.MassFlowRate ahu.fanEx.vol.m_flow_small(unit = 
    "kg/s", min = 0.0) = ahu.fanEx.m_flow_small "Small mass flow rate for regularization of zero flow";
  parameter Boolean ahu.fanEx.vol.allowFlowReversal = ahu.fanEx.allowFlowReversal
     "= false to simplify equations, assuming, but not enforcing, no flow reversal. Used only if model has two ports.";
  parameter Modelica.SIunits.Volume ahu.fanEx.vol.V(unit = "m3") = 
    ahu.fanEx.vol.V_nominal "Volume";
  parameter Modelica.SIunits.Density ahu.fanEx.vol.rho_start(unit = "kg/m3", 
    displayUnit = "g/cm3", min = 0.0) = ahu.fanEx.vol.density_Unique129(
    ahu.fanEx.vol.state_start) "Density, used to compute start and guess values";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanEx.vol.state_default.p
    (nominal = 100000.0, unit = "Pa", displayUnit = "bar", min = 0.0, max = 
    100000000.0) = 101325 "Absolute pressure of medium";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanEx.vol.state_default.T
    (nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0, max = 10000.0)
     = 293.15 "Temperature of medium";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanEx.vol.state_default.X
    [2](nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = {0.01, 0.99} 
    "Mass fractions (= (component mass)/total mass  m_i/m)";
  parameter Modelica.SIunits.Density ahu.fanEx.vol.rho_default(unit = "kg/m3", 
    displayUnit = "g/cm3", min = 0.0) = ahu.fanEx.vol.density_Unique129(
    ahu.fanEx.vol.state_default) "Density, used to compute fluid mass";
  parameter Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanEx.vol.state_start.p
    (nominal = 100000.0, unit = "Pa", displayUnit = "bar", min = 0.0, max = 
    100000000.0) = 101325 "Absolute pressure of medium";
  parameter Modelica.Media.Interfaces.Types.Temperature ahu.fanEx.vol.state_start.T
    (nominal = 300.0, unit = "K", displayUnit = "degC", min = 1.0, max = 10000.0)
     = 293.15 "Temperature of medium";
  parameter Modelica.Media.Interfaces.Types.MassFraction ahu.fanEx.vol.state_start.X
    [2](nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) = {0.01, 0.99} 
    "Mass fractions (= (component mass)/total mass  m_i/m)";
  parameter Boolean ahu.fanEx.vol.useSteadyStateTwoPort = ahu.fanEx.vol.nPorts
     == 2 and (ahu.fanEx.vol.prescribedHeatFlowRate or  not ahu.fanEx.vol.allowFlowReversal)
     and ahu.fanEx.vol.energyDynamics == Modelica.Fluid.Types.Dynamics.
    SteadyState and ahu.fanEx.vol.massDynamics == Modelica.Fluid.Types.Dynamics.
    SteadyState and ahu.fanEx.vol.substanceDynamics == Modelica.Fluid.Types.Dynamics.
    SteadyState and ahu.fanEx.vol.traceDynamics == Modelica.Fluid.Types.Dynamics.
    SteadyState "Flag, true if the model has two ports only and uses a steady state balance";
  constant Boolean ahu.fanEx.vol.use_C_flow = false "Set to true to enable input connector for trace substance";
  parameter Modelica.SIunits.Time ahu.fanEx.vol.tau(unit = "s") = ahu.fanEx.tau 
    "Time constant at nominal flow";
  parameter Modelica.SIunits.Volume ahu.fanEx.vol.V_nominal(unit = "m3") = 
    ahu.fanEx.vol.m_flow_nominal*ahu.fanEx.vol.tau/ahu.fanEx.vol.rho_default 
    "Volume of delay element";
  parameter Modelica.Blocks.Types.AnalogFilter ahu.fanEx.filter.analogFilter = 
    Modelica.Blocks.Types.AnalogFilter.CriticalDamping "Analog filter characteristics (CriticalDamping/Bessel/Butterworth/ChebyshevI)";
  parameter Modelica.Blocks.Types.FilterType ahu.fanEx.filter.filterType = 
    Modelica.Blocks.Types.FilterType.LowPass "Type of filter (LowPass/HighPass/BandPass/BandStop)";
  parameter Integer ahu.fanEx.filter.order(min = 1.0) = 2 "Order of filter";
  parameter Modelica.SIunits.Frequency ahu.fanEx.filter.f_cut(unit = "Hz") = 5/(
    6.283185307179586*ahu.fanEx.riseTime) "Cut-off frequency";
  parameter Real ahu.fanEx.filter.gain = 1.0 "Gain (= amplitude of frequency response at zero frequency)";
  parameter Real ahu.fanEx.filter.A_ripple(unit = "dB") = 0.5 "Pass band ripple for Chebyshev filter (otherwise not used); > 0 required";
  parameter Modelica.SIunits.Frequency ahu.fanEx.filter.f_min(unit = "Hz") = 0 
    "Band of band pass/stop filter is f_min (A=-3db*gain) .. f_cut (A=-3db*gain)";
  parameter Boolean ahu.fanEx.filter.normalized = true "= true, if amplitude at f_cut = -3db, otherwise unmodified filter";
  parameter Modelica.Blocks.Types.Init ahu.fanEx.filter.init = ahu.fanEx.init 
    "Type of initialization (no init/steady state/initial state/initial output)";
  parameter Integer ahu.fanEx.filter.nx = (if ahu.fanEx.filter.filterType == 
    Modelica.Blocks.Types.FilterType.LowPass or ahu.fanEx.filter.filterType == 
    Modelica.Blocks.Types.FilterType.HighPass then ahu.fanEx.filter.order else 2
    *ahu.fanEx.filter.order);
  parameter Real ahu.fanEx.filter.x_start[ahu.fanEx.filter.nx] = zeros(
    ahu.fanEx.filter.nx) "Initial or guess values of states";
  parameter Real ahu.fanEx.filter.y_start = ahu.fanEx.y_start "Initial value of output";
  parameter Real ahu.fanEx.filter.u_nominal = 1 "Nominal value of input (used for scaling the states)";
  parameter Integer ahu.fanEx.filter.ncr = (if ahu.fanEx.filter.analogFilter == 
    Modelica.Blocks.Types.AnalogFilter.CriticalDamping then ahu.fanEx.filter.order
     else mod(ahu.fanEx.filter.order, 2));
  parameter Integer ahu.fanEx.filter.nc0 = (if ahu.fanEx.filter.analogFilter == 
    Modelica.Blocks.Types.AnalogFilter.CriticalDamping then 0 else integer(
    ahu.fanEx.filter.order/2));
  parameter Integer ahu.fanEx.filter.na = (if ahu.fanEx.filter.filterType == 
    Modelica.Blocks.Types.FilterType.BandPass or ahu.fanEx.filter.filterType == 
    Modelica.Blocks.Types.FilterType.BandStop then ahu.fanEx.filter.order else (
    if ahu.fanEx.filter.analogFilter == Modelica.Blocks.Types.AnalogFilter.
    CriticalDamping then 0 else integer(ahu.fanEx.filter.order/2)));
  parameter Integer ahu.fanEx.filter.nr = (if ahu.fanEx.filter.filterType == 
    Modelica.Blocks.Types.FilterType.BandPass or ahu.fanEx.filter.filterType == 
    Modelica.Blocks.Types.FilterType.BandStop then 0 else (if ahu.fanEx.filter.analogFilter
     == Modelica.Blocks.Types.AnalogFilter.CriticalDamping then ahu.fanEx.filter.order
     else mod(ahu.fanEx.filter.order, 2)));
  parameter Real ahu.fanEx.filter.cr[ahu.fanEx.filter.ncr](fixed = false);
  parameter Real ahu.fanEx.filter.c0[ahu.fanEx.filter.nc0](fixed = false);
  parameter Real ahu.fanEx.filter.c1[ahu.fanEx.filter.nc0](fixed = false);
  parameter Real ahu.fanEx.filter.r[ahu.fanEx.filter.nr](fixed = false);
  parameter Real ahu.fanEx.filter.a[ahu.fanEx.filter.na](fixed = false);
  parameter Real ahu.fanEx.filter.b[ahu.fanEx.filter.na](fixed = false);
  parameter Real ahu.fanEx.filter.ku[ahu.fanEx.filter.na](fixed = false);
  parameter Real ahu.fanEx.filter.k1[(if ahu.fanEx.filter.filterType == 
    Modelica.Blocks.Types.FilterType.LowPass then 0 else ahu.fanEx.filter.na)](
    fixed = false);
  parameter Real ahu.fanEx.filter.k2[(if ahu.fanEx.filter.filterType == 
    Modelica.Blocks.Types.FilterType.LowPass then 0 else ahu.fanEx.filter.na)](
    fixed = false);
  parameter Real ahu.fanEx.gaiSpe.k(start = 1, unit = "1") = 1/ahu.fanEx.per.speed_nominal
     "Gain value multiplied with input signal";
  constant Boolean ahu.fanEx.preSou.allowFlowReversal = true "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.PressureDifference ahu.fanEx.preSou.dp_start(
    unit = "Pa", displayUnit = "Pa") = 0 "Guess value of dp = port_a.p - port_b.p";
  parameter Modelica.Media.Interfaces.PartialMedium.MassFlowRate 
    ahu.fanEx.preSou.m_flow_start(unit = "kg/s", min = -100000.0, max = 100000.0)
     = 0 "Guess value of m_flow = port_a.m_flow";
  parameter Modelica.Media.Interfaces.PartialMedium.MassFlowRate 
    ahu.fanEx.preSou.m_flow_small(unit = "kg/s", min = -100000.0, max = 100000.0)
     = ahu.fanEx.m_flow_small "Small mass flow rate for regularization of zero flow";
  constant Boolean ahu.fanEx.preSou.show_T = false "= true, if temperatures at port_a and port_b are computed";
  constant Boolean ahu.fanEx.preSou.show_V_flow = true "= true, if volume flow rate at inflowing port is computed";
  constant Boolean ahu.fanEx.preSou.control_m_flow = false "if true, then the mass flow rate is equal to the value of m_flow_in";
  constant Boolean ahu.fanEx.preSou.control_dp = true "if true, then the head is equal to the value of dp_in";
  constant Boolean ahu.fanEx.senMasFlo.allowFlowReversal = true "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.fanEx.senMasFlo.m_flow_nominal(
    unit = "kg/s", min = 0.0) = 0 "Nominal mass flow rate, used for regularization near zero flow";
  parameter Modelica.SIunits.MassFlowRate ahu.fanEx.senMasFlo.m_flow_small(
    unit = "kg/s", min = 0.0) = 0 "For bi-directional flow, temperature is regularized in the region |m_flow| < m_flow_small (m_flow_small > 0 required)";
  constant Boolean ahu.fanEx.eff.homotopyInitialization = true "= true, use homotopy method";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.eff.per.pressure.V_flow[:]
    (unit = "m3/s", min = 0.0) "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanEx.eff.per.pressure.dp[
    size(ahu.fanEx.eff.per.pressure.V_flow, 1)](unit = "Pa", displayUnit = "Pa",
     min = 0.0) "Fan or pump total pressure at these flow rates";
  parameter Boolean ahu.fanEx.eff.per.use_powerCharacteristic = ahu.fanEx.per.use_powerCharacteristic
     "Use power data instead of motor efficiency";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.eff.per.hydraulicEfficiency.V_flow
    [:](unit = "m3/s", min = 0.0) "Volumetric flow rate at user-selected operating points";
  parameter Modelica.SIunits.Efficiency ahu.fanEx.eff.per.hydraulicEfficiency.eta
    [size(ahu.fanEx.eff.per.hydraulicEfficiency.V_flow, 1)](unit = "1", min = 
    0.0, max = 1.0) "Fan or pump efficiency at these flow rates";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.eff.per.motorEfficiency.V_flow
    [:](unit = "m3/s", min = 0.0) "Volumetric flow rate at user-selected operating points";
  parameter Modelica.SIunits.Efficiency ahu.fanEx.eff.per.motorEfficiency.eta[
    size(ahu.fanEx.eff.per.motorEfficiency.V_flow, 1)](unit = "1", min = 0.0, 
    max = 1.0) "Fan or pump efficiency at these flow rates";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.eff.per.power.V_flow[:](
    unit = "m3/s", min = 0.0) "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.Power ahu.fanEx.eff.per.power.P[size(
    ahu.fanEx.eff.per.power.V_flow, 1)](unit = "W", min = 0.0) "Fan or pump electrical power at these flow rates";
  parameter Boolean ahu.fanEx.eff.per.motorCooledByFluid = ahu.fanEx.per.motorCooledByFluid
     "If true, then motor heat is added to fluid stream";
  parameter Real ahu.fanEx.eff.per.speed_nominal(unit = "1", min = 0.0) = 0 
    "Nominal rotational speed for flow characteristic";
  parameter Real ahu.fanEx.eff.per.constantSpeed(unit = "1", min = 0.0) = 0 
    "Normalized speed set point, used if inputType = Buildings.Fluid.Types.InputType.Constant";
  parameter Real ahu.fanEx.eff.per.speeds[:](unit = "1", min = 0.0) = {0} 
    "Vector of normalized speed set points, used if inputType = Buildings.Fluid.Types.InputType.Stages";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanEx.eff.per.speed_rpm_nominal(unit = "rev/min") = 1500 
    "Nominal rotational speed for flow characteristic";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanEx.eff.per.constantSpeed_rpm(unit = "rev/min") = ahu.fanEx.eff.per.speed_rpm_nominal
     "Speed set point, used if inputType = Buildings.Fluid.Types.InputType.Constant";
  parameter Modelica.SIunits.Conversions.NonSIunits.AngularVelocity_rpm 
    ahu.fanEx.eff.per.speeds_rpm[:](unit = "rev/min") = {ahu.fanEx.eff.per.speed_rpm_nominal}
     "Vector of speed set points, used if inputType = Buildings.Fluid.Types.InputType.Stages";
  parameter Boolean ahu.fanEx.eff.per.havePressureCurve = sum(ahu.fanEx.eff.per.pressure.V_flow)
     > 1E-15 and sum(ahu.fanEx.eff.per.pressure.dp) > 1E-15 "= true, if default record values are being used";
  parameter Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable 
    ahu.fanEx.eff.preVar = ahu.fanEx.preVar "Type of prescribed variable";
  parameter Boolean ahu.fanEx.eff.computePowerUsingSimilarityLaws = 
    ahu.fanEx.computePowerUsingSimilarityLaws "= true, compute power exactly, using similarity laws. Otherwise approximate.";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.eff.V_flow_nominal(unit = 
    "m3/s") = ahu.fanEx.eff.per.pressure.V_flow[ahu.fanEx.eff.nOri] 
    "Nominal volume flow rate, used for homotopy";
  parameter Modelica.SIunits.Density ahu.fanEx.eff.rho_default(unit = "kg/m3", 
    displayUnit = "g/cm3", min = 0.0) = ahu.fanEx.rho_default "Fluid density at medium default state";
  parameter Boolean ahu.fanEx.eff.haveVMax = ahu.fanEx.haveVMax "Flag, true if user specified data that contain V_flow_max";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.eff.V_flow_max(unit = 
    "m3/s") = ahu.fanEx.V_flow_max "Maximum volume flow rate, used for smoothing";
  parameter Integer ahu.fanEx.eff.nOri(min = 1.0) = ahu.fanEx.nOri 
    "Number of data points for pressure curve";
  parameter Boolean ahu.fanEx.eff.preSpe = ahu.fanEx.eff.preVar == 
    Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.Speed 
    "True if speed is a prescribed variable of this block";
  parameter Boolean ahu.fanEx.eff.prePre = ahu.fanEx.eff.preVar == 
    Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.PressureDifference
     or ahu.fanEx.eff.preVar == Buildings.Fluid.Movers.BaseClasses.Types.PrescribedVariable.
    FlowRate "True if pressure head is a prescribed variable of this block";
  parameter Real ahu.fanEx.eff.motDer[size(ahu.fanEx.eff.per.motorEfficiency.V_flow,
     1)](fixed = false) "Coefficients for polynomial of motor efficiency vs. volume flow rate";
  parameter Real ahu.fanEx.eff.hydDer[size(ahu.fanEx.eff.per.hydraulicEfficiency.V_flow,
     1)](fixed = false) "Coefficients for polynomial of hydraulic efficiency vs. volume flow rate";
  parameter Modelica.SIunits.PressureDifference ahu.fanEx.eff.dpMax(unit = "Pa",
     displayUnit = "Pa") = (if ahu.fanEx.eff.haveDPMax then ahu.fanEx.eff.per.pressure.dp
    [1] else ahu.fanEx.eff.per.pressure.dp[1]-(ahu.fanEx.eff.per.pressure.dp[2]-
    ahu.fanEx.eff.per.pressure.dp[1])/(ahu.fanEx.eff.per.pressure.V_flow[2]-
    ahu.fanEx.eff.per.pressure.V_flow[1])*ahu.fanEx.eff.per.pressure.V_flow[1]) 
    "Maximum head";
  parameter Real ahu.fanEx.eff.delta = 0.05 "Small value used to for regularization and to approximate an internal flow resistance of the fan";
  parameter Real ahu.fanEx.eff.kRes(unit = "kg/(s.m4)", min = 0.0) = 
    ahu.fanEx.eff.dpMax/ahu.fanEx.eff.V_flow_max*ahu.fanEx.eff.delta^2/10 
    "Coefficient for internal pressure drop of fan or pump";
  parameter Integer ahu.fanEx.eff.curve = (if ahu.fanEx.eff.haveVMax and 
    ahu.fanEx.eff.haveDPMax or ahu.fanEx.eff.nOri == 2 then 1 else (if 
    ahu.fanEx.eff.haveVMax or ahu.fanEx.eff.haveDPMax then 2 else 3)) 
    "Flag, used to pick the right representatio of the fan or pump pressure curve";
  parameter Integer ahu.fanEx.eff.pCur1.n = ahu.fanEx.eff.nOri "Number of elements in each array";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.eff.pCur1.V_flow[
    ahu.fanEx.eff.pCur1.n](unit = "m3/s", min = 0.0) = (if ahu.fanEx.eff.haveVMax
     and ahu.fanEx.eff.haveDPMax or ahu.fanEx.eff.nOri == 2 then (array(
    ahu.fanEx.eff.per.pressure.V_flow[i] for i in 1:ahu.fanEx.eff.nOri)) else 
    zeros(ahu.fanEx.eff.nOri)) "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanEx.eff.pCur1.dp[
    ahu.fanEx.eff.pCur1.n](unit = "Pa", displayUnit = "Pa", min = 0.0) = (if 
    ahu.fanEx.eff.haveVMax and ahu.fanEx.eff.haveDPMax or ahu.fanEx.eff.nOri == 2
     then (array(ahu.fanEx.eff.per.pressure.dp[i]+ahu.fanEx.eff.per.pressure.V_flow
    [i]*ahu.fanEx.eff.kRes for i in 1:ahu.fanEx.eff.nOri)) else zeros(
    ahu.fanEx.eff.nOri)) "Fan or pump total pressure at these flow rates";
  parameter Integer ahu.fanEx.eff.pCur2.n = ahu.fanEx.eff.nOri+1 
    "Number of elements in each array";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.eff.pCur2.V_flow[
    ahu.fanEx.eff.pCur2.n](unit = "m3/s", min = 0.0) = (if ahu.fanEx.eff.haveVMax
     and ahu.fanEx.eff.haveDPMax or ahu.fanEx.eff.nOri == 2 then zeros(
    ahu.fanEx.eff.nOri+1) else (if ahu.fanEx.eff.haveVMax then cat(1, {0}, array
    (ahu.fanEx.eff.per.pressure.V_flow[i] for i in 1:ahu.fanEx.eff.nOri)) else (
    if ahu.fanEx.eff.haveDPMax then cat(1, array(ahu.fanEx.eff.per.pressure.V_flow
    [i] for i in 1:ahu.fanEx.eff.nOri), {ahu.fanEx.eff.V_flow_max}) else zeros(
    ahu.fanEx.eff.nOri+1)))) "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanEx.eff.pCur2.dp[
    ahu.fanEx.eff.pCur2.n](unit = "Pa", displayUnit = "Pa", min = 0.0) = (if 
    ahu.fanEx.eff.haveVMax and ahu.fanEx.eff.haveDPMax or ahu.fanEx.eff.nOri == 2
     then zeros(ahu.fanEx.eff.nOri+1) else (if ahu.fanEx.eff.haveVMax then cat(1,
     {ahu.fanEx.eff.dpMax}, array(ahu.fanEx.eff.per.pressure.dp[i]+
    ahu.fanEx.eff.per.pressure.V_flow[i]*ahu.fanEx.eff.kRes for i in 1:
    ahu.fanEx.eff.nOri)) else (if ahu.fanEx.eff.haveDPMax then cat(1, array(
    ahu.fanEx.eff.per.pressure.dp[i]+ahu.fanEx.eff.per.pressure.V_flow[i]*
    ahu.fanEx.eff.kRes for i in 1:ahu.fanEx.eff.nOri), {0}) else zeros(
    ahu.fanEx.eff.nOri+1)))) "Fan or pump total pressure at these flow rates";
  parameter Integer ahu.fanEx.eff.pCur3.n = ahu.fanEx.eff.nOri+2 
    "Number of elements in each array";
  parameter Modelica.SIunits.VolumeFlowRate ahu.fanEx.eff.pCur3.V_flow[
    ahu.fanEx.eff.pCur3.n](unit = "m3/s", min = 0.0) = (if ahu.fanEx.eff.haveVMax
     and ahu.fanEx.eff.haveDPMax or ahu.fanEx.eff.nOri == 2 then zeros(
    ahu.fanEx.eff.nOri+2) else (if ahu.fanEx.eff.haveVMax or ahu.fanEx.eff.haveDPMax
     then zeros(ahu.fanEx.eff.nOri+2) else cat(1, {0}, array(ahu.fanEx.eff.per.pressure.V_flow
    [i] for i in 1:ahu.fanEx.eff.nOri), {ahu.fanEx.eff.V_flow_max}))) 
    "Volume flow rate at user-selected operating points";
  parameter Modelica.SIunits.PressureDifference ahu.fanEx.eff.pCur3.dp[
    ahu.fanEx.eff.pCur3.n](unit = "Pa", displayUnit = "Pa", min = 0.0) = (if 
    ahu.fanEx.eff.haveVMax and ahu.fanEx.eff.haveDPMax or ahu.fanEx.eff.nOri == 2
     then zeros(ahu.fanEx.eff.nOri+2) else (if ahu.fanEx.eff.haveVMax or 
    ahu.fanEx.eff.haveDPMax then zeros(ahu.fanEx.eff.nOri+2) else cat(1, {
    ahu.fanEx.eff.dpMax}, array(ahu.fanEx.eff.per.pressure.dp[i]+
    ahu.fanEx.eff.per.pressure.V_flow[i]*ahu.fanEx.eff.kRes for i in 1:
    ahu.fanEx.eff.nOri), {0}))) "Fan or pump total pressure at these flow rates";
  parameter Real ahu.fanEx.eff.preDer1[ahu.fanEx.eff.nOri](fixed = false) 
    "Derivatives of flow rate vs. pressure at the support points";
  parameter Real ahu.fanEx.eff.preDer2[ahu.fanEx.eff.nOri+1](fixed = false) 
    "Derivatives of flow rate vs. pressure at the support points";
  parameter Real ahu.fanEx.eff.preDer3[ahu.fanEx.eff.nOri+2](fixed = false) 
    "Derivatives of flow rate vs. pressure at the support points";
  parameter Real ahu.fanEx.eff.powDer[size(ahu.fanEx.eff.per.power.V_flow, 1)]
     = (if ahu.fanEx.eff.per.use_powerCharacteristic then Buildings.Utilities.Math.Functions.splineDerivatives
    (ahu.fanEx.eff.per.power.V_flow, ahu.fanEx.eff.per.power.P, Buildings.Utilities.Math.Functions.isMonotonic
    (ahu.fanEx.eff.per.power.P, false)) else zeros(size(ahu.fanEx.eff.per.power.V_flow,
     1))) "Coefficients for polynomial of power vs. flow rate";
  parameter Boolean ahu.fanEx.eff.haveMinimumDecrease = Modelica.Math.BooleanVectors.allTrue
    (array((ahu.fanEx.eff.per.pressure.dp[i+1]-ahu.fanEx.eff.per.pressure.dp[i])
    /(ahu.fanEx.eff.per.pressure.V_flow[i+1]-ahu.fanEx.eff.per.pressure.V_flow[i])
     <  -ahu.fanEx.eff.kRes for i in 1:ahu.fanEx.eff.nOri-1)) "Flag used for reporting";
  parameter Boolean ahu.fanEx.eff.haveDPMax = abs(ahu.fanEx.eff.per.pressure.V_flow
    [1]) < 1E-15 "Flag, true if user specified data that contain dpMax";
  parameter Real ahu.fanEx.gain.k(start = 1, unit = "1") = -1 "Gain value multiplied with input signal";
  constant Boolean ahu.senTemEx2.allowFlowReversal = false "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.senTemEx2.m_flow_nominal(unit = 
    "kg/s", min = 0.0) = ahu.m_flow_nominal "Nominal mass flow rate, used for regularization near zero flow";
  parameter Modelica.SIunits.MassFlowRate ahu.senTemEx2.m_flow_small(unit = 
    "kg/s", min = 0.0) = 0.0001*ahu.senTemEx2.m_flow_nominal "For bi-directional flow, temperature is regularized in the region |m_flow| < m_flow_small (m_flow_small > 0 required)";
  parameter Modelica.SIunits.Time ahu.senTemEx2.tau(unit = "s", min = 0.0) = 1 
    "Time constant at nominal flow rate (use tau=0 for steady-state sensor, but see user guide for potential problems)";
  parameter Modelica.Blocks.Types.Init ahu.senTemEx2.initType = Modelica.Blocks.Types.Init.
    InitialState "Type of initialization (InitialState and InitialOutput are identical)";
  parameter Boolean ahu.senTemEx2.dynamic = ahu.senTemEx2.tau > 1E-10 or 
    ahu.senTemEx2.tau < -1E-10 "Flag, true if the sensor is a dynamic sensor";
  parameter Real ahu.senTemEx2.tauInv(unit = "s-1") = (if ahu.senTemEx2.dynamic
     then 1/ahu.senTemEx2.tau else 0) "Inverse of tau";
  parameter Modelica.SIunits.Temperature ahu.senTemEx2.T_start(start = 288.15, 
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 0.0) = 293.15 
    "Initial or guess value of output (= state)";
  parameter Boolean ahu.senTemEx2.transferHeat = false "if true, temperature T converges towards TAmb when no flow";
  parameter Modelica.SIunits.Temperature ahu.senTemEx2.TAmb(start = 288.15, 
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 0.0) = 293.15 
    "Fixed ambient temperature for heat transfer";
  parameter Modelica.SIunits.Time ahu.senTemEx2.tauHeaTra(unit = "s", min = 1.0)
     = 1200 "Time constant for heat transfer, default 20 minutes";
  parameter Real ahu.senTemEx2.tauHeaTraInv(unit = "1/s") = (if ahu.senTemEx2.tauHeaTra
     < 1E-10 then 0 else 1/ahu.senTemEx2.tauHeaTra) "Dummy parameter to avoid division by tauHeaTra";
  parameter Real ahu.senTemEx2.ratTau = (if ahu.senTemEx2.dynamic then 
    ahu.senTemEx2.tauHeaTra/ahu.senTemEx2.tau else 1) "Ratio of tau";
  constant Boolean ahu.senTemIn1.allowFlowReversal = false "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.senTemIn1.m_flow_nominal(unit = 
    "kg/s", min = 0.0) = ahu.m_flow_nominal "Nominal mass flow rate, used for regularization near zero flow";
  parameter Modelica.SIunits.MassFlowRate ahu.senTemIn1.m_flow_small(unit = 
    "kg/s", min = 0.0) = 0.0001*ahu.senTemIn1.m_flow_nominal "For bi-directional flow, temperature is regularized in the region |m_flow| < m_flow_small (m_flow_small > 0 required)";
  parameter Modelica.SIunits.Time ahu.senTemIn1.tau(unit = "s", min = 0.0) = 1 
    "Time constant at nominal flow rate (use tau=0 for steady-state sensor, but see user guide for potential problems)";
  parameter Modelica.Blocks.Types.Init ahu.senTemIn1.initType = Modelica.Blocks.Types.Init.
    InitialState "Type of initialization (InitialState and InitialOutput are identical)";
  parameter Boolean ahu.senTemIn1.dynamic = ahu.senTemIn1.tau > 1E-10 or 
    ahu.senTemIn1.tau < -1E-10 "Flag, true if the sensor is a dynamic sensor";
  parameter Real ahu.senTemIn1.tauInv(unit = "s-1") = (if ahu.senTemIn1.dynamic
     then 1/ahu.senTemIn1.tau else 0) "Inverse of tau";
  parameter Modelica.SIunits.Temperature ahu.senTemIn1.T_start(start = 288.15, 
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 0.0) = 293.15 
    "Initial or guess value of output (= state)";
  parameter Boolean ahu.senTemIn1.transferHeat = false "if true, temperature T converges towards TAmb when no flow";
  parameter Modelica.SIunits.Temperature ahu.senTemIn1.TAmb(start = 288.15, 
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 0.0) = 293.15 
    "Fixed ambient temperature for heat transfer";
  parameter Modelica.SIunits.Time ahu.senTemIn1.tauHeaTra(unit = "s", min = 1.0)
     = 1200 "Time constant for heat transfer, default 20 minutes";
  parameter Real ahu.senTemIn1.tauHeaTraInv(unit = "1/s") = (if ahu.senTemIn1.tauHeaTra
     < 1E-10 then 0 else 1/ahu.senTemIn1.tauHeaTra) "Dummy parameter to avoid division by tauHeaTra";
  parameter Real ahu.senTemIn1.ratTau = (if ahu.senTemIn1.dynamic then 
    ahu.senTemIn1.tauHeaTra/ahu.senTemIn1.tau else 1) "Ratio of tau";
  constant Boolean ahu.senTemIn3.allowFlowReversal = false "= false to simplify equations, assuming, but not enforcing, no flow reversal";
  parameter Modelica.SIunits.MassFlowRate ahu.senTemIn3.m_flow_nominal(unit = 
    "kg/s", min = 0.0) = ahu.m_flow_nominal "Nominal mass flow rate, used for regularization near zero flow";
  parameter Modelica.SIunits.MassFlowRate ahu.senTemIn3.m_flow_small(unit = 
    "kg/s", min = 0.0) = 0.0001*ahu.senTemIn3.m_flow_nominal "For bi-directional flow, temperature is regularized in the region |m_flow| < m_flow_small (m_flow_small > 0 required)";
  parameter Modelica.SIunits.Time ahu.senTemIn3.tau(unit = "s", min = 0.0) = 1 
    "Time constant at nominal flow rate (use tau=0 for steady-state sensor, but see user guide for potential problems)";
  parameter Modelica.Blocks.Types.Init ahu.senTemIn3.initType = Modelica.Blocks.Types.Init.
    InitialState "Type of initialization (InitialState and InitialOutput are identical)";
  parameter Boolean ahu.senTemIn3.dynamic = ahu.senTemIn3.tau > 1E-10 or 
    ahu.senTemIn3.tau < -1E-10 "Flag, true if the sensor is a dynamic sensor";
  parameter Real ahu.senTemIn3.tauInv(unit = "s-1") = (if ahu.senTemIn3.dynamic
     then 1/ahu.senTemIn3.tau else 0) "Inverse of tau";
  parameter Modelica.SIunits.Temperature ahu.senTemIn3.T_start(start = 288.15, 
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 0.0) = 293.15 
    "Initial or guess value of output (= state)";
  parameter Boolean ahu.senTemIn3.transferHeat = false "if true, temperature T converges towards TAmb when no flow";
  parameter Modelica.SIunits.Temperature ahu.senTemIn3.TAmb(start = 288.15, 
    nominal = 300.0, unit = "K", displayUnit = "degC", min = 0.0) = 293.15 
    "Fixed ambient temperature for heat transfer";
  parameter Modelica.SIunits.Time ahu.senTemIn3.tauHeaTra(unit = "s", min = 1.0)
     = 1200 "Time constant for heat transfer, default 20 minutes";
  parameter Real ahu.senTemIn3.tauHeaTraInv(unit = "1/s") = (if ahu.senTemIn3.tauHeaTra
     < 1E-10 then 0 else 1/ahu.senTemIn3.tauHeaTra) "Dummy parameter to avoid division by tauHeaTra";
  parameter Real ahu.senTemIn3.ratTau = (if ahu.senTemIn3.dynamic then 
    ahu.senTemIn3.tauHeaTra/ahu.senTemIn3.tau else 1) "Ratio of tau";
  parameter Real ahu.add.k1 = 1 "Gain of input signal 1";
  parameter Real ahu.add.k2 = 1 "Gain of input signal 2";
  constant Integer ahu.outEx.nPorts = 1 "Number of ports";
  constant Boolean ahu.outEx.verifyInputs = true "Set to true to stop the simulation with an error if the medium temperature is outside its allowable range";
  parameter Modelica.Fluid.Types.PortFlowDirection ahu.outEx.flowDirection = 
    Modelica.Fluid.Types.PortFlowDirection.Bidirectional "Allowed flow direction";
  constant Boolean ahu.outEx.medium.preferredMediumStates = false 
    "= true if StateSelect.prefer shall be used for the independent property variables of the medium";
  parameter Boolean ahu.outEx.medium.standardOrderComponents = true 
    "If true, and reducedX = true, the last element of X will be computed from the other ones";

  Modelica.Media.Interfaces.PartialMedium.MassFlowRate ahu.fanSu.port_a.m_flow(
    unit = "kg/s", min = -1E+60, max = 100000.0) "Mass flow rate from the connection point into the component";
  Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanSu.port_a.p(start = 101325,
     nominal = 100000.0, unit = "Pa", displayUnit = "bar", min = 0.0, max = 
    100000000.0) "Thermodynamic pressure in the connection point";
  Modelica.Media.Interfaces.Types.SpecificEnthalpy ahu.fanSu.port_a.h_outflow(
    start = ahu.fanSu.h_outflow_start, nominal = 45300.945, unit = "J/kg", 
    min = -10000000000.0, max = 10000000000.0) "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
  Modelica.Media.Interfaces.Types.MassFraction ahu.fanSu.port_a.Xi_outflow[1](
    nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
  Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanSu.port_a.C_outflow[1](
    start = fill(1.0, size(ahu.fanSu.port_a.C_outflow, 1)), min = 0.0) 
    "Properties c_i/m close to the connection point if m_flow < 0";
  Modelica.Media.Interfaces.PartialMedium.MassFlowRate ahu.fanSu.port_b.m_flow(
    unit = "kg/s", min = -100000.0, max = 1E+60) "Mass flow rate from the connection point into the component";
  Modelica.Media.Interfaces.Types.AbsolutePressure ahu.fanSu.port_b.p(start = 
    ahu.fanSu.p_start, nominal = 100000.0, unit = "Pa", displayUnit = "bar", 
    min = 0.0, max = 100000000.0) "Thermodynamic pressure in the connection point";
  Modelica.Media.Interfaces.Types.SpecificEnthalpy ahu.fanSu.port_b.h_outflow(
    start = ahu.fanSu.h_outflow_start, nominal = 45300.945, unit = "J/kg", 
    min = -10000000000.0, max = 10000000000.0) "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
  Modelica.Media.Interfaces.Types.MassFraction ahu.fanSu.port_b.Xi_outflow[1](
    nominal = 0.1, unit = "kg/kg", min = 0.0, max = 1.0) "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
  Modelica.Media.Interfaces.Types.ExtraProperty ahu.fanSu.port_b.C_outflow[1](
    start = fill(1.0, size(ahu.fanSu.port_b.C_outflow, 1)), min = 0.0) 
    "Properties c_i/m close to the connection point if m_flow < 0";
  Modelica.SIunits.MassFlowRate ahu.fanSu.m_flow(start = ahu.fanSu._m_flow_start,
     unit = "kg/s") = ahu.fanSu.port_a.m_flow "Mass flow rate from port_a to port_b (m_flow > 0 is design flow direction)";
  Modelica.SIunits.PressureDifference ahu.fanSu.dp(start = ahu.fanSu._dp_start, 
    unit = "Pa", displayUnit = "Pa") = ahu.fanSu.port_a.p-ahu.fanSu.port_b.p 
    "Pressure difference between port_a and port_b";
  Modelica.Blocks.Interfaces.RealOutput ahu.fanSu.y_actual(unit = "1") 
    "Actual normalised pump speed that is used for computations";
  Modelica.Blocks.Interfaces.RealOutput ahu.fanSu.P(unit = "W") "Electrical power consumed";
  Modelica.SIunits.Temperature ahu.fanSu.heatPort.T(start = 288.15, nominal = 
    300.0, unit = "K", displayUnit = "degC", min = 0.0) "Port temperature";
  Modelica.SIunits.HeatFlowRate ahu.fanSu.heatPort.Q_flow(unit = "W") 
    "Heat flow rate (positive if flowing from outside into the component)";
  Modelica.SIunits.VolumeFlowRate ahu.fanSu.VMachine_flow(start = 
